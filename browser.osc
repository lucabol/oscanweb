// OscaWeb — A minimal SDI web browser with Vim-like keybindings
// Written in Oscan. JavaScript via embedded QuickJS-ng engine.

use "url.osc"
use "html.osc"
use "http.osc"
use "http_cache.osc"
use "css.osc"
use "js.osc"
use "storage.osc"
use "vlog.osc"
use "libs/ui.osc"

// ─── Constants ───────────────────────────────────────────

let CHROME_TOP: i32 = 30;
let CHROME_BOT: i32 = 20;
let FONT_W: i32 = 8;
// Body text defaults to the 12-row (_L) font variants — glyph advance stays
// 8 px, but vertical cell is 12 rows.  FONT_H / LINE_H reflect that so the
// body layout reserves enough vertical room.
let FONT_H: i32 = 12;
let LINE_H: i32 = 20;
let PAD: i32 = 10;
let MAX_REDIRECTS: i32 = 5;

// ─── Font rendering helpers ─────────────────────────────
// Font id constants (FONT_DEFAULT, FONT_PROPORTIONAL, FONT_*_L, ...) are
// defined in libs/ui.osc and imported via `use "libs/ui.osc"` above.  The
// bundled fonts come in two cell heights: 8-row (compact) and 12-row (_L).
// Body text uses the 12-row proportional variant by default; scale is an
// integer multiplier applied uniformly on top.

// Body text defaults.  Headings override scale; <pre>/<code>/<table> override
// font to FONT_DEFAULT_L (the 12-row fixed-width variant) so mono runs keep
// the same vertical metrics as surrounding body text.
let BODY_FONT: i32 = FONT_PROPORTIONAL_L;
let BODY_MONO_FONT: i32 = FONT_DEFAULT_L;

// ─── TrueType helpers ──────────────────────────────────
// When the UI toggles TrueType rendering on, body text (pages, link
// labels, table cells) goes through tt_* instead of gfx_draw_text.
// Chrome (URL bar, homepage, help, source-view) always stays on the
// bitmap font.
//
// TT state is threaded as three parameters through the render chain:
//   tt_reg: handle     regular (proportional) TT handle, or 0 if unloaded
//   tt_mono: handle    monospace TT handle, or 0 if unloaded
//   tt_cfg: [i32]      [enabled, body_px, mono_px,
//                       reg_ascent, reg_line_h, reg_space_w,
//                       mono_ascent, mono_line_h, mono_space_w]
//
// Metrics at indices 3..8 are cached at load/toggle time so pure metric
// helpers (text_width_f, line_h_of, glyph_h_of) don't have to invoke
// `tt_*` on every call.

// TT config array indices.
let TTC_ENABLED: i32 = 0;
let TTC_BODY_PX: i32 = 1;        // Effective (possibly scaled by small_font)
let TTC_MONO_PX: i32 = 2;
let TTC_REG_ASCENT: i32 = 3;
let TTC_REG_LINEH: i32 = 4;
let TTC_REG_SPACEW: i32 = 5;
let TTC_MONO_ASCENT: i32 = 6;
let TTC_MONO_LINEH: i32 = 7;
let TTC_MONO_SPACEW: i32 = 8;
// Heading (Trebuchet / Lucida / Verdana / Tahoma / Arial fallback).
// Uses the same pixel size as body text; heading tags scale via child_scale.
// Zero values mean "no head font loaded" — dispatchers then fall back to the
// body (tt_reg) handle.
let TTC_HEAD_ASCENT: i32 = 9;
let TTC_HEAD_LINEH: i32 = 10;
let TTC_HEAD_SPACEW: i32 = 11;
let TTC_BASE_BODY_PX: i32 = 12;   // "12pt" size, what Ctrl+/- adjusts
let TTC_BASE_MONO_PX: i32 = 13;
let TTC_LEN: i32 = 14;

// Recompute effective sizes + cached metrics.  Called whenever the TT
// state changes (toggle, size change, small_font flip).  When small
// mode is on, effective size is ~70% of base so the 8pt/12pt chrome
// button visibly shrinks TT text too.
fn! tt_recache(tt_reg: handle, tt_mono: handle, tt_head: handle, tt_cfg: [i32], small_font: bool) {
    let body_base: i32 = tt_cfg[TTC_BASE_BODY_PX];
    let mono_base: i32 = tt_cfg[TTC_BASE_MONO_PX];
    let mut body_eff: i32 = if small_font { (body_base * 7) / 10 } else { body_base };
    let mut mono_eff: i32 = if small_font { (mono_base * 7) / 10 } else { mono_base };
    if body_eff < 8 { body_eff = 8; };
    if mono_eff < 8 { mono_eff = 8; };
    tt_cfg[TTC_BODY_PX] = body_eff;
    tt_cfg[TTC_MONO_PX] = mono_eff;
    if (tt_reg as i64) != (0 as i64) {
        tt_cfg[TTC_REG_ASCENT] = tt_ascent(tt_reg, body_eff as f64);
        tt_cfg[TTC_REG_LINEH] = tt_line_height(tt_reg, body_eff as f64);
        tt_cfg[TTC_REG_SPACEW] = tt_text_width(tt_reg, " ", body_eff as f64);
    };
    if (tt_mono as i64) != (0 as i64) {
        tt_cfg[TTC_MONO_ASCENT] = tt_ascent(tt_mono, mono_eff as f64);
        tt_cfg[TTC_MONO_LINEH] = tt_line_height(tt_mono, mono_eff as f64);
        tt_cfg[TTC_MONO_SPACEW] = tt_text_width(tt_mono, " ", mono_eff as f64);
    };
    if (tt_head as i64) != (0 as i64) {
        tt_cfg[TTC_HEAD_ASCENT] = tt_ascent(tt_head, body_eff as f64);
        tt_cfg[TTC_HEAD_LINEH] = tt_line_height(tt_head, body_eff as f64);
        tt_cfg[TTC_HEAD_SPACEW] = tt_text_width(tt_head, " ", body_eff as f64);
    } else {
        tt_cfg[TTC_HEAD_ASCENT] = 0;
        tt_cfg[TTC_HEAD_LINEH] = 0;
        tt_cfg[TTC_HEAD_SPACEW] = 0;
    };
}

// Is TT active for body rendering?  Requires both "enabled" flag and a
// valid regular handle.
fn tt_on(tt_reg: handle, tt_cfg: [i32]) -> bool {
    tt_cfg[TTC_ENABLED] != 0 and (tt_reg as i64) != (0 as i64)
}

// Try each file path in order and return the first successfully loaded
// TrueType handle, or 0 if every path fails.  Used to build per-face
// fallback chains (Georgia→Times→Arial, Trebuchet→Lucida→Verdana→…).
fn! tt_load_first(paths: [str]) -> handle {
    let mut out: handle = (0 as i64) as handle;
    let mut done: bool = false;
    let n: i32 = len(paths);
    for pi in 0..n {
        if not done {
            match read_file(paths[pi]) {
                Result::Ok(fb) => {
                    match tt_load(fb) {
                        Result::Ok(h) => { out = h; done = true; },
                        Result::Err(_) => {},
                    };
                },
                Result::Err(_) => {},
            };
        };
    };
    out
}

// Mono bitmap font ids that route to the mono TT handle.
fn is_mono_font_id(font: i32) -> bool {
    font == 0 or font == 4 or font == 2 or font == 6
}

// Heading virtual font id (no matching bitmap glyph set).
fn is_heading_font_id(font: i32) -> bool {
    font == FONT_HEADING_L
}

// Map virtual heading font id back to a real bitmap id for gfx_* calls.
fn bitmap_font_of(font: i32) -> i32 {
    if font == FONT_HEADING_L { FONT_PROPORTIONAL_L } else { font }
}

// Bitmap line height: FONT_H is the glyph cell (12 rows); the +10 of leading
// gives room for the underline at gh+2 plus a visible gap before the next
// line's glyph top.  Using +8 made underlined links in lists visually merge
// with the next item.
fn line_h_of(scale: i32) -> i32 { FONT_H * scale + 10 }

// CSS line-height override helper: prefer computed style if set,
// otherwise the scale-derived default.  A multiplier (unitless / %
// / "normal") is resolved against the current rendered font size so
// it tracks user-adjustable TT body size.  Absolute px values (set
// via explicit px/em/pt) are used verbatim.
fn effective_line_h(styles: [ComputedStyle], idx: i32, scale: i32,
                    tt_reg: handle, tt_cfg: [i32], font: i32) -> i32 {
    // Bitmap-mode minimum: the underline sits at gh+2, so any line-height
    // tighter than gh+4 makes underlined links touch the next line.  Floor
    // CSS line-height to this minimum in bitmap mode.
    let bmp_min: i32 = if tt_on(tt_reg, tt_cfg) { 0 } else { FONT_H * scale + 8 };
    if idx >= 0 and idx < len(styles) {
        let mul: i32 = styles[idx].line_height_mul_x100;
        if mul > 0 {
            let em: i32 = if tt_on(tt_reg, tt_cfg) {
                let px: i32 = if is_mono_font_id(font) { tt_cfg[TTC_MONO_PX] } else { tt_cfg[TTC_BODY_PX] };
                px * scale
            } else {
                FONT_H * scale
            };
            let out: i32 = (em * mul + 50) / 100;
            let floored: i32 = if out < bmp_min { bmp_min } else { out };
            if floored > 0 { return floored; };
        };
        if styles[idx].line_height_px > 0 {
            let px_out: i32 = styles[idx].line_height_px;
            return if px_out < bmp_min { bmp_min } else { px_out };
        };
    };
    tt_line_h_of(scale, tt_reg, tt_cfg, font)
}
fn glyph_h_of(scale: i32) -> i32 { FONT_H * scale }

// TT-aware line/glyph height.  When TT is on, returns cached TT metrics
// scaled by `scale`; otherwise bitmap metrics.
fn tt_line_h_of(scale: i32, tt_reg: handle, tt_cfg: [i32], font: i32) -> i32 {
    if tt_on(tt_reg, tt_cfg) {
        if is_mono_font_id(font) {
            tt_cfg[TTC_MONO_LINEH] * scale + 4
        } else if is_heading_font_id(font) and tt_cfg[TTC_HEAD_LINEH] > 0 {
            tt_cfg[TTC_HEAD_LINEH] * scale + 4
        } else {
            tt_cfg[TTC_REG_LINEH] * scale + 4
        }
    } else {
        line_h_of(scale)
    }
}

fn tt_glyph_h_of(scale: i32, tt_reg: handle, tt_cfg: [i32], font: i32) -> i32 {
    if tt_on(tt_reg, tt_cfg) {
        if is_mono_font_id(font) {
            tt_cfg[TTC_MONO_LINEH] * scale
        } else if is_heading_font_id(font) and tt_cfg[TTC_HEAD_LINEH] > 0 {
            tt_cfg[TTC_HEAD_LINEH] * scale
        } else {
            tt_cfg[TTC_REG_LINEH] * scale
        }
    } else {
        glyph_h_of(scale)
    }
}

// Pure text width dispatcher.  When TT is off it's a simple multiply.
// When TT is on it queries tt_text_width, which is impure; hence the
// whole helper is `fn!`.
fn! text_width_f(s: str, font: i32, scale: i32,
                 tt_reg: handle, tt_mono: handle, tt_head: handle, tt_cfg: [i32]) -> i32 {
    if tt_on(tt_reg, tt_cfg) {
        let h: handle = if is_mono_font_id(font) {
            tt_mono
        } else if is_heading_font_id(font) and (tt_head as i64) != (0 as i64) {
            tt_head
        } else {
            tt_reg
        };
        let px: i32 = if is_mono_font_id(font) { tt_cfg[TTC_MONO_PX] } else { tt_cfg[TTC_BODY_PX] };
        if (h as i64) != (0 as i64) {
            tt_text_width(h, s, (px * scale) as f64)
        } else {
            gfx_text_width(ascii_fold_utf8(s), bitmap_font_of(font)) * scale
        }
    } else {
        gfx_text_width(ascii_fold_utf8(s), bitmap_font_of(font)) * scale
    }
}

// Heading scale lookup.  h1 biggest, h2/h3 medium, h4..h6 use color/bold only.
fn heading_scale(tag: str) -> i32 {
    if str_eq(tag, "h1") { 2 }
    else if str_eq(tag, "h2") { 2 }
    else if str_eq(tag, "h3") { 1 }
    else { 1 }
}

fn is_mono_tag(tag: str) -> bool {
    str_eq(tag, "pre") or str_eq(tag, "code") or str_eq(tag, "kbd") or
    str_eq(tag, "samp") or str_eq(tag, "tt") or str_eq(tag, "var")
}

fn! draw_text_f(x: i32, y: i32, s: str, color: i32, font: i32, scale: i32,
                tt_reg: handle, tt_mono: handle, tt_head: handle, tt_cfg: [i32]) -> i32 {
    if tt_on(tt_reg, tt_cfg) {
        let h: handle = if is_mono_font_id(font) {
            tt_mono
        } else if is_heading_font_id(font) and (tt_head as i64) != (0 as i64) {
            tt_head
        } else {
            tt_reg
        };
        let px: i32 = if is_mono_font_id(font) { tt_cfg[TTC_MONO_PX] } else { tt_cfg[TTC_BODY_PX] };
        if (h as i64) != (0 as i64) {
            // `y` is the top-left of a bitmap glyph cell; TT uses
            // baseline.  Add ascent and a small leading fudge so the
            // baseline lands where the bitmap font's baseline would.
            let ascent: i32 = if is_mono_font_id(font) {
                tt_cfg[TTC_MONO_ASCENT]
            } else if is_heading_font_id(font) and tt_cfg[TTC_HEAD_ASCENT] > 0 {
                tt_cfg[TTC_HEAD_ASCENT]
            } else {
                tt_cfg[TTC_REG_ASCENT]
            };
            let baseline: i32 = y + ascent * scale + 2;
            // OscaWeb colors are packed as 0x00RRGGBB (alpha byte = 0).
            // tt_draw_text uses the alpha channel as coverage weight, so
            // we must force full alpha or the glyph renders invisibly.
            let tt_color: i32 = bor(color, bshl(255, 24));
            tt_draw_text(x, baseline, s, h, (px * scale) as f64, tt_color)
        } else {
            let folded: str = ascii_fold_utf8(s);
            if scale <= 1 {
                gfx_draw_text(x, y, folded, color, bitmap_font_of(font))
            } else {
                gfx_draw_text_scaled(x, y, folded, color, scale, scale, bitmap_font_of(font))
            }
        }
    } else {
        let folded2: str = ascii_fold_utf8(s);
        if scale <= 1 {
            gfx_draw_text(x, y, folded2, color, bitmap_font_of(font))
        } else {
            gfx_draw_text_scaled(x, y, folded2, color, scale, scale, bitmap_font_of(font))
        }
    }
}

// Colors — themed (dark + light variants, indexed into a runtime theme array)
// The theme array is built once per frame by theme_make(light_mode) and
// passed through the render pipeline so light/dark mode can swap without
// module-level mutable state (which Oscan doesn't support).
let T_BG: i32 = 0;
let T_FG: i32 = 1;
let T_LINK: i32 = 2;
let T_H1: i32 = 3;
let T_H2: i32 = 4;
let T_H3: i32 = 5;
let T_BOLD: i32 = 6;
let T_EM: i32 = 7;
let T_CODE_FG: i32 = 8;
let T_HINT_BG: i32 = 9;
let T_HINT_FG: i32 = 10;
let T_STATUS_BG: i32 = 11;
let T_HR: i32 = 12;
let T_PRE_BG: i32 = 13;
let T_SEARCH_HL: i32 = 14;
let T_SEL: i32 = 15;
let T_QUOTE: i32 = 16;
let T_QUOTE_BAR: i32 = 17;
let T_MARK_BG: i32 = 18;
let T_DT: i32 = 19;
let T_FIGCAP: i32 = 20;
let T_TABLE_BORDER: i32 = 21;
let T_TABLE_HEADER_BG: i32 = 22;
let T_LEN: i32 = 23;

fn! theme_make(light: bool) -> [i32] {
    let mut t: [i32] = [];
    for _i in 0..T_LEN { push(t, 0); };
    if light {
        // Palette tuned to a printable near-white light theme:
        //   --color-text: #000; --color-border: #e0e0e0;
        //   --color-code-bg: #fbfbff; --color-table-header: #f5f5ff;
        //   --color-muted: #666;
        t[T_BG]              = 255 * 65536 + 255 * 256 + 255;
        t[T_FG]              =   0 * 65536 +   0 * 256 +   0;
        t[T_LINK]            =   0 * 65536 + 102 * 256 + 204;
        t[T_H1]              =   0 * 65536 +   0 * 256 +   0;
        t[T_H2]              =   0 * 65536 +   0 * 256 +   0;
        t[T_H3]              =   0 * 65536 +   0 * 256 +   0;
        t[T_BOLD]            =   0 * 65536 +   0 * 256 +   0;
        t[T_EM]              =   0 * 65536 +   0 * 256 +   0;
        t[T_CODE_FG]         =   0 * 65536 +   0 * 256 +   0;
        t[T_HINT_BG]         = 255 * 65536 + 220 * 256 +   0;
        t[T_HINT_FG]         =   0 * 65536 +   0 * 256 +   0;
        t[T_STATUS_BG]       = 245 * 65536 + 245 * 256 + 255;   // #f5f5ff
        t[T_HR]              = 224 * 65536 + 224 * 256 + 224;   // #e0e0e0
        t[T_PRE_BG]          = 251 * 65536 + 251 * 256 + 255;   // #fbfbff
        t[T_SEARCH_HL]       = 255 * 65536 + 235 * 256 + 100;
        t[T_SEL]             = 180 * 65536 + 210 * 256 + 250;
        t[T_QUOTE]           = 102 * 65536 + 102 * 256 + 102;   // #666
        t[T_QUOTE_BAR]       =   0 * 65536 + 102 * 256 + 204;
        t[T_MARK_BG]         = 255 * 65536 + 240 * 256 + 120;
        t[T_DT]              =   0 * 65536 +   0 * 256 +   0;
        t[T_FIGCAP]          = 102 * 65536 + 102 * 256 + 102;   // #666
        t[T_TABLE_BORDER]    = 224 * 65536 + 224 * 256 + 224;   // #e0e0e0
        t[T_TABLE_HEADER_BG] = 245 * 65536 + 245 * 256 + 255;   // #f5f5ff
    } else {
        t[T_BG]              =  30 * 65536 +  30 * 256 +  34;
        t[T_FG]              = 220 * 65536 + 220 * 256 + 220;
        t[T_LINK]            = 100 * 65536 + 149 * 256 + 237;
        t[T_H1]              = 255 * 65536 + 255 * 256 + 255;
        t[T_H2]              = 200 * 65536 + 200 * 256 + 200;
        t[T_H3]              = 170 * 65536 + 180 * 256 + 220;
        t[T_BOLD]            = 255 * 65536 + 255 * 256 + 220;
        t[T_EM]              = 255 * 65536 + 230 * 256 + 180;
        t[T_CODE_FG]         = 180 * 65536 + 220 * 256 + 180;
        t[T_HINT_BG]         = 255 * 65536 + 220 * 256 +   0;
        t[T_HINT_FG]         =   0 * 65536 +   0 * 256 +   0;
        t[T_STATUS_BG]       =  40 * 65536 +  40 * 256 +  44;
        t[T_HR]              =  80 * 65536 +  80 * 256 +  85;
        t[T_PRE_BG]          =  45 * 65536 +  45 * 256 +  50;
        t[T_SEARCH_HL]       = 255 * 65536 + 255 * 256 + 100;
        t[T_SEL]             =  80 * 65536 + 140 * 256 + 220;
        t[T_QUOTE]           = 160 * 65536 + 170 * 256 + 190;
        t[T_QUOTE_BAR]       =  80 * 65536 + 120 * 256 + 200;
        t[T_MARK_BG]         = 200 * 65536 + 180 * 256 +  50;
        t[T_DT]              = 240 * 65536 + 240 * 256 + 255;
        t[T_FIGCAP]          = 140 * 65536 + 140 * 256 + 150;
        t[T_TABLE_BORDER]    =  90 * 65536 +  90 * 256 + 100;
        t[T_TABLE_HEADER_BG] =  50 * 65536 +  50 * 256 +  60;
    };
    t
}

// Build a UI_C_LEN-element array for ui_button / ui_textbox from a theme.
// Light mode gets a white-on-black button/urlbar palette that matches the
// --color-text / --color-border CSS pair; dark mode keeps the legacy look.
fn! theme_make_ui(light: bool) -> [i32] {
    let mut u: [i32] = [];
    for _i in 0..UI_C_LEN { push(u, 0); };
    if light {
        u[UI_C_BG]        = 255 * 65536 + 255 * 256 + 255;   // #fff
        u[UI_C_BG_HOVER]  = 240 * 65536 + 240 * 256 + 248;   // #f0f0f8
        u[UI_C_BG_ACTIVE] = 232 * 65536 + 232 * 256 + 240;   // #e8e8f0
        u[UI_C_FG]        =   0 * 65536 +   0 * 256 +   0;   // #000
        u[UI_C_FG_DIM]    = 102 * 65536 + 102 * 256 + 102;   // #666
        u[UI_C_BORDER]    = 224 * 65536 + 224 * 256 + 224;   // #e0e0e0
        u[UI_C_ACCENT]    =   0 * 65536 + 102 * 256 + 204;
    } else {
        u[UI_C_BG]        =  45 * 65536 +  45 * 256 +  48;
        u[UI_C_BG_HOVER]  =  62 * 65536 +  62 * 256 +  66;
        u[UI_C_BG_ACTIVE] =  37 * 65536 +  37 * 256 +  38;
        u[UI_C_FG]        = 220 * 65536 + 220 * 256 + 220;
        u[UI_C_FG_DIM]    = 150 * 65536 + 150 * 256 + 150;
        u[UI_C_BORDER]    =  80 * 65536 +  80 * 256 +  85;
        u[UI_C_ACCENT]    =   0 * 65536 + 122 * 256 + 204;
    };
    u
}

let KEY_ESC: i32 = 27;
let KEY_ENTER: i32 = 13;

// ─── Browser Mode ────────────────────────────────────────

enum BrowserMode {
    Normal,
    Insert,
    Follow,
    Search,
}

// ─── Link Info ───────────────────────────────────────────

struct LinkInfo {
    x: i32,
    y: i32,
    w: i32,
    h: i32,
    href: str,
    label: str,
    // True when this link is inside site chrome (nav/aside/header/footer,
    // or a node with a landmark role).  Used by the `F` hint mode to
    // label only chrome links, complementing `f` which labels all.
    chrome: bool,
}

// ─── Word position map (for text selection) ─────────────

struct WordInfo {
    x: i32,
    y: i32,
    w: i32,
    text: str,
}

// ─── Clickable element info (for onclick handlers) ──────

struct ClickInfo {
    x: i32,
    y: i32,
    w: i32,
    h: i32,
    node_idx: i32,
}

// ─── Image Cache ─────────────────────────────────────────
// img_cache_idx: map from URL -> index string (i32 as str)
// img_cache_data: array of pixel-only arrays (no w/h header)
// img_cache_w / img_cache_h: parallel arrays of dimensions

let IMG_MAX_W: i32 = 1000;

// Nearest-neighbor downscale: src pixels (src_w x src_h) -> dst pixels (dst_w x dst_h)
fn! img_scale(src_px: [i32], src_w: i32, src_h: i32, dst_w: i32, dst_h: i32) -> [i32] {
    let mut dst: [i32] = [];
    for dy in 0..dst_h {
        let sy: i32 = dy * src_h / dst_h;
        for dx in 0..dst_w {
            let sx: i32 = dx * src_w / dst_w;
            push(dst, src_px[sy * src_w + sx]);
        };
    };
    dst
}

fn! img_fetch_and_decode(src: str, base_scheme: str, base_host: str, base_port: i32, base_path: str,
                         img_cache_idx: map, img_cache_data: [[i32]],
                         img_cache_w: [i32], img_cache_h: [i32]) -> i32 {
    // Check cache
    if map_has(img_cache_idx, src) {
        let idx_str: str = map_get(img_cache_idx, src);
        let pr: Result<i32, str> = parse_i32(idx_str);
        match pr {
            Result::Ok(idx) => { return idx; },
            Result::Err(_e) => { return -1; },
        };
    };

    // Resolve URL
    let mut img_host: str = base_host;
    let mut img_port: i32 = base_port;
    let mut img_path: str = src;
    let mut img_tls: bool = str_eq(base_scheme, "https");

    if str_contains(src, "://") {
        let u: Url = url_parse(src);
        img_host = u.host;
        img_port = u.port;
        img_path = u.path;
        img_tls = str_eq(u.scheme, "https");
    } else if str_starts_with(src, "//") {
        let u: Url = url_parse(str_concat(base_scheme, ":{src}"));
        img_host = u.host;
        img_port = u.port;
        img_path = u.path;
        img_tls = str_eq(u.scheme, "https");
    } else {
        img_path = url_resolve_relative(base_path, src);
    };

    // Skip data: URLs
    if str_starts_with(src, "data:") {
        map_set(img_cache_idx, src, "-1");
        return -1;
    };

    // Fetch image data
    let resp: HttpResponse = http_get(img_host, img_port, img_path, img_tls);
    if not resp.ok or str_len(resp.body) == 0 {
        map_set(img_cache_idx, src, "-1");
        return -1;
    };

    // Detect SVG by file extension or content type
    let is_svg: bool = str_ends_with(str_to_lower(img_path), ".svg") or
                       str_contains(str_to_lower(resp.content_type), "svg");

    // Decode image (SVG or raster)
    let mut decode_ok: bool = false;
    let mut dec_w: i32 = 0;
    let mut dec_h: i32 = 0;
    let mut dec_px: [i32] = [];

    if is_svg {
        // SVG: use intrinsic size (width=0, height=0 tells svg_load to use viewBox).
        // Only cap at IMG_MAX_W if the result is too wide (done below).
        let svg_result: Result<[i32], str> = svg_load(resp.body, 0, 0);
        match svg_result {
            Result::Ok(svg_raw) => {
                if len(svg_raw) >= 3 {
                    dec_w = svg_raw[0];
                    dec_h = svg_raw[1];
                    let svg_px_count: i32 = dec_w * dec_h;
                    // Composite SVG over white background for icons, since most
                    // SVG icons are dark shapes on transparent background. Using
                    // the dark page BG makes them invisible.
                    let bg_r: i32 = 240;
                    let bg_g: i32 = 240;
                    let bg_b: i32 = 240;
                    for spi in 0..svg_px_count {
                        let argb: i32 = svg_raw[spi + 2];
                        let alpha: i32 = band(bshr(argb, 24), 255);
                        let src_r: i32 = band(bshr(argb, 16), 255);
                        let src_g: i32 = band(bshr(argb, 8), 255);
                        let src_b: i32 = band(argb, 255);
                        let inv_a: i32 = 255 - alpha;
                        let out_r: i32 = (src_r * alpha + bg_r * inv_a) / 255;
                        let out_g: i32 = (src_g * alpha + bg_g * inv_a) / 255;
                        let out_b: i32 = (src_b * alpha + bg_b * inv_a) / 255;
                        push(dec_px, out_r * 65536 + out_g * 256 + out_b);
                    };
                    decode_ok = true;
                };
            },
            Result::Err(_se) => {},
        };
    } else {
        let decode_result: Result<[i32], str> = img_load(resp.body);
        match decode_result {
            Result::Ok(raw) => {
                if len(raw) >= 3 {
                    dec_w = raw[0];
                    dec_h = raw[1];
                    let raster_px_count: i32 = dec_w * dec_h;
                    for rpi in 0..raster_px_count {
                        push(dec_px, raw[rpi + 2]);
                    };
                    decode_ok = true;
                };
            },
            Result::Err(_re) => {},
        };
    };

    if not decode_ok {
        map_set(img_cache_idx, src, "-1");
        return -1;
    };

    // Scale down if wider than viewport
    let mut final_px: [i32] = dec_px;
    let mut final_w: i32 = dec_w;
    let mut final_h: i32 = dec_h;
    if dec_w > IMG_MAX_W {
        final_h = dec_h * IMG_MAX_W / dec_w;
        final_w = IMG_MAX_W;
        if final_h < 1 { final_h = 1; };
        final_px = img_scale(dec_px, dec_w, dec_h, final_w, final_h);
    };

    let cache_idx: i32 = len(img_cache_data);
    push(img_cache_data, final_px);
    push(img_cache_w, final_w);
    push(img_cache_h, final_h);
    let idx_str: str = i32_to_str(cache_idx);
    map_set(img_cache_idx, src, idx_str);
    cache_idx
}

// ─── Tag classification ─────────────────────────────────

fn html_is_block_tag(tag: str) -> bool {
    str_eq(tag, "div") or str_eq(tag, "p") or str_eq(tag, "h1") or
    str_eq(tag, "h2") or str_eq(tag, "h3") or str_eq(tag, "h4") or
    str_eq(tag, "h5") or str_eq(tag, "h6") or str_eq(tag, "ul") or
    str_eq(tag, "ol") or str_eq(tag, "li") or str_eq(tag, "pre") or
    str_eq(tag, "blockquote") or str_eq(tag, "table") or str_eq(tag, "tr") or
    str_eq(tag, "section") or str_eq(tag, "article") or str_eq(tag, "nav") or
    str_eq(tag, "header") or str_eq(tag, "footer") or str_eq(tag, "main") or
    str_eq(tag, "dl") or str_eq(tag, "dt") or str_eq(tag, "dd") or
    str_eq(tag, "figure") or str_eq(tag, "figcaption")
}

fn html_is_skip_tag(tag: str) -> bool {
    str_eq(tag, "head") or str_eq(tag, "script") or str_eq(tag, "style") or
    str_eq(tag, "meta") or str_eq(tag, "link") or str_eq(tag, "title")
}

// ─── Pre/code verbatim rendering ────────────────────────
// Flush a run of characters at the current cursor.  Shared between the
// newline-break path and the end-of-text trailing flush below.  Paints a
// theme[T_PRE_BG] band from the segment's start to the right edge of the content
// box (so adjacent inline children on the same line stitch into one
// contiguous background) and records a WordInfo so text selection works
// inside verbatim blocks.
fn! flush_pre_segment(segment_chars: [i32], x_ptr: [i32], y_ptr: [i32],
                      vp_top: i32, line_right: i32, line_left: i32,
                      color: i32, font: i32, scale: i32,
                      word_map: [WordInfo],
                      theme: [i32],
                      tt_reg: handle, tt_mono: handle, tt_head: handle, tt_cfg: [i32]) {
    let gh: i32 = tt_glyph_h_of(scale, tt_reg, tt_cfg, font);
    let lh: i32 = tt_line_h_of(scale, tt_reg, tt_cfg, font);
    let draw_y: i32 = y_ptr[0] - vp_top + CHROME_TOP;
    let visible: bool = draw_y + gh >= CHROME_TOP and draw_y < canvas_height() - CHROME_BOT;
    if len(segment_chars) > 0 {
        let seg: str = str_from_chars(segment_chars);
        let seg_w: i32 = text_width_f(seg, font, scale, tt_reg, tt_mono, tt_head, tt_cfg);
        if visible {
            let bg_x: i32 = x_ptr[0];
            let bg_w: i32 = line_right - bg_x;
            if bg_w > 0 { gfx_fill_rect(bg_x, draw_y, bg_w, lh, theme[T_PRE_BG]); };
            draw_text_f(x_ptr[0], draw_y, seg, color, font, scale, tt_reg, tt_mono, tt_head, tt_cfg);
            let wi: WordInfo = WordInfo { x: x_ptr[0], y: draw_y, w: seg_w, text: seg };
            push(word_map, wi);
        };
        x_ptr[0] = x_ptr[0] + seg_w;
    } else if x_ptr[0] == line_left {
        // Empty line: still paint the full-width band so the block reads
        // as one cohesive code rectangle rather than disconnected stripes.
        if visible {
            let bg_w2: i32 = line_right - line_left;
            if bg_w2 > 0 { gfx_fill_rect(line_left, draw_y, bg_w2, lh, theme[T_PRE_BG]); };
        };
    };
}

// ─── Text rendering with word-wrap ──────────────────────

fn! render_text(text: str, x_ptr: [i32], y_ptr: [i32], color: i32,
                font: i32, scale: i32,
                vp_top: i32, vp_width: i32, underline: bool,
                links: [LinkInfo], href: str, search_q: str,
                word_map: [WordInfo], strikethrough: bool, mark_bg: i32,
                indent: i32, in_chrome: bool,
                theme: [i32],
                tt_reg: handle, tt_mono: handle, tt_head: handle, tt_cfg: [i32]) {
    // Normalize whitespace: collapse \n, \r, \t into spaces so split by space
    // doesn't emit them as visible "words" (which render as missing-glyph ?).
    let raw_chars: [i32] = str_to_chars(text);
    let mut norm_chars: [i32] = [];
    for ci in 0..len(raw_chars) {
        let c: i32 = raw_chars[ci];
        if c == 10 or c == 13 or c == 9 { push(norm_chars, 32); }
        else { push(norm_chars, c); };
    };
    let normalized: str = str_from_chars(norm_chars);
    let words: [str] = str_split(normalized, " ");
    let max_x: i32 = vp_width - PAD;
    let lh: i32 = tt_line_h_of(scale, tt_reg, tt_cfg, font);
    let gh: i32 = tt_glyph_h_of(scale, tt_reg, tt_cfg, font);
    // Word gap: measured space width in current font, with a minimum so
    // proportional rendering doesn't collapse word boundaries.
    let raw_gap: i32 = text_width_f(" ", font, scale, tt_reg, tt_mono, tt_head, tt_cfg);
    let gap: i32 = if raw_gap < 3 * scale { 3 * scale } else { raw_gap };

    // Track link bounding box (first word position + accumulated width)
    let mut link_x: i32 = x_ptr[0];
    let mut link_y: i32 = y_ptr[0] - vp_top + CHROME_TOP;
    let mut link_w: i32 = 0;
    let mut link_recorded: bool = false;

    for word_idx in 0..len(words) {
        let word: str = words[word_idx];
        if str_len(word) == 0 { continue; };

        let word_w: i32 = text_width_f(word, font, scale, tt_reg, tt_mono, tt_head, tt_cfg);

        // Word wrap
        if x_ptr[0] + word_w > max_x and x_ptr[0] > indent + PAD {
            // If we wrapped to a new line, emit link for the previous line segment
            if str_len(href) > 0 and link_w > 0 and not link_recorded {
                let draw_y_check: i32 = link_y;
                if draw_y_check + gh >= CHROME_TOP and draw_y_check < canvas_height() - CHROME_BOT {
                    let li: LinkInfo = LinkInfo {
                        x: link_x, y: link_y, w: link_w, h: lh,
                        href: href, label: "", chrome: in_chrome,
                    };
                    push(links, li);
                    link_recorded = true;
                };
            };
            x_ptr[0] = indent + PAD;
            y_ptr[0] = y_ptr[0] + lh;
        };

        let draw_y: i32 = y_ptr[0] - vp_top + CHROME_TOP;

        if draw_y + gh >= CHROME_TOP and draw_y < canvas_height() - CHROME_BOT {
            // Mark background highlight
            if mark_bg >= 0 {
                gfx_fill_rect(x_ptr[0], draw_y, word_w, lh, mark_bg);
            };
            // Highlight search matches in this word
            if str_len(search_q) > 0 and str_contains(str_to_lower(word), search_q) {
                gfx_fill_rect(x_ptr[0], draw_y, word_w, lh, theme[T_SEARCH_HL]);
                draw_text_f(x_ptr[0], draw_y, word, theme[T_HINT_FG], font, scale, tt_reg, tt_mono, tt_head, tt_cfg);
            } else {
                draw_text_f(x_ptr[0], draw_y, word, color, font, scale, tt_reg, tt_mono, tt_head, tt_cfg);
            };
            if underline {
                // TT: draw just below the baseline (ascent + a few px of
                // leading).  Bitmap: near the bottom of the glyph cell.
                let ul_y: i32 = if tt_on(tt_reg, tt_cfg) {
                    let asc: i32 = if is_mono_font_id(font) {
                        tt_cfg[TTC_MONO_ASCENT]
                    } else if is_heading_font_id(font) and tt_cfg[TTC_HEAD_ASCENT] > 0 {
                        tt_cfg[TTC_HEAD_ASCENT]
                    } else {
                        tt_cfg[TTC_REG_ASCENT]
                    };
                    draw_y + asc * scale + 5
                } else {
                    // Bitmap: sit just below the glyph cell so descenders
                    // (p, g, y) don't touch the underline.
                    draw_y + gh + 2
                };
                gfx_line(x_ptr[0], ul_y, x_ptr[0] + word_w, ul_y, color);
            };
            if strikethrough {
                // TT: run through the x-height (roughly 0.35 of ascent
                // below the baseline, negative y).
                let sk_y: i32 = if tt_on(tt_reg, tt_cfg) {
                    let asc2: i32 = if is_mono_font_id(font) {
                        tt_cfg[TTC_MONO_ASCENT]
                    } else if is_heading_font_id(font) and tt_cfg[TTC_HEAD_ASCENT] > 0 {
                        tt_cfg[TTC_HEAD_ASCENT]
                    } else {
                        tt_cfg[TTC_REG_ASCENT]
                    };
                    draw_y + asc2 * scale + 2 - (asc2 * scale * 35) / 100
                } else {
                    draw_y + gh / 2
                };
                gfx_line(x_ptr[0], sk_y, x_ptr[0] + word_w, sk_y, color);
            };
            // Record word position for text selection
            let wi: WordInfo = WordInfo { x: x_ptr[0], y: draw_y, w: word_w, text: word };
            push(word_map, wi);
        };

        // Update link bounds
        if not link_recorded {
            link_w = (x_ptr[0] + word_w) - link_x;
        };

        x_ptr[0] = x_ptr[0] + word_w + gap;
    };

    // Emit single LinkInfo for the entire link text
    if str_len(href) > 0 and not link_recorded {
        if link_y + gh >= CHROME_TOP and link_y < canvas_height() - CHROME_BOT {
            let li: LinkInfo = LinkInfo {
                x: link_x, y: link_y, w: link_w, h: lh,
                href: href, label: "", chrome: in_chrome,
            };
            push(links, li);
        };
    };
}

// Measure the single-line rendered width (in pixels) of all text in the
// subtree rooted at `idx`.  Used by text-align to preposition x_ptr for
// centered/right-aligned blocks whose content fits on one line.  Uses
// proportional font metrics via text_width_f.
fn! measure_inline_text(nodes: [HtmlNode], idx: i32, styles: [ComputedStyle],
                        font: i32, scale: i32, out: [i32],
                        tt_reg: handle, tt_mono: handle, tt_head: handle, tt_cfg: [i32]) {
    if idx < 0 or idx >= len(nodes) { return; };
    if idx < len(styles) and styles[idx].display_none { return; };
    let node: HtmlNode = nodes[idx];
    if node.is_text {
        // Collapse runs of \n / \r / \t / space into a single space so the
        // measurement matches render_text's word-splitting.
        let raw: [i32] = str_to_chars(node.text);
        let mut norm: [i32] = [];
        let mut in_ws: bool = true;
        for mi in 0..len(raw) {
            let c: i32 = raw[mi];
            if c == 10 or c == 13 or c == 9 or c == 32 {
                if not in_ws {
                    push(norm, 32);
                    in_ws = true;
                };
            } else {
                push(norm, c);
                in_ws = false;
            };
        };
        // Strip trailing space.
        while len(norm) > 0 and norm[len(norm) - 1] == 32 { pop(norm); };
        if len(norm) == 0 { return; };
        let collapsed: str = str_from_chars(norm);
        out[0] = out[0] + text_width_f(collapsed, font, scale, tt_reg, tt_mono, tt_head, tt_cfg);
        return;
    };
    if html_is_skip_tag(node.tag) { return; };
    let mut child: i32 = node.first_child;
    while child != -1 {
        measure_inline_text(nodes, child, styles, font, scale, out, tt_reg, tt_mono, tt_head, tt_cfg);
        child = nodes[child].next_sibling;
    };
}

// ─── Table helpers (Phase 3) ────────────────────────────

// Normalize HTML whitespace (\n \r \t all collapse to one space, runs of
// spaces compact to one).  Used for table cell measurement and wrapping.
fn! normalize_ws(text: str) -> str {
    let chars: [i32] = str_to_chars(text);
    let n: i32 = len(chars);
    let mut out: [i32] = [];
    let mut last_ws: bool = true;  // leading whitespace trimmed
    for i in 0..n {
        let c: i32 = chars[i];
        let is_ws: bool = c == 32 or c == 9 or c == 10 or c == 13;
        if is_ws {
            if not last_ws { push(out, 32); };
            last_ws = true;
        } else {
            push(out, c);
            last_ws = false;
        };
    };
    // trim trailing space
    while len(out) > 0 and out[len(out) - 1] == 32 { pop(out); };
    str_from_chars(out)
}

// Flatten a <table>'s children (handling tbody/thead/tfoot wrappers) into
// a flat list of <tr> node indices in document order.
fn! collect_tr_indices(nodes: [HtmlNode], table_node: HtmlNode) -> [i32] {
    let mut out: [i32] = [];
    let mut n: i32 = table_node.first_child;
    while n != -1 {
        let t: str = nodes[n].tag;
        if str_eq(t, "tr") {
            push(out, n);
        } else if str_eq(t, "tbody") or str_eq(t, "thead") or str_eq(t, "tfoot") {
            let mut m: i32 = nodes[n].first_child;
            while m != -1 {
                if str_eq(nodes[m].tag, "tr") { push(out, m); };
                m = nodes[m].next_sibling;
            };
        };
        n = nodes[n].next_sibling;
    };
    out
}

// Collect cell (<td>/<th>) indices for one <tr>.
fn! collect_cell_indices(nodes: [HtmlNode], tr_node: HtmlNode) -> [i32] {
    let mut out: [i32] = [];
    let mut n: i32 = tr_node.first_child;
    while n != -1 {
        let t: str = nodes[n].tag;
        if str_eq(t, "td") or str_eq(t, "th") { push(out, n); };
        n = nodes[n].next_sibling;
    };
    out
}

// Greedy word-wrap `text` into lines that each fit within max_px at the
// given font/scale.  Returns at least one (possibly empty) line.
fn! wrap_text_to_lines(text: str, max_px: i32, font: i32, scale: i32,
                       tt_reg: handle, tt_mono: handle, tt_head: handle, tt_cfg: [i32]) -> [str] {
    let flat: str = normalize_ws(text);
    let mut lines: [str] = [];
    if str_len(flat) == 0 { push(lines, ""); return lines; };
    let words: [str] = str_split(flat, " ");
    let space_w: i32 = text_width_f(" ", font, scale, tt_reg, tt_mono, tt_head, tt_cfg);
    let mut cur: str = "";
    let mut cur_w: i32 = 0;
    for wi in 0..len(words) {
        let w: str = words[wi];
        if str_len(w) == 0 { continue; };
        let ww: i32 = text_width_f(w, font, scale, tt_reg, tt_mono, tt_head, tt_cfg);
        if str_len(cur) == 0 {
            cur = w;
            cur_w = ww;
        } else if cur_w + space_w + ww <= max_px {
            cur = str_concat(str_concat(cur, " "), w);
            cur_w = cur_w + space_w + ww;
        } else {
            push(lines, cur);
            cur = w;
            cur_w = ww;
        };
    };
    if str_len(cur) > 0 { push(lines, cur); };
    if len(lines) == 0 { push(lines, ""); };
    lines
}

// ─── Render a DOM node (flat-array tree) ────────────────

fn! render_node(nodes: [HtmlNode], idx: i32, x_ptr: [i32], y_ptr: [i32],
                vp_top: i32, vp_width: i32, links: [LinkInfo],
                color: i32, font: i32, scale: i32,
                is_link: bool, link_href: str,
                indent: i32, in_pre: bool,
                img_cache_idx: map, img_cache_data: [[i32]],
                img_cache_w: [i32], img_cache_h: [i32],
                base_scheme: str, base_host: str, base_port: i32, base_path: str,
                search_q: str, word_map: [WordInfo],
                strikethrough: bool, force_underline: bool, mark_bg: i32,
                ol_counter: [i32], clickables: [ClickInfo],
                styles: [ComputedStyle],
                trim_chrome: bool, in_chrome: bool,
                fragment_target: str, fragment_y_out: [i32],
                outline_idx: [i32], outline_y_out: [i32],
                body_mono_font: i32,
                theme: [i32],
                tt_reg: handle, tt_mono: handle, tt_head: handle, tt_cfg: [i32]) {
    let node: HtmlNode = nodes[idx];

    // Compute whether this node is itself chrome (nav/aside/header/footer,
    // or carries a landmark ARIA role).  Used both to skip the subtree
    // when trim_chrome is set and to mark descendant links so `F` can
    // label chrome-only hints.
    let mut node_is_chrome: bool = false;
    if not node.is_text {
        let rt: str = node.tag;
        if str_eq(rt, "nav") or str_eq(rt, "header") or str_eq(rt, "footer") or
           str_eq(rt, "aside") {
            node_is_chrome = true;
        } else {
            let role_attr: str = html_get_attr(node, "role");
            if str_len(role_attr) > 0 {
                if str_eq(role_attr, "navigation") or str_eq(role_attr, "banner") or
                   str_eq(role_attr, "complementary") or str_eq(role_attr, "contentinfo") or
                   str_eq(role_attr, "search") {
                    node_is_chrome = true;
                };
            };
        };
    };

    // Trim chrome: when enabled, drop nav/header/footer/aside/form subtrees,
    // role-based landmarks (navigation/banner/complementary/contentinfo/search),
    // aria-hidden="true", and hidden="" elements.  Main content lives in
    // <main>/<article>; stripping these surfaces it without a heavy
    // readability scorer.
    if trim_chrome and not node.is_text {
        let rt2: str = node.tag;
        if str_eq(rt2, "form") or node_is_chrome {
            return;
        };
        let aria_hidden: str = html_get_attr(node, "aria-hidden");
        if str_eq(aria_hidden, "true") { return; };
        if map_has(node.attrs, "hidden") { return; };
    };

    // Fragment target: record absolute y when we encounter the node whose id
    // matches.  y_ptr[0] here is pre-scroll document space — exactly what we
    // need to set scroll_y to.
    if not node.is_text and str_len(fragment_target) > 0 and fragment_y_out[0] < 0 {
        let nid: str = html_get_attr(node, "id");
        if str_len(nid) > 0 and str_eq(nid, fragment_target) {
            fragment_y_out[0] = y_ptr[0];
        };
    };

    // Outline: record absolute y for any node whose index appears in
    // outline_idx.  Populated by the outline-panel builder for H1-H3
    // elements so `t` can jump to each heading.
    if not node.is_text and len(outline_idx) > 0 {
        for oi in 0..len(outline_idx) {
            if outline_idx[oi] == idx and outline_y_out[oi] < 0 {
                outline_y_out[oi] = y_ptr[0];
                break;
            };
        };
    };

    // ── Text node ──
    if node.is_text {
        let text: str = node.text;
        if in_pre {
            // Verbatim rendering: preserve whitespace, honour inherited
            // color/font/scale, advance y only on actual '\n'.  The previous
            // implementation split every text child on '\n' and forced a line
            // break at the end of each, which turned inline syntax-highlight
            // spans (e.g. Wikipedia code blocks) into one token per line.
            let raw: [i32] = str_to_chars(text);
            let pre_lh: i32 = tt_line_h_of(scale, tt_reg, tt_cfg, font);
            let line_left: i32 = indent + PAD;
            let line_right: i32 = vp_width - PAD;
            let mut segment_chars: [i32] = [];
            let raw_len: i32 = len(raw);
            for ci in 0..raw_len {
                let c: i32 = raw[ci];
                if c == 13 { continue; };
                if c == 10 {
                    flush_pre_segment(segment_chars, x_ptr, y_ptr, vp_top,
                                      line_right, line_left, color, font, scale, word_map,
                                      theme,
                                      tt_reg, tt_mono, tt_head, tt_cfg);
                    while len(segment_chars) > 0 { pop(segment_chars); };
                    y_ptr[0] = y_ptr[0] + pre_lh;
                    x_ptr[0] = line_left;
                } else if c == 9 {
                    // Tab → 4 spaces.  No tab-stop alignment; real-world
                    // verbatim blocks (Wikipedia, MDN) indent with spaces
                    // already, and a fixed expansion keeps the renderer simple.
                    push(segment_chars, 32); push(segment_chars, 32);
                    push(segment_chars, 32); push(segment_chars, 32);
                } else {
                    push(segment_chars, c);
                };
            };
            flush_pre_segment(segment_chars, x_ptr, y_ptr, vp_top,
                              line_right, line_left, color, font, scale, word_map,
                              theme,
                              tt_reg, tt_mono, tt_head, tt_cfg);
        } else {
            if str_len(str_trim(text)) == 0 { return; };
            render_text(text, x_ptr, y_ptr, color, font, scale, vp_top, vp_width,
                        is_link or force_underline, links, link_href, search_q, word_map,
                        strikethrough, mark_bg, indent, in_chrome,
                        theme,
                        tt_reg, tt_mono, tt_head, tt_cfg);
        };
        return;
    };

    // ── Element node ──
    let tag: str = node.tag;
    if html_is_skip_tag(tag) { return; };

    // CSS: display:none hides the entire subtree.
    if idx >= 0 and idx < len(styles) and styles[idx].display_none { return; };

    let is_block: bool = html_is_block_tag(tag);

    // Phase 3: compute effective indent / viewport width and padding
    // from the node's ComputedStyle.  For non-block elements these
    // default to the inherited values (no effect).
    let mut eff_indent: i32 = indent;
    let mut eff_vp_width: i32 = vp_width;
    let mut pad_top_px: i32 = 0;
    let mut pad_bot_px: i32 = 0;
    if is_block and idx >= 0 and idx < len(styles) {
        let csp: ComputedStyle = styles[idx];
        // Max-width: resolve px first, else percent of current vp_width.
        let mut mw: i32 = -1;
        if csp.max_width_px >= 0 {
            mw = csp.max_width_px;
        } else if csp.max_width_pct > 0 {
            mw = (vp_width * csp.max_width_pct) / 100;
        };
        if mw > 0 {
            let avail: i32 = vp_width - indent - PAD * 2;
            if mw < avail {
                let extra: i32 = if csp.center_block == 1 {
                    (avail - mw) / 2
                } else { 0 };
                eff_indent = indent + extra;
                eff_vp_width = eff_indent + PAD + mw + PAD;
                if eff_vp_width > vp_width { eff_vp_width = vp_width; };
            };
        };
        // Padding: shift left/right edges inward.
        if csp.pad_l > 0 { eff_indent = eff_indent + csp.pad_l; };
        if csp.pad_r > 0 { eff_vp_width = eff_vp_width - csp.pad_r; };
        if csp.pad_t > 0 { pad_top_px = csp.pad_t; };
        if csp.pad_b > 0 { pad_bot_px = csp.pad_b; };
    };

    let entry_line_h: i32 = effective_line_h(styles, idx, scale, tt_reg, tt_cfg, font);

    if is_block {
        if x_ptr[0] > eff_indent + PAD {
            y_ptr[0] = y_ptr[0] + entry_line_h;
        };
        x_ptr[0] = eff_indent + PAD;
    };
    if is_block and pad_top_px > 0 {
        y_ptr[0] = y_ptr[0] + pad_top_px;
        x_ptr[0] = eff_indent + PAD;
    };

    // Heading / paragraph pre-spacing
    if str_eq(tag, "h1") or str_eq(tag, "h2") or str_eq(tag, "h3") {
        y_ptr[0] = y_ptr[0] + entry_line_h;
    };
    if str_eq(tag, "p") { y_ptr[0] = y_ptr[0] + entry_line_h / 2; };

    // HR
    if str_eq(tag, "hr") {
        y_ptr[0] = y_ptr[0] + entry_line_h / 2;
        let draw_y: i32 = y_ptr[0] - vp_top + CHROME_TOP;
        if draw_y >= CHROME_TOP and draw_y < canvas_height() - CHROME_BOT {
            gfx_line(PAD, draw_y, eff_vp_width - PAD, draw_y, theme[T_HR]);
        };
        y_ptr[0] = y_ptr[0] + entry_line_h / 2;
        x_ptr[0] = eff_indent + PAD;
        return;
    };

    // BR
    if str_eq(tag, "br") {
        y_ptr[0] = y_ptr[0] + entry_line_h;
        x_ptr[0] = eff_indent + PAD;
        return;
    };

    // IMG — fetch, decode, and blit
    if str_eq(tag, "img") {
        let src: str = html_get_attr(node, "src");
        let alt: str = html_get_attr(node, "alt");
        let attr_w_str: str = html_get_attr(node, "width");
        let attr_h_str: str = html_get_attr(node, "height");
        let mut attr_w: i32 = 0;
        let mut attr_h: i32 = 0;
        let avail_img_w: i32 = vp_width - indent - PAD * 2;
        if str_len(attr_w_str) > 0 {
            if str_ends_with(attr_w_str, "%") {
                let pct_str: str = str_slice(attr_w_str, 0, str_len(attr_w_str) - 1);
                let ppw: Result<i32, str> = parse_i32(pct_str);
                match ppw { Result::Ok(pv) => { attr_w = avail_img_w * pv / 100; }, Result::Err(_epw) => {}, };
            } else {
                let pw: Result<i32, str> = parse_i32(attr_w_str);
                match pw { Result::Ok(wv) => { attr_w = wv; }, Result::Err(_ew) => {}, };
            };
        };
        if str_len(attr_h_str) > 0 {
            if str_ends_with(attr_h_str, "%") {
                let pct_h_str: str = str_slice(attr_h_str, 0, str_len(attr_h_str) - 1);
                let pph: Result<i32, str> = parse_i32(pct_h_str);
                match pph { Result::Ok(phv) => { attr_h = (canvas_height() - CHROME_TOP - CHROME_BOT) * phv / 100; }, Result::Err(_eph) => {}, };
            } else {
                let ph: Result<i32, str> = parse_i32(attr_h_str);
                match ph { Result::Ok(hv) => { attr_h = hv; }, Result::Err(_eh) => {}, };
            };
        };

        if str_len(src) > 0 {
            let cache_idx: i32 = img_fetch_and_decode(src, base_scheme, base_host, base_port, base_path,
                                                       img_cache_idx, img_cache_data,
                                                       img_cache_w, img_cache_h);
            if cache_idx >= 0 and cache_idx < len(img_cache_data) {
                let mut draw_px: [i32] = img_cache_data[cache_idx];
                let mut draw_w: i32 = img_cache_w[cache_idx];
                let mut draw_h: i32 = img_cache_h[cache_idx];

                // Scale to HTML-specified dimensions if present
                if attr_w > 0 and attr_h > 0 and (attr_w != draw_w or attr_h != draw_h) {
                    draw_px = img_scale(img_cache_data[cache_idx], draw_w, draw_h, attr_w, attr_h);
                    draw_w = attr_w;
                    draw_h = attr_h;
                } else if attr_w > 0 and attr_w != draw_w {
                    let scaled_h: i32 = draw_h * attr_w / draw_w;
                    if scaled_h > 0 {
                        draw_px = img_scale(img_cache_data[cache_idx], draw_w, draw_h, attr_w, scaled_h);
                        draw_w = attr_w;
                        draw_h = scaled_h;
                    };
                } else if attr_h > 0 and attr_h != draw_h {
                    let scaled_w: i32 = draw_w * attr_h / draw_h;
                    if scaled_w > 0 {
                        draw_px = img_scale(img_cache_data[cache_idx], draw_w, draw_h, scaled_w, attr_h);
                        draw_w = scaled_w;
                        draw_h = attr_h;
                    };
                };

                // Start on new line for block images
                if x_ptr[0] > indent + PAD {
                    x_ptr[0] = indent + PAD;
                    y_ptr[0] = y_ptr[0] + LINE_H;
                };

                let draw_y: i32 = y_ptr[0] - vp_top + CHROME_TOP;
                if draw_y + draw_h >= CHROME_TOP and draw_y < canvas_height() - CHROME_BOT {
                    gfx_blit(x_ptr[0], draw_y, draw_w, draw_h, draw_px);
                };
                y_ptr[0] = y_ptr[0] + draw_h + 4;
                x_ptr[0] = indent + PAD;
                return;
            };
        };

        // Fallback: show alt text placeholder
        let display: str = if str_len(alt) > 0 { "[IMG: {alt}]" } else { "[IMG]" };
        let draw_y: i32 = y_ptr[0] - vp_top + CHROME_TOP;
        if draw_y + FONT_H >= CHROME_TOP and draw_y < canvas_height() - CHROME_BOT {
            draw_text_f(x_ptr[0], draw_y, display, theme[T_HR], font, scale, tt_reg, tt_mono, tt_head, tt_cfg);
        };
        x_ptr[0] = x_ptr[0] + text_width_f(display, font, scale, tt_reg, tt_mono, tt_head, tt_cfg) + text_width_f(" ", font, scale, tt_reg, tt_mono, tt_head, tt_cfg);
        return;
    };

    // TABLE — column-aligned rendering
    if str_eq(tag, "table") {
        // Phase 3: two-pass content-based column sizing with word wrap.
        let tr_idxs: [i32] = collect_tr_indices(nodes, node);
        if len(tr_idxs) == 0 {
            // Empty table — skip default block handling.
            y_ptr[0] = y_ptr[0] + LINE_H;
            x_ptr[0] = eff_indent + PAD;
            return;
        };

        // Per-row cell index lists; track max column count.
        let mut rows_cells: [[i32]] = [];
        let mut max_cols: i32 = 0;
        for ri0 in 0..len(tr_idxs) {
            let rcells: [i32] = collect_cell_indices(nodes, nodes[tr_idxs[ri0]]);
            if len(rcells) > max_cols { max_cols = len(rcells); };
            push(rows_cells, rcells);
        };
        if max_cols == 0 { max_cols = 1; };

        let avail_w: i32 = eff_vp_width - eff_indent - PAD * 2;
        // Cell padding (per cell, split left + right).
        let cell_pad: i32 = 8;

        // Pass 1: measure.  col_max = natural width of longest line of text;
        // col_min = width of longest single word (ensures wrapping works).
        let mut col_max: [i32] = [];
        let mut col_min: [i32] = [];
        for c0 in 0..max_cols { push(col_max, 0); push(col_min, 0); };
        for ri1 in 0..len(rows_cells) {
            let cells1: [i32] = rows_cells[ri1];
            for ci1 in 0..len(cells1) {
                let raw: str = html_get_text_content(nodes, cells1[ci1]);
                let txt: str = normalize_ws(raw);
                let w_nat: i32 = text_width_f(txt, body_mono_font, 1, tt_reg, tt_mono, tt_head, tt_cfg);
                let ws: [str] = str_split(txt, " ");
                let mut max_word_w: i32 = 0;
                for wi in 0..len(ws) {
                    let ww: i32 = text_width_f(ws[wi], body_mono_font, 1, tt_reg, tt_mono, tt_head, tt_cfg);
                    if ww > max_word_w { max_word_w = ww; };
                };
                if w_nat > col_max[ci1] { col_max[ci1] = w_nat; };
                if max_word_w > col_min[ci1] { col_min[ci1] = max_word_w; };
            };
        };

        // Distribute avail_w across columns.
        let mut col_w: [i32] = [];
        for c1 in 0..max_cols { push(col_w, 0); };

        let mut sum_max: i32 = 0;
        let mut sum_min: i32 = 0;
        for c2 in 0..max_cols {
            sum_max = sum_max + col_max[c2] + cell_pad;
            sum_min = sum_min + col_min[c2] + cell_pad;
        };

        if sum_max <= avail_w {
            // Comfortable fit: natural widths, distribute leftover equally.
            for c3 in 0..max_cols { col_w[c3] = col_max[c3] + cell_pad; };
            let leftover: i32 = avail_w - sum_max;
            if max_cols > 0 and leftover > 0 {
                let bonus: i32 = leftover / max_cols;
                for c4 in 0..max_cols { col_w[c4] = col_w[c4] + bonus; };
                let rem: i32 = leftover - bonus * max_cols;
                col_w[max_cols - 1] = col_w[max_cols - 1] + rem;
            };
        } else if sum_min <= avail_w and sum_max > sum_min {
            // Squeeze between min and max proportionally.
            let range_total: i32 = sum_max - sum_min;
            let avail_range: i32 = avail_w - sum_min;
            for c5 in 0..max_cols {
                let col_range: i32 = col_max[c5] - col_min[c5];
                let give: i32 = if range_total > 0 { (col_range * avail_range) / range_total } else { 0 };
                col_w[c5] = col_min[c5] + cell_pad + give;
            };
            // Fix rounding so columns sum exactly to avail_w.
            let mut got: i32 = 0;
            for c6 in 0..max_cols { got = got + col_w[c6]; };
            let delta: i32 = avail_w - got;
            if max_cols > 0 { col_w[max_cols - 1] = col_w[max_cols - 1] + delta; };
        } else {
            // Too narrow even for minimum widths — fall back to equal split.
            let eq: i32 = avail_w / max_cols;
            for c7 in 0..max_cols { col_w[c7] = eq; };
            if max_cols > 0 {
                let rem2: i32 = avail_w - eq * max_cols;
                col_w[max_cols - 1] = col_w[max_cols - 1] + rem2;
            };
        };

        // Pre-compute column x-offsets.
        let mut col_x: [i32] = [];
        let mut acc: i32 = eff_indent + PAD;
        for c8 in 0..max_cols {
            push(col_x, acc);
            acc = acc + col_w[c8];
        };

        // Draw top border.
        let tbl_top_y: i32 = y_ptr[0] - vp_top + CHROME_TOP;
        if tbl_top_y >= CHROME_TOP and tbl_top_y < canvas_height() - CHROME_BOT {
            gfx_line(eff_indent + PAD, tbl_top_y, eff_indent + PAD + avail_w, tbl_top_y, theme[T_TABLE_BORDER]);
        };
        y_ptr[0] = y_ptr[0] + 2;

        // Pass 2: render each row with word-wrap; row height = max line count.
        for ri2 in 0..len(rows_cells) {
            let cells2: [i32] = rows_cells[ri2];
            // First compute wrapped lines per cell + row max lines.
            let mut max_lines: i32 = 1;
            let mut row_any_th: bool = false;
            for ci2 in 0..len(cells2) {
                if str_eq(nodes[cells2[ci2]].tag, "th") { row_any_th = true; };
            };
            // Use nested arrays: cell_lines is [[str]].
            let mut cell_lines: [[str]] = [];
            for ci3 in 0..len(cells2) {
                let raw2: str = html_get_text_content(nodes, cells2[ci3]);
                let inner_w: i32 = col_w[ci3] - cell_pad;
                let ln: [str] = wrap_text_to_lines(raw2, inner_w, body_mono_font, 1, tt_reg, tt_mono, tt_head, tt_cfg);
                if len(ln) > max_lines { max_lines = len(ln); };
                push(cell_lines, ln);
            };

            // Draw each cell's lines.
            for ci4 in 0..len(cells2) {
                let cx: i32 = col_x[ci4] + 4;
                let cell_tag: str = nodes[cells2[ci4]].tag;
                let cc: i32 = if str_eq(cell_tag, "th") { theme[T_BOLD] } else { color };
                // Fill header cell background (--color-table-header) behind
                // the text so the heading row visibly separates from body
                // rows in light mode.
                if str_eq(cell_tag, "th") {
                    let hdr_y: i32 = y_ptr[0] - vp_top + CHROME_TOP;
                    let hdr_h: i32 = LINE_H * max_lines;
                    if hdr_y + hdr_h >= CHROME_TOP and hdr_y < canvas_height() - CHROME_BOT {
                        gfx_fill_rect(col_x[ci4], hdr_y, col_w[ci4], hdr_h,
                                      theme[T_TABLE_HEADER_BG]);
                    };
                };
                let lines: [str] = cell_lines[ci4];
                for li in 0..len(lines) {
                    let cy: i32 = y_ptr[0] - vp_top + CHROME_TOP + li * LINE_H;
                    if cy + FONT_H >= CHROME_TOP and cy < canvas_height() - CHROME_BOT {
                        draw_text_f(cx, cy, lines[li], cc, body_mono_font, 1, tt_reg, tt_mono, tt_head, tt_cfg);
                    };
                };
            };
            y_ptr[0] = y_ptr[0] + LINE_H * max_lines;

            // Header separator: draw after the first row if it's all/mostly <th>.
            if ri2 == 0 and row_any_th {
                let sep_y: i32 = y_ptr[0] - vp_top + CHROME_TOP;
                if sep_y >= CHROME_TOP and sep_y < canvas_height() - CHROME_BOT {
                    gfx_line(eff_indent + PAD, sep_y, eff_indent + PAD + avail_w, sep_y, theme[T_TABLE_BORDER]);
                };
                y_ptr[0] = y_ptr[0] + 2;
            };
        };

        // Draw bottom border.
        let tbl_bot_y: i32 = y_ptr[0] - vp_top + CHROME_TOP;
        if tbl_bot_y >= CHROME_TOP and tbl_bot_y < canvas_height() - CHROME_BOT {
            gfx_line(eff_indent + PAD, tbl_bot_y, eff_indent + PAD + avail_w, tbl_bot_y, theme[T_TABLE_BORDER]);
        };
        y_ptr[0] = y_ptr[0] + LINE_H;
        x_ptr[0] = eff_indent + PAD;
        return;
    };

    // Determine child properties
    let mut child_color: i32 = color;
    let mut child_font: i32 = font;
    let mut child_scale: i32 = scale;
    let mut child_link: bool = is_link;
    let mut child_href: str = link_href;
    let mut child_indent: i32 = eff_indent;
    let mut child_pre: bool = in_pre;
    let mut child_strike: bool = strikethrough;
    let mut child_uline: bool = force_underline;
    let mut child_markbg: i32 = mark_bg;
    let mut child_ol: [i32] = ol_counter;

    if str_eq(tag, "h1") { child_color = theme[T_H1]; child_scale = heading_scale(tag) * scale; child_font = FONT_HEADING_L; }
    else if str_eq(tag, "h2") { child_color = theme[T_H2]; child_scale = heading_scale(tag) * scale; child_font = FONT_HEADING_L; }
    else if str_eq(tag, "h3") or str_eq(tag, "h4") or str_eq(tag, "h5") or str_eq(tag, "h6") {
        child_color = theme[T_H3];
        child_scale = heading_scale(tag) * scale;
        child_font = FONT_HEADING_L;
    }
    else if str_eq(tag, "b") or str_eq(tag, "strong") { child_color = theme[T_BOLD]; }
    else if str_eq(tag, "em") or str_eq(tag, "i") or str_eq(tag, "cite") { child_color = theme[T_EM]; }
    else if str_eq(tag, "a") {
        child_color = theme[T_LINK];
        child_link = true;
        child_href = url_unwrap_tracking(html_get_attr(node, "href"));
    }
    else if str_eq(tag, "pre") {
        child_color = theme[T_CODE_FG]; child_pre = true; child_font = body_mono_font;
    }
    else if str_eq(tag, "code") {
        // Inherit verbatim layout from a parent <pre> (via in_pre), but
        // standalone inline <code> in a paragraph renders with normal
        // word-wrap — just in mono font and theme[T_CODE_FG].  Forcing the pre
        // layout on inline <code> used to break line flow after every
        // occurrence.
        child_color = theme[T_CODE_FG]; child_font = body_mono_font;
    }
    else if is_mono_tag(tag) {
        child_color = theme[T_CODE_FG]; child_font = body_mono_font;
    }
    else if str_eq(tag, "ul") {
        child_indent = eff_indent + 20;
        child_ol = [0];
    }
    else if str_eq(tag, "ol") {
        child_indent = eff_indent + 20;
        child_ol = [1];
    }
    else if str_eq(tag, "blockquote") {
        child_indent = eff_indent + 30;
        child_color = theme[T_QUOTE];
        // Draw left accent bar
        let bar_x: i32 = eff_indent + PAD + 10;
        let bar_y: i32 = y_ptr[0] - vp_top + CHROME_TOP;
        if bar_y >= CHROME_TOP and bar_y < canvas_height() - CHROME_BOT {
            gfx_line(bar_x, bar_y, bar_x, bar_y + LINE_H * 2, theme[T_QUOTE_BAR]);
        };
    }
    else if str_eq(tag, "del") or str_eq(tag, "s") { child_strike = true; }
    else if str_eq(tag, "u") or str_eq(tag, "ins") { child_uline = true; }
    else if str_eq(tag, "mark") { child_markbg = theme[T_MARK_BG]; }
    else if str_eq(tag, "dt") { child_color = theme[T_DT]; }
    else if str_eq(tag, "dd") { child_indent = eff_indent + 30; }
    else if str_eq(tag, "figure") { child_indent = eff_indent + 20; }
    else if str_eq(tag, "figcaption") { child_color = theme[T_FIGCAP]; };

    // CSS overrides from stylesheet cascade + inline style="..."
    if idx >= 0 and idx < len(styles) {
        let cs: ComputedStyle = styles[idx];
        if cs.color >= 0 {
            child_color = cs.color;
        } else if cs.bold == 1 {
            child_color = theme[T_BOLD];
        } else if cs.italic == 1 {
            child_color = theme[T_EM];
        };
        if cs.underline == 1 { child_uline = true; };
        if cs.strike == 1 { child_strike = true; };
        if cs.bg_color >= 0 { child_markbg = cs.bg_color; };
    };

    // Anchors always use the browser's link color.  Many pages ship a
    // light-mode stylesheet that sets `a { color: #... }` or inherits a
    // near-black color from body; on our dark chrome that produces
    // unreadable near-invisible links.  Keeping theme[T_LINK] here trades a
    // bit of per-site styling fidelity for reliably readable links.
    if str_eq(tag, "a") {
        child_color = theme[T_LINK];
    };

    // List item: numbered or bulleted
    if str_eq(tag, "li") {
        x_ptr[0] = eff_indent + PAD;
        let draw_y: i32 = y_ptr[0] - vp_top + CHROME_TOP;
        if ol_counter[0] > 0 {
            let num_str: str = i32_to_str(ol_counter[0]);
            let li_label: str = str_concat(num_str, ". ");
            if draw_y + tt_glyph_h_of(child_scale, tt_reg, tt_cfg, child_font) >= CHROME_TOP and draw_y < canvas_height() - CHROME_BOT {
                draw_text_f(x_ptr[0], draw_y, li_label, child_color, child_font, child_scale, tt_reg, tt_mono, tt_head, tt_cfg);
            };
            x_ptr[0] = x_ptr[0] + text_width_f(li_label, child_font, child_scale, tt_reg, tt_mono, tt_head, tt_cfg);
            ol_counter[0] = ol_counter[0] + 1;
        } else {
            if draw_y + tt_glyph_h_of(child_scale, tt_reg, tt_cfg, child_font) >= CHROME_TOP and draw_y < canvas_height() - CHROME_BOT {
                draw_text_f(x_ptr[0], draw_y, "* ", child_color, child_font, child_scale, tt_reg, tt_mono, tt_head, tt_cfg);
            };
            x_ptr[0] = x_ptr[0] + text_width_f("* ", child_font, child_scale, tt_reg, tt_mono, tt_head, tt_cfg);
        };
    };

    // CSS: text-align for block elements.  Only applies when the subtree's
    // inline content fits on a single line; wrapped content falls back to
    // left alignment (acceptable for the common case of centered headings
    // and footers).
    if is_block and idx >= 0 and idx < len(styles) {
        let ta: i32 = styles[idx].text_align;
        if ta == 1 or ta == 2 {
            let w_ptr: [i32] = [0];
            measure_inline_text(nodes, idx, styles, child_font, child_scale, w_ptr, tt_reg, tt_mono, tt_head, tt_cfg);
            let measured: i32 = w_ptr[0];
            let line_start: i32 = eff_indent + PAD;
            let line_end: i32 = eff_vp_width - PAD;
            let avail: i32 = line_end - line_start;
            if measured > 0 and measured <= avail {
                if ta == 1 {
                    x_ptr[0] = line_start + (avail - measured) / 2;
                } else {
                    x_ptr[0] = line_end - measured;
                };
            };
        };
    };

    // Track onclick elements — record y before children render
    let has_onclick: bool = str_len(html_get_attr(node, "onclick")) > 0;
    let onclick_y_start: i32 = y_ptr[0] - vp_top + CHROME_TOP;

    // Render children via sibling walk
    let child_in_chrome: bool = in_chrome or node_is_chrome;
    let mut child: i32 = node.first_child;
    while child != -1 {
        render_node(nodes, child, x_ptr, y_ptr, vp_top, eff_vp_width,
                    links, child_color, child_font, child_scale,
                    child_link, child_href,
                    child_indent, child_pre,
                    img_cache_idx, img_cache_data,
                    img_cache_w, img_cache_h,
                    base_scheme, base_host, base_port, base_path,
                    search_q, word_map,
                    child_strike, child_uline, child_markbg, child_ol,
                    clickables, styles,
                    trim_chrome, child_in_chrome,
                    fragment_target, fragment_y_out,
                    outline_idx, outline_y_out,
                    body_mono_font,
                    theme,
                    tt_reg, tt_mono, tt_head, tt_cfg);
        child = nodes[child].next_sibling;
    };

    // Record clickable element after children are rendered
    if has_onclick {
        let onclick_y_end: i32 = y_ptr[0] - vp_top + CHROME_TOP;
        let mut onclick_h: i32 = onclick_y_end - onclick_y_start;
        if onclick_h < LINE_H {
            onclick_h = LINE_H;
        };
        let cci: ClickInfo = ClickInfo {
            x: eff_indent + PAD, y: onclick_y_start,
            w: eff_vp_width - eff_indent - PAD * 2,
            h: onclick_h,
            node_idx: idx,
        };
        push(clickables, cci);
    };

    // Block post-spacing (includes CSS padding-bottom).
    if is_block {
        x_ptr[0] = eff_indent + PAD;
        y_ptr[0] = y_ptr[0] + effective_line_h(styles, idx, child_scale, tt_reg, tt_cfg, child_font);
        if pad_bot_px > 0 {
            y_ptr[0] = y_ptr[0] + pad_bot_px;
        };
    };
    if str_eq(tag, "h1") or str_eq(tag, "h2") { y_ptr[0] = y_ptr[0] + effective_line_h(styles, idx, child_scale, tt_reg, tt_cfg, child_font) / 2; };
    // Paragraph spacing: pre-p already adds half a line (line ~945);
    // block post-spacing adds a full line.  That's 1.5 lines between
    // paragraph tops — a visible blank line gap without an extra
    // half-line bump that felt too airy.
}

// ─── Hint label generation ──────────────────────────────

fn! make_hint_labels(count: i32) -> [str] {
    let hc: [i32] = str_to_chars("asdfghjklqwertyuiopzxcvbnm");
    let n: i32 = len(hc);
    let mut labels: [str] = [];
    if count <= n {
        // Single-letter labels
        for i in 0..count {
            let lbl: [i32] = [hc[i]];
            push(labels, str_from_chars(lbl));
        };
    } else {
        // Two-letter labels (up to n*n)
        let cap: i32 = if count < n * n { count } else { n * n };
        for j in 0..cap {
            let c1: i32 = hc[j / n];
            let c2: i32 = hc[mod_i32(j, n)];
            let lbl2: [i32] = [c1, c2];
            push(labels, str_from_chars(lbl2));
        };
    };
    labels
}

// ─── Reader-mode helpers ────────────────────────────────
// Prefer <main> or <article> as the reader root when available — this
// usually strips the site's nav / header / footer / sidebars far more
// cleanly than tag-list exclusion alone.
fn! find_main_content_idx(nodes: [HtmlNode], start_idx: i32) -> i32 {
    if start_idx < 0 or start_idx >= len(nodes) { return -1; };
    let node: HtmlNode = nodes[start_idx];
    if not node.is_text {
        if str_eq(node.tag, "main") or str_eq(node.tag, "article") {
            return start_idx;
        };
    };
    let mut child: i32 = node.first_child;
    while child != -1 {
        let r: i32 = find_main_content_idx(nodes, child);
        if r >= 0 { return r; };
        child = nodes[child].next_sibling;
    };
    -1
}

// Return true if the DOM subtree rooted at `start_idx` contains any
// chrome element (nav/header/footer/aside, or a landmark ARIA role).
// Used by the main loop to decide whether to draw the floating "F"
// button that lets mouse users reach trimmed chrome links.
fn! dom_has_chrome(nodes: [HtmlNode], start_idx: i32) -> bool {
    if start_idx < 0 or start_idx >= len(nodes) { return false; };
    let node: HtmlNode = nodes[start_idx];
    if not node.is_text {
        let tg: str = node.tag;
        if str_eq(tg, "nav") or str_eq(tg, "header") or str_eq(tg, "footer") or
           str_eq(tg, "aside") {
            return true;
        };
        let role_attr: str = html_get_attr(node, "role");
        if str_len(role_attr) > 0 {
            if str_eq(role_attr, "navigation") or str_eq(role_attr, "banner") or
               str_eq(role_attr, "complementary") or str_eq(role_attr, "contentinfo") or
               str_eq(role_attr, "search") {
                return true;
            };
        };
    };
    let mut child: i32 = node.first_child;
    while child != -1 {
        if dom_has_chrome(nodes, child) { return true; };
        child = nodes[child].next_sibling;
    };
    false
}

// ─── Outline (table of contents) builder ────────────────
// Walks the DOM under `start_idx` and records every H1/H2/H3 element's
// node index, its heading level, and a short text label.  The y
// coordinate is filled later by render_node via outline_y_out.
fn! build_outline(nodes: [HtmlNode], start_idx: i32,
                  o_idx: [i32], o_level: [i32], o_text: [str]) {
    if start_idx < 0 or start_idx >= len(nodes) { return; };
    let node: HtmlNode = nodes[start_idx];
    if not node.is_text {
        let tg: str = node.tag;
        let mut lvl: i32 = 0;
        if str_eq(tg, "h1") { lvl = 1; }
        else if str_eq(tg, "h2") { lvl = 2; }
        else if str_eq(tg, "h3") { lvl = 3; };
        if lvl > 0 {
            let txt: str = str_trim(html_get_text_content(nodes, start_idx));
            if str_len(txt) > 0 {
                push(o_idx, start_idx);
                push(o_level, lvl);
                let disp: str = if str_len(txt) > 60 {
                    str_concat(str_slice(txt, 0, 60), "…")
                } else {
                    txt
                };
                push(o_text, disp);
            };
        };
    };
    let mut child: i32 = node.first_child;
    while child != -1 {
        build_outline(nodes, child, o_idx, o_level, o_text);
        child = nodes[child].next_sibling;
    };
}

// ─── User stylesheet ────────────────────────────────────
// A small author-loses-to-user cascade overlay that hides common site
// chrome selectors on the major CMSes.  Applied after page stylesheets
// so source order breaks ties in its favour; every declaration is
// marked !important to beat inline style="" and author !important of
// equal specificity that happens to come earlier.  Skipped when the
// user toggles `gR` (show_full), so "show me the whole page" still
// works as an escape hatch.
fn user_stylesheet() -> str {
    "nav {{ display: none !important; }} aside {{ display: none !important; }} .sidebar {{ display: none !important; }} .site-header {{ display: none !important; }} .global-nav {{ display: none !important; }} .skip-link {{ display: none !important; }} .cookie-banner {{ display: none !important; }} .cookie-notice {{ display: none !important; }} .hamburger {{ display: none !important; }} .menu-toggle {{ display: none !important; }} #mw-navigation {{ display: none !important; }} #mw-panel {{ display: none !important; }} .mw-panel {{ display: none !important; }} .mw-jump-link {{ display: none !important; }} .vector-main-menu {{ display: none !important; }} .vector-pinned-container {{ display: none !important; }} .vector-header-container {{ display: none !important; }} .vector-sticky-header {{ display: none !important; }} .vector-toc {{ display: none !important; }} .mw-footer {{ display: none !important; }} #p-lang {{ display: none !important; }} .navbox {{ display: none !important; }} .sister-project {{ display: none !important; }} .interlanguage-link {{ display: none !important; }}"
}


// ─── Main ────────────────────────────────────────────────

fn! main() {
    let co: Result<str, str> = canvas_open(1024, 768, "OscaWeb Browser");
    match co {
        Result::Ok(_s) => {},
        Result::Err(e) => { println("Failed to open window: {e}"); exit(1); },
    };

    // State
    let mut mode: BrowserMode = BrowserMode::Normal;
    let mut current_url: str = "";
    let mut dom_nodes: [HtmlNode] = [];
    let mut dom_root: i32 = -1;
    let mut dom_styles: [ComputedStyle] = [];
    let mut page_loaded: bool = false;
    let mut status_msg: str = "Press 'o' to enter a URL";
    let mut scroll_y: i32 = 0;
    let mut doc_height: i32 = 0;
    let mut max_scroll: i32 = 0;
    let mut page_links: [LinkInfo] = [];
    let mut error_msg: str = "";

    // JavaScript engine
    let js_ctx: handle = js_engine_init();

    // Image cache
    let mut img_cache_idx: map = map_new();
    let mut img_cache_data: [[i32]] = [];
    let mut img_cache_w: [i32] = [];
    let mut img_cache_h: [i32] = [];

    // Page (HTML document) cache. Keyed by canonical URL
    // (scheme://host:port/path). Populated on successful fetch, consulted
    // on every navigation before going to the network so back/forward
    // (H/L) and repeat visits are instant. Images keep their own cache
    // above — this one only caches top-level documents. `r` (reload)
    // invalidates the current URL before re-navigating so the user can
    // force a fresh fetch.
    let mut page_cache_urls: [str] = [];
    let mut page_cache_bodies: [str] = [];
    let mut page_cache_cts: [str] = [];
    let mut page_cache_status: [i32] = [];

    // Address bar
    let mut url_buf: [i32] = [];
    let mut url_focused: bool = false;
    let mut prev_btn: i32 = 0;
    let mut url_cursor: i32 = 0;
    let mut url_select_all: bool = false;

    // History
    let mut history_back: [str] = [];
    let mut history_forward: [str] = [];

    // Persistent history (most-recent-first) and bookmarks, loaded from disk.
    let mut persistent_history: [str] = storage_load_lines("oscaweb_history.txt");
    let mut bookmarks: [str] = storage_load_lines("oscaweb_bookmarks.txt");

    // URL-bar autocomplete (derived each frame in Insert mode)
    let mut ac_matches: [str] = [];
    let mut ac_selected: i32 = -1;
    let mut show_bookmarks: bool = false;

    // Reader mode
    let mut reader_on: bool = false;

    // Show-full override: `gR` toggles.  When true, renders the whole
    // DOM from dom_root and disables chrome trimming (role/aria/hidden
    // and nav/aside/etc filters).  Default is false so pages with a
    // <main>/<article> landmark get rendered from that subtree and
    // site chrome is hidden automatically.
    let mut show_full: bool = false;

    // Outline overlay (table of contents)
    let mut show_outline: bool = false;
    let mut outline_idx: [i32] = [];
    let mut outline_y: [i32] = [];
    let mut outline_text: [str] = [];
    let mut outline_level: [i32] = [];

    // When `F` is pressed on a page whose chrome is currently hidden,
    // we flip show_full + reload and defer the follow-mode activation
    // until after the next render populates page_links.
    let mut pending_follow_chrome: bool = false;

    // True if the current page contains any chrome element (nav, header,
    // footer, aside, or landmark-role'd container).  Drives the visibility
    // of the floating "F" button when chrome is auto-trimmed.
    let mut has_chrome: bool = false;

    // Runtime zoom (1..4)
    let mut body_scale: i32 = 1;

    // Body font size toggle: false = 12pt (12-row cell), true = 8pt (8-row cell).
    // Flipped by the "12pt"/"8pt" button in the top chrome.
    let mut small_font: bool = false;

    // Theme: light mode is the default.  Flipped by the ☀/☾ button in the
    // top chrome.  Persisted to theme.cfg so it survives restarts.
    let mut light_mode: bool = true;
    let tm_persist: [str] = storage_load_lines("theme.cfg");
    if len(tm_persist) >= 1 {
        match parse_i32(str_trim(tm_persist[0])) {
            Result::Ok(tv) => { light_mode = tv != 0; },
            Result::Err(_) => {},
        };
    };
    let mut theme: [i32] = theme_make(light_mode);
    let mut ui_colors: [i32] = theme_make_ui(light_mode);

    // ─── TrueType font state ───
    // Three handles loaded from system fonts at startup:
    //   tt_reg   — proportional body serif (Georgia, with Times New Roman /
    //              Arial fallbacks so we always get a readable face).
    //   tt_head  — proportional heading sans (Trebuchet MS, falling through
    //              Lucida Sans Unicode / Verdana / Tahoma / Arial).  When
    //              unavailable, heading tags fall back to tt_reg via the
    //              dispatcher so layout still works.
    //   tt_mono  — monospace for <pre>/<code> (Consolas, falling through
    //              Courier New / Lucida Console).
    // Toggled on/off by the "TT"/"Bmp" chrome button and Ctrl+T.  Size
    // adjustable with Ctrl+= / Ctrl+- when active.  Persisted to font.cfg.
    let mut tt_reg: handle = (0 as i64) as handle;
    let mut tt_mono: handle = (0 as i64) as handle;
    let mut tt_head: handle = (0 as i64) as handle;
    let mut tt_cfg: [i32] = [];
    for _tti in 0..TTC_LEN { push(tt_cfg, 0); };
    tt_cfg[TTC_BASE_BODY_PX] = 20;
    tt_cfg[TTC_BASE_MONO_PX] = 18;
    tt_cfg[TTC_BODY_PX] = 20;
    tt_cfg[TTC_MONO_PX] = 18;

    // Try loading system fonts.  Each face uses a fallback chain so that
    // missing primary fonts (e.g. Georgia disabled, or a stripped system
    // image without Trebuchet) still yield a usable TT render path.  If
    // the entire chain fails, that slot stays 0 and the dispatcher falls
    // back silently to the bitmap font.
    let body_font_paths: [str] = [
        "C:\\Windows\\Fonts\\georgia.ttf",
        "C:\\Windows\\Fonts\\times.ttf",
        "C:\\Windows\\Fonts\\arial.ttf",
    ];
    let head_font_paths: [str] = [
        "C:\\Windows\\Fonts\\trebuc.ttf",
        "C:\\Windows\\Fonts\\l_10646.ttf",
        "C:\\Windows\\Fonts\\verdana.ttf",
        "C:\\Windows\\Fonts\\tahoma.ttf",
        "C:\\Windows\\Fonts\\arial.ttf",
    ];
    let mono_font_paths: [str] = [
        "C:\\Windows\\Fonts\\consola.ttf",
        "C:\\Windows\\Fonts\\cour.ttf",
        "C:\\Windows\\Fonts\\lucon.ttf",
    ];
    tt_reg = tt_load_first(body_font_paths);
    tt_head = tt_load_first(head_font_paths);
    tt_mono = tt_load_first(mono_font_paths);
    defer tt_free(tt_reg);
    defer tt_free(tt_mono);
    defer tt_free(tt_head);

    // Persisted TT settings: [enabled, body_px, mono_px].
    let tt_persist: [str] = storage_load_lines("font.cfg");
    if len(tt_persist) >= 1 {
        match parse_i32(str_trim(tt_persist[0])) {
            Result::Ok(v) => { tt_cfg[TTC_ENABLED] = v; },
            Result::Err(_) => {},
        };
    };
    if len(tt_persist) >= 2 {
        match parse_i32(str_trim(tt_persist[1])) {
            Result::Ok(bp) => { if bp >= 8 and bp <= 48 { tt_cfg[TTC_BASE_BODY_PX] = bp; }; },
            Result::Err(_) => {},
        };
    };
    if len(tt_persist) >= 3 {
        match parse_i32(str_trim(tt_persist[2])) {
            Result::Ok(mp) => { if mp >= 8 and mp <= 48 { tt_cfg[TTC_BASE_MONO_PX] = mp; }; },
            Result::Err(_) => {},
        };
    };
    // If user had TT enabled but fonts failed to load, turn it off.
    if (tt_reg as i64) == (0 as i64) { tt_cfg[TTC_ENABLED] = 0; };
    tt_recache(tt_reg, tt_mono, tt_head, tt_cfg, small_font);

    // Pending scroll target when the URL fragment (#id) matches an element.
    let mut pending_fragment: str = "";

    // Follow mode
    let mut follow_links: [LinkInfo] = [];
    let mut follow_input: [i32] = [];

    // Search
    let mut search_buf: [i32] = [];
    let mut search_active: bool = false;
    let mut search_query: str = "";
    let mut search_match_y: [i32] = [];
    let mut search_match_idx: i32 = 0;

    // Help
    let mut show_help: bool = false;
    let mut last_key: i32 = 0;

    // Text selection
    let mut word_map: [WordInfo] = [];
    let mut sel_active: bool = false;
    let mut sel_start_x: i32 = 0;
    let mut sel_start_y: i32 = 0;
    let mut sel_end_x: i32 = 0;
    let mut sel_end_y: i32 = 0;

    // Clickable elements (onclick handlers)
    let mut page_clickables: [ClickInfo] = [];

    // Navigation trigger
    let mut needs_navigate: bool = false;
    let mut nav_url: str = "";

    // Render gating: only re-render when user input or state changes.
    // Without this, render_node is called 60× per second and — because the
    // main loop intentionally runs outside any `arena { }` block — every
    // per-frame allocation (str_split, str_to_lower, WordInfo/LinkInfo
    // pushes, etc.) accumulates on the process arena.  For content-heavy
    // pages (many links/words) the working set grows by ~1 MB/sec until
    // the OS starts paging and the window becomes unresponsive.
    let mut render_dirty: bool = true;
    let mut prev_mx: i32 = -1;
    let mut prev_my: i32 = -1;

    // Navigate to arg if provided (skipping --verbose flag)
    let mut verbose: bool = false;
    let mut url_arg: str = "";
    for ai in 1..arg_count() {
        let a: str = arg_get(ai);
        if str_eq(a, "--verbose") or str_eq(a, "-v") {
            verbose = true;
        } else if str_len(url_arg) == 0 {
            url_arg = a;
        };
    };
    if verbose {
        vlog_enable("");
        vlog_msg("startup", "verbose logging enabled");
    };
    if str_len(url_arg) > 0 {
        nav_url = url_arg;
        let init_chars: [i32] = str_to_chars(nav_url);
        for ci in 0..len(init_chars) {
            push(url_buf, init_chars[ci]);
        };
        needs_navigate = true;
        vlog_msg("startup url", nav_url);
    };

    while canvas_alive() {
        // Poll key OUTSIDE arena so array push/pop stays on parent arena
        let key: i32 = canvas_key();

        // Mouse wheel scrolling — handle outside arena and independent of mode
        // so the page scrolls like in a normal browser regardless of whether
        // the URL bar, search, or follow mode is active. Positive wheel values
        // mean scroll up (content moves down, scroll_y decreases).
        let wheel: i32 = canvas_wheel();
        if wheel != 0 {
            scroll_y -= wheel * LINE_H * 3;
            if scroll_y < 0 { scroll_y = 0; };
            if scroll_y > max_scroll { scroll_y = max_scroll; };
        };

        // Global TrueType keyboard shortcuts (only in Normal mode, and only
        // when not editing a textbox).  Ctrl+T toggles TT/bitmap; Ctrl+=
        // and Ctrl+- adjust the body pixel size when TT is on.
        let is_normal_mode: bool = match mode {
            BrowserMode::Normal => true,
            _ => false,
        };
        if is_normal_mode {
            let mut tt_changed: bool = false;
            if key == 20 and (tt_reg as i64) != (0 as i64) {
                // Ctrl+T: toggle.
                tt_cfg[TTC_ENABLED] = if tt_cfg[TTC_ENABLED] != 0 { 0 } else { 1 };
                tt_changed = true;
            };
            if tt_cfg[TTC_ENABLED] != 0 {
                // Ctrl+= (29 = Ctrl+]) / Ctrl+- (31): resize.  key 43 '+',
                // 45 '-', 61 '=' are the raw ASCII; without Ctrl they'd
                // type into insert mode, so only fire here in Normal.
                if key == 43 or key == 61 {
                    if tt_cfg[TTC_BASE_BODY_PX] < 48 { tt_cfg[TTC_BASE_BODY_PX] = tt_cfg[TTC_BASE_BODY_PX] + 1; tt_changed = true; };
                    if tt_cfg[TTC_BASE_MONO_PX] < 48 { tt_cfg[TTC_BASE_MONO_PX] = tt_cfg[TTC_BASE_MONO_PX] + 1; };
                };
                if key == 45 {
                    if tt_cfg[TTC_BASE_BODY_PX] > 8 { tt_cfg[TTC_BASE_BODY_PX] = tt_cfg[TTC_BASE_BODY_PX] - 1; tt_changed = true; };
                    if tt_cfg[TTC_BASE_MONO_PX] > 8 { tt_cfg[TTC_BASE_MONO_PX] = tt_cfg[TTC_BASE_MONO_PX] - 1; };
                };
            };
            if tt_changed {
                tt_recache(tt_reg, tt_mono, tt_head, tt_cfg, small_font);
                // Persist.
                let mut pl2: [str] = [];
                push(pl2, i32_to_str(tt_cfg[TTC_ENABLED]));
                push(pl2, i32_to_str(tt_cfg[TTC_BASE_BODY_PX]));
                push(pl2, i32_to_str(tt_cfg[TTC_BASE_MONO_PX]));
                storage_save_lines("font.cfg", pl2);
            };
        };

        // Handle textbox input outside arena to avoid realloc on child arena
        let url_is_insert: bool = match mode {
            BrowserMode::Insert => true,
            _ => false,
        };
        if url_focused and url_is_insert {
            // If select-all is active, first printable key or backspace replaces all
            if url_select_all and key > 0 and key != 1001 and key != 1002 and key != 1003 and key != 1004 and key != KEY_ENTER and key != KEY_ESC {
                if key >= 32 and key <= 126 {
                    while len(url_buf) > 0 { pop(url_buf); };
                    push(url_buf, key);
                    url_cursor = 1;
                    url_select_all = false;
                } else if key == 8 or key == 127 {
                    while len(url_buf) > 0 { pop(url_buf); };
                    url_cursor = 0;
                    url_select_all = false;
                } else if key == 22 {
                    // Ctrl+V replaces selection
                    while len(url_buf) > 0 { pop(url_buf); };
                    url_cursor = 0;
                    url_select_all = false;
                    let paste_sel: Result<str, str> = clipboard_get();
                    match paste_sel {
                        Result::Ok(clip_s) => {
                            let cs_chars: [i32] = str_to_chars(str_trim(clip_s));
                            for csi in 0..len(cs_chars) {
                                push(url_buf, cs_chars[csi]);
                            };
                            url_cursor = len(url_buf);
                        },
                        Result::Err(_e2) => {},
                    };
                } else if key == 1001 {
                    // Left arrow clears selection, cursor to start
                    url_select_all = false;
                    url_cursor = 0;
                } else if key == 1002 {
                    // Right arrow clears selection, cursor to end
                    url_select_all = false;
                    url_cursor = len(url_buf);
                };
            } else {
                // Normal cursor editing
                if key >= 32 and key <= 126 {
                    // Insert character at cursor position
                    push(url_buf, 0);
                    let mut si: i32 = len(url_buf) - 1;
                    while si > url_cursor {
                        url_buf[si] = url_buf[si - 1];
                        si = si - 1;
                    };
                    url_buf[url_cursor] = key;
                    url_cursor = url_cursor + 1;
                };
                if key == 8 and url_cursor > 0 {
                    // Backspace: remove char before cursor
                    let mut ri: i32 = url_cursor - 1;
                    while ri < len(url_buf) - 1 {
                        url_buf[ri] = url_buf[ri + 1];
                        ri = ri + 1;
                    };
                    pop(url_buf);
                    url_cursor = url_cursor - 1;
                };
                if key == 127 and url_cursor < len(url_buf) {
                    // Delete: remove char at cursor
                    let mut di: i32 = url_cursor;
                    while di < len(url_buf) - 1 {
                        url_buf[di] = url_buf[di + 1];
                        di = di + 1;
                    };
                    pop(url_buf);
                };
                // Arrow keys
                if key == 1001 and url_cursor > 0 {
                    url_cursor = url_cursor - 1;
                };
                if key == 1002 and url_cursor < len(url_buf) {
                    url_cursor = url_cursor + 1;
                };
                // Ctrl+A (key 1) = Home
                if key == 1 {
                    url_cursor = 0;
                };
                // Ctrl+E (key 5) = End
                if key == 5 {
                    url_cursor = len(url_buf);
                };
                // Ctrl+V (key 22) — paste at cursor
                if key == 22 {
                    let paste_r: Result<str, str> = clipboard_get();
                    match paste_r {
                        Result::Ok(clip) => {
                            let clip_chars: [i32] = str_to_chars(str_trim(clip));
                            for ci in 0..len(clip_chars) {
                                // Insert each char at cursor
                                push(url_buf, 0);
                                let mut pi: i32 = len(url_buf) - 1;
                                while pi > url_cursor {
                                    url_buf[pi] = url_buf[pi - 1];
                                    pi = pi - 1;
                                };
                                url_buf[url_cursor] = clip_chars[ci];
                                url_cursor = url_cursor + 1;
                            };
                        },
                        Result::Err(_e) => {},
                    };
                };
            };
        };

        // Handle search input outside arena
        let is_search: bool = match mode {
            BrowserMode::Search => true,
            _ => false,
        };
        if is_search {
            if key >= 32 and key <= 126 {
                push(search_buf, key);
            };
            if key == 8 and len(search_buf) > 0 {
                pop(search_buf);
            };
        };

        // Handle follow input outside arena
        let is_follow: bool = match mode {
            BrowserMode::Follow => true,
            _ => false,
        };
        if is_follow and key >= 97 and key <= 122 {
            push(follow_input, key);
        };

        // Main frame body (no arena block — avoids array realloc corruption)
        //
        // `nav_pass` lets us re-execute the navigate block once if input
        // dispatch sets `needs_navigate=true` (e.g. the F key reveals chrome
        // by reloading with show_full).  Without this retry the reload
        // would be deferred to the next frame and any follow-up key press
        // would race with it.
        let mut nav_pass: i32 = 0;
        while nav_pass < 2 {

            // ── Navigation ──────────────────────────
            if needs_navigate {
                needs_navigate = false;

                // Pre-parse to see if this is a same-page fragment jump — if
                // so we can skip the network round-trip entirely and just
                // scroll.
                let pending_u: Url = url_parse(nav_url);
                let prev_u: Url = url_parse(current_url);
                let same_page: bool = page_loaded and
                    str_eq(pending_u.scheme, prev_u.scheme) and
                    str_eq(pending_u.host, prev_u.host) and
                    pending_u.port == prev_u.port and
                    str_eq(pending_u.path, prev_u.path);

                if same_page and str_len(pending_u.fragment) > 0 {
                    // Same-document fragment jump: update pending fragment,
                    // update current_url so the URL bar reflects it, and let
                    // the render pass find the target.
                    pending_fragment = pending_u.fragment;
                    current_url = nav_url;
                    while len(url_buf) > 0 { pop(url_buf); };
                    let uc_s: [i32] = str_to_chars(current_url);
                    for ci in 0..len(uc_s) { push(url_buf, uc_s[ci]); };
                    url_cursor = len(url_buf);
                    render_dirty = true;
                } else {

                status_msg = "Loading...";
                error_msg = "";
                vlog_msg("nav start", nav_url);

                // Reset per-host TLS prime cache: first fetch of a new
                // user navigation re-primes (some hosts, e.g. text.npr.org,
                // need a fresh :443 warm-up per navigation), but repeated
                // subresource fetches within the same page still skip the
                // prime so image-heavy pages don't freeze.
                reset_prime_cache();

                // Draw a "Loading…" frame BEFORE the blocking HTTP fetch so the
                // window is visibly alive.  Without this the Win32 message pump
                // is blocked for the full duration of the TLS handshake +
                // recv loop (several seconds on slow hosts) and Windows marks
                // the app as "Not Responding".
                canvas_clear(theme[T_BG]);
                gfx_fill_rect(0, 0, canvas_width(), CHROME_TOP - 4, theme[T_STATUS_BG]);
                gfx_draw_text(8, 10, "Loading: {nav_url}", theme[T_FG], FONT_DEFAULT);
                let sty0: i32 = canvas_height() - CHROME_BOT;
                gfx_fill_rect(0, sty0, canvas_width(), CHROME_BOT, theme[T_STATUS_BG]);
                gfx_draw_text(4, sty0 + 6, " LOADING | {nav_url}", theme[T_FG], FONT_DEFAULT);
                canvas_flush();

                let u: Url = url_parse(nav_url);
                let use_tls: bool = str_eq(u.scheme, "https");

                if str_len(current_url) > 0 and not str_eq(current_url, nav_url) {
                    push(history_back, current_url);
                    while len(history_forward) > 0 { pop(history_forward); };
                };
                current_url = nav_url;

                let mut redir_count: i32 = 0;
                let mut fetch_host: str = u.host;
                let mut fetch_port: i32 = u.port;
                let mut fetch_path: str = u.path;
                let mut fetch_tls: bool = use_tls;
                let mut done: bool = false;

                while not done and redir_count < MAX_REDIRECTS {
                    vlog_msg("fetch start", fetch_host);
                    vlog_int("fetch tls", if fetch_tls { 1 } else { 0 });
                    // Canonical URL for cache keying. Always includes port
                    // for consistency (the cache doesn't normalize default
                    // ports, but all callers within a session agree).
                    let cache_scheme: str = if fetch_tls { "https" } else { "http" };
                    let cache_key: str = "{cache_scheme}://{fetch_host}:{fetch_port}{fetch_path}";
                    let cache_hit: i32 = http_cache_lookup(page_cache_urls, cache_key);
                    let mut resp: HttpResponse = http_make_error("");
                    let mut from_cache: bool = false;
                    if cache_hit >= 0 {
                        vlog_msg("cache hit", cache_key);
                        resp = http_cache_build(page_cache_bodies[cache_hit],
                                                page_cache_cts[cache_hit],
                                                page_cache_status[cache_hit]);
                        from_cache = true;
                    } else {
                        resp = http_get(fetch_host, fetch_port, fetch_path, fetch_tls);
                    };
                    vlog_int("fetch status", resp.status_code);
                    vlog_int("fetch body_len", str_len(resp.body));
                    // Cache any successful or 3xx-redirect response (not
                    // errors). Redirects are cheap to cache and let the
                    // full chain short-circuit on revisit.
                    if not from_cache and str_len(resp.error) == 0 and resp.status_code >= 200 and resp.status_code < 400 {
                        http_cache_put(page_cache_urls, page_cache_bodies,
                                       page_cache_cts, page_cache_status,
                                       cache_key, resp);
                    };

                    if str_len(resp.redirect_url) > 0 and (resp.status_code == 301 or resp.status_code == 302 or resp.status_code == 307) {
                        vlog_msg("redirect", resp.redirect_url);
                        let redir_u: Url = url_parse(resp.redirect_url);
                        fetch_host = redir_u.host;
                        fetch_port = redir_u.port;
                        fetch_path = redir_u.path;
                        fetch_tls = str_eq(redir_u.scheme, "https");
                        current_url = resp.redirect_url;
                        redir_count += 1;
                    } else if resp.ok {
                        while len(dom_nodes) > 0 { pop(dom_nodes); };
                        while len(dom_styles) > 0 { pop(dom_styles); };
                        // Clear image cache for new page
                        img_cache_idx = map_new();
                        while len(img_cache_data) > 0 { pop(img_cache_data); };
                        while len(img_cache_w) > 0 { pop(img_cache_w); };
                        while len(img_cache_h) > 0 { pop(img_cache_h); };
                        vlog_msg("parse start", "");
                        dom_root = html_parse(dom_nodes, resp.body);
                        vlog_int("parse nodes", len(dom_nodes));

                        page_loaded = true;
                        scroll_y = 0;
                        status_msg = current_url;

                        // Set DOM for JS bridge and execute inline <script> tags
                        js_bridge_set_dom(dom_nodes);
                        vlog_msg("js scripts start", "");
                        js_run_scripts(js_ctx, dom_nodes, dom_root);
                        vlog_msg("js scripts end", "");
                        if js_bridge_is_dom_dirty() > 0 {
                            js_bridge_clear_dom_dirty();
                        };

                        // CSS: collect <style> contents, external <link
                        // rel="stylesheet"> hrefs, and inline style=""
                        // attributes, parse into rules, then compute per-node
                        // ComputedStyle.  Done after JS so dynamically added
                        // nodes/classes participate in the cascade.
                        let mut css_rules: [CssRule] = [];
                        let mut css_kinds: [i32] = [];
                        let mut css_values: [str] = [];
                        css_collect_sources(dom_nodes, dom_root, css_kinds, css_values);
                        let mut css_order: i32 = 0;
                        for sti in 0..len(css_kinds) {
                            if css_kinds[sti] == 0 {
                                // Inline <style> text
                                css_order = css_parse(css_rules, css_values[sti], css_order);
                            } else {
                                // External <link rel="stylesheet" href="...">
                                let href: str = css_values[sti];
                                let mut link_host: str = fetch_host;
                                let mut link_port: i32 = fetch_port;
                                let mut link_path: str = href;
                                let mut link_tls: bool = fetch_tls;
                                if str_contains(href, "://") {
                                    let lu: Url = url_parse(href);
                                    link_host = lu.host;
                                    link_port = lu.port;
                                    link_path = lu.path;
                                    link_tls = str_eq(lu.scheme, "https");
                                } else if str_starts_with(href, "//") {
                                    let scheme: str = if fetch_tls { "https" } else { "http" };
                                    let lu2: Url = url_parse(str_concat(scheme, ":{href}"));
                                    link_host = lu2.host;
                                    link_port = lu2.port;
                                    link_path = lu2.path;
                                    link_tls = str_eq(lu2.scheme, "https");
                                } else {
                                    link_path = url_resolve_relative(fetch_path, href);
                                };
                                vlog_msg("css link fetch", href);
                                let lresp: HttpResponse = http_get(link_host, link_port, link_path, link_tls);
                                if lresp.ok and str_len(lresp.body) > 0 {
                                    css_order = css_parse(css_rules, lresp.body, css_order);
                                };
                            };
                        };
                        vlog_int("css rules", len(css_rules));
                        // Rebuild outline from the page's headings so `t`
                        // can jump between them.  Populated now; y values
                        // are filled in during render_node.
                        while len(outline_idx) > 0 { pop(outline_idx); };
                        while len(outline_y) > 0 { pop(outline_y); };
                        while len(outline_text) > 0 { pop(outline_text); };
                        while len(outline_level) > 0 { pop(outline_level); };
                        build_outline(dom_nodes, dom_root,
                                      outline_idx, outline_level, outline_text);
                        for _oy in 0..len(outline_idx) { push(outline_y, -1); };
                        // Detect chrome presence for the floating "F" button.
                        has_chrome = dom_has_chrome(dom_nodes, dom_root);
                        // Inject user stylesheet (site-chrome hiders) last,
                        // unless the user has toggled show_full.
                        if not show_full {
                            css_order = css_parse(css_rules, user_stylesheet(), css_order);
                        };
                        css_compute_all(dom_nodes, dom_root, css_rules, dom_styles);

                        done = true;
                    } else {
                        vlog_msg("fetch error", resp.error);
                        error_msg = resp.error;
                        status_msg = "Error: {resp.error}";
                        page_loaded = false;
                        done = true;
                    };
                };

                if redir_count >= MAX_REDIRECTS {
                    error_msg = "Too many redirects";
                    status_msg = "Error: too many redirects";
                };

                while len(url_buf) > 0 { pop(url_buf); };
                let uc: [i32] = str_to_chars(current_url);
                for ci in 0..len(uc) { push(url_buf, uc[ci]); };
                url_cursor = len(url_buf);

                // Force a repaint this frame. The fetch above drew a
                // provisional "Loading…" canvas to prove liveness, so
                // render_dirty is currently false. Without this flag the
                // newly parsed DOM wouldn't repaint until the next key/mouse
                // event, leaving the "Loading…" screen up until the user
                // presses a key.
                render_dirty = true;

                // Record fragment for post-render scroll.
                pending_fragment = pending_u.fragment;

                // Persistent history: prepend current_url, dedupe, trim to
                // 500 entries, and write back to disk.  current_url already
                // reflects any redirect target.
                if str_len(current_url) > 0 {
                    let mut dedup: [str] = [];
                    push(dedup, current_url);
                    for phi in 0..len(persistent_history) {
                        if len(dedup) >= 500 { break; };
                        let old: str = persistent_history[phi];
                        if not str_eq(old, current_url) {
                            push(dedup, old);
                        };
                    };
                    while len(persistent_history) > 0 { pop(persistent_history); };
                    for ph2 in 0..len(dedup) {
                        push(persistent_history, dedup[ph2]);
                    };
                    storage_save_lines("oscaweb_history.txt", persistent_history);
                };
                };  // end else (not same-page fragment)
            };

            // ── Input handling ──────────────────────
            if nav_pass == 0 {
            match mode {
                BrowserMode::Normal => {
                    if key == KEY_ESC {
                        show_help = false;
                        search_active = false;
                        search_query = "";
                        while len(search_match_y) > 0 { pop(search_match_y); };
                    } else if key == 106 {
                        scroll_y += LINE_H * 3;
                        if scroll_y > max_scroll { scroll_y = max_scroll; };
                    } else if key == 107 {
                        scroll_y -= LINE_H * 3;
                        if scroll_y < 0 { scroll_y = 0; };
                    } else if key == 100 or key == 32 {
                        // d or Space — scroll down one page (Space) / half page (d)
                        let scroll_amount: i32 = if key == 32 {
                            canvas_height() - CHROME_TOP - CHROME_BOT
                        } else {
                            (canvas_height() - CHROME_TOP - CHROME_BOT) / 2
                        };
                        scroll_y += scroll_amount;
                        if scroll_y > max_scroll { scroll_y = max_scroll; };
                    } else if key == 117 {
                        scroll_y -= (canvas_height() - CHROME_TOP - CHROME_BOT) / 2;
                        if scroll_y < 0 { scroll_y = 0; };
                    } else if key == 71 {
                        scroll_y = max_scroll;
                    } else if key == 103 {
                        if last_key == 103 { scroll_y = 0; };
                    } else if key == 102 {
                        if page_loaded {
                            mode = BrowserMode::Follow;
                            while len(follow_input) > 0 { pop(follow_input); };
                            while len(follow_links) > 0 { pop(follow_links); };
                            let labels: [str] = make_hint_labels(len(page_links));
                            for li in 0..len(page_links) {
                                let lk: LinkInfo = page_links[li];
                                let labeled: LinkInfo = LinkInfo {
                                    x: lk.x, y: lk.y, w: lk.w, h: lk.h,
                                    href: lk.href,
                                    label: if li < len(labels) { labels[li] } else { "" },
                                    chrome: lk.chrome,
                                };
                                push(follow_links, labeled);
                            };
                        };
                    } else if key == 114 {
                        if last_key == 103 {
                            // gr — toggle reader mode
                            reader_on = not reader_on;
                            scroll_y = 0;
                            render_dirty = true;
                        } else if str_len(current_url) > 0 {
                            // `r` — reload. Invalidate the cached copy of
                            // the current page (and its redirect chain, if
                            // any) so the re-navigation re-fetches instead
                            // of hitting the page cache.
                            let ru: Url = url_parse(current_url);
                            let rsch: str = if str_eq(ru.scheme, "https") { "https" } else { "http" };
                            let rkey: str = "{rsch}://{ru.host}:{ru.port}{ru.path}";
                            http_cache_invalidate(page_cache_urls, page_cache_bodies,
                                                  page_cache_cts, page_cache_status, rkey);
                            nav_url = current_url;
                            needs_navigate = true;
                        };
                    } else if key == 82 and last_key == 103 {
                        // gR — toggle show_full (show whole page / re-enable
                        // auto chrome trim).  Reloads so the user stylesheet
                        // and CSS cascade are rebuilt with the new flag.
                        show_full = not show_full;
                        scroll_y = 0;
                        if str_len(current_url) > 0 {
                            nav_url = current_url;
                            needs_navigate = true;
                        };
                        render_dirty = true;
                    } else if key == 109 and last_key == 103 {
                        // gm — jump to main content landmark.  Uses the
                        // existing fragment machinery by scanning the
                        // outline's y values (populated by the last render).
                        if page_loaded and dom_root >= 0 {
                            let main_jx: i32 = find_main_content_idx(dom_nodes, dom_root);
                            if main_jx >= 0 {
                                // A subsequent render pass is the cheapest
                                // way to resolve the y coordinate of the
                                // landmark — reuse fragment_y_out with an
                                // idx-synthesized id.  Fallback: scroll to
                                // first outline item.
                                if len(outline_y) > 0 and outline_y[0] >= 0 {
                                    scroll_y = outline_y[0];
                                    if scroll_y > max_scroll { scroll_y = max_scroll; };
                                } else {
                                    scroll_y = 0;
                                };
                                render_dirty = true;
                            };
                        };
                    } else if key == 70 {
                        // F — toggle chrome visibility.  When chrome is
                        // trimmed, reveal it and enter follow-hint mode on
                        // the freshly-populated chrome links.  When chrome
                        // is already visible, hide it again (returning to
                        // the trimmed view).
                        if page_loaded {
                            if not show_full {
                                show_full = true;
                                scroll_y = 0;
                                pending_follow_chrome = true;
                                if str_len(current_url) > 0 {
                                    nav_url = current_url;
                                    needs_navigate = true;
                                };
                                render_dirty = true;
                            } else {
                                show_full = false;
                                scroll_y = 0;
                                pending_follow_chrome = false;
                                mode = BrowserMode::Normal;
                                while len(follow_input) > 0 { pop(follow_input); };
                                while len(follow_links) > 0 { pop(follow_links); };
                                if str_len(current_url) > 0 {
                                    nav_url = current_url;
                                    needs_navigate = true;
                                };
                                render_dirty = true;
                            };
                        };
                    } else if key == 116 {
                        // t — toggle outline (table of contents) panel
                        show_outline = not show_outline;
                        render_dirty = true;
                    } else if key == 112 {
                        // p — paste URL from clipboard and navigate
                        let paste_result: Result<str, str> = clipboard_get();
                        match paste_result {
                            Result::Ok(clip_text) => {
                                let trimmed: str = str_trim(clip_text);
                                if str_len(trimmed) > 0 {
                                    if not str_contains(trimmed, "://") {
                                        nav_url = str_concat("https://", trimmed);
                                    } else {
                                        nav_url = trimmed;
                                    };
                                    needs_navigate = true;
                                };
                            },
                            Result::Err(_e) => {},
                        };
                    } else if key == 111 {
                        // 'o' — open URL (clear bar)
                        mode = BrowserMode::Insert;
                        url_focused = true;
                        while len(url_buf) > 0 { pop(url_buf); };
                        url_cursor = 0;
                        url_select_all = false;
                    } else if key == 79 {
                        // 'O' — edit current URL (select all)
                        mode = BrowserMode::Insert;
                        url_focused = true;
                        url_cursor = len(url_buf);
                        url_select_all = true;
                    } else if key == 47 {
                        mode = BrowserMode::Search;
                        while len(search_buf) > 0 { pop(search_buf); };
                        search_active = true;
                    } else if key == 63 {
                        show_help = not show_help;
                    } else if key == 121 {
                        // y — if last key was also y (yy), copy URL to clipboard
                        if last_key == 121 {
                            if str_len(current_url) > 0 {
                                clipboard_set(current_url);
                            };
                        };
                    } else if key == 3 {
                        // Ctrl+C — copy current URL to clipboard
                        if str_len(current_url) > 0 {
                            clipboard_set(current_url);
                        };
                    } else if key == 72 {
                        if len(history_back) > 0 {
                            push(history_forward, current_url);
                            nav_url = pop(history_back);
                            needs_navigate = true;
                        };
                    } else if key == 76 {
                        if len(history_forward) > 0 {
                            push(history_back, current_url);
                            nav_url = pop(history_forward);
                            needs_navigate = true;
                        };
                    } else if key == 110 and search_active {
                        // n — next search match
                        if len(search_match_y) > 0 {
                            search_match_idx += 1;
                            if search_match_idx >= len(search_match_y) {
                                search_match_idx = 0;
                            };
                            scroll_y = search_match_y[search_match_idx];
                            if scroll_y < 0 { scroll_y = 0; };
                            if scroll_y > max_scroll { scroll_y = max_scroll; };
                        };
                    } else if key == 81 {
                        // Q — quit the browser
                        canvas_close();
                        exit(0);
                    } else if key == 78 and search_active {
                        // N — previous search match
                        if len(search_match_y) > 0 {
                            search_match_idx -= 1;
                            if search_match_idx < 0 {
                                search_match_idx = len(search_match_y) - 1;
                            };
                            scroll_y = search_match_y[search_match_idx];
                            if scroll_y < 0 { scroll_y = 0; };
                            if scroll_y > max_scroll { scroll_y = max_scroll; };
                        };
                    } else if key == 98 {
                        // b — toggle bookmark for current URL
                        if str_len(current_url) > 0 {
                            let mut was_bookmarked: bool = false;
                            let mut new_bm: [str] = [];
                            for bi in 0..len(bookmarks) {
                                if str_eq(bookmarks[bi], current_url) {
                                    was_bookmarked = true;
                                } else {
                                    push(new_bm, bookmarks[bi]);
                                };
                            };
                            if not was_bookmarked {
                                // Prepend new bookmark
                                let mut with_new: [str] = [];
                                push(with_new, current_url);
                                for bi2 in 0..len(new_bm) {
                                    push(with_new, new_bm[bi2]);
                                };
                                while len(bookmarks) > 0 { pop(bookmarks); };
                                for bi3 in 0..len(with_new) {
                                    push(bookmarks, with_new[bi3]);
                                };
                                status_msg = "Bookmarked: {current_url}";
                            } else {
                                while len(bookmarks) > 0 { pop(bookmarks); };
                                for bi4 in 0..len(new_bm) {
                                    push(bookmarks, new_bm[bi4]);
                                };
                                status_msg = "Removed bookmark: {current_url}";
                            };
                            storage_save_lines("oscaweb_bookmarks.txt", bookmarks);
                        };
                    } else if key == 66 {
                        // B — open bookmarks overlay
                        show_bookmarks = not show_bookmarks;
                    } else if key >= 49 and key <= 57 and show_outline {
                        // 1..9 jumps to the Nth outline item (takes
                        // precedence over bookmarks when outline is open).
                        let opick: i32 = key - 49;
                        if opick < len(outline_y) and outline_y[opick] >= 0 {
                            scroll_y = outline_y[opick];
                            if scroll_y < 0 { scroll_y = 0; };
                            if scroll_y > max_scroll { scroll_y = max_scroll; };
                            render_dirty = true;
                        };
                    } else if key >= 49 and key <= 57 and show_bookmarks {
                        // 1..9 opens the corresponding bookmark
                        let pick: i32 = key - 49;
                        if pick < len(bookmarks) {
                            nav_url = bookmarks[pick];
                            needs_navigate = true;
                            show_bookmarks = false;
                        };
                    } else if key == 43 or key == 61 {
                        // + or = — zoom in
                        if body_scale < 4 { body_scale = body_scale + 1; };
                        render_dirty = true;
                    } else if key == 45 {
                        // - — zoom out
                        if body_scale > 1 { body_scale = body_scale - 1; };
                        render_dirty = true;
                    } else if key == 48 {
                        // 0 — reset zoom
                        body_scale = 1;
                        render_dirty = true;
                    };
                    if key > 0 { last_key = key; };
                },
                BrowserMode::Insert => {
                    if key == KEY_ESC {
                        mode = BrowserMode::Normal;
                        url_focused = false;
                        url_select_all = false;
                        ac_selected = -1;
                    } else if key == 1004 or key == 9 {
                        // Down-arrow / Tab cycles autocomplete forward
                        if len(ac_matches) > 0 {
                            ac_selected = ac_selected + 1;
                            if ac_selected >= len(ac_matches) { ac_selected = 0; };
                        };
                    } else if key == 1003 {
                        // Up-arrow cycles autocomplete backward
                        if len(ac_matches) > 0 {
                            if ac_selected <= 0 { ac_selected = len(ac_matches) - 1; }
                            else { ac_selected = ac_selected - 1; };
                        };
                    } else if key == KEY_ENTER and url_focused {
                        let typed_url: str = str_from_chars(url_buf);
                        // If an autocomplete suggestion is highlighted, use it
                        let target: str = if ac_selected >= 0 and ac_selected < len(ac_matches) {
                            ac_matches[ac_selected]
                        } else {
                            typed_url
                        };
                        if str_len(target) > 0 {
                            if str_contains(target, "://") {
                                nav_url = target;
                            } else if url_looks_like_url(target) {
                                nav_url = str_concat("https://", target);
                            } else {
                                // Omnibox search: route to DuckDuckGo
                                nav_url = str_concat("https://html.duckduckgo.com/html/?q=", url_encode(target));
                            };
                            needs_navigate = true;
                            mode = BrowserMode::Normal;
                            url_focused = false;
                            url_select_all = false;
                            ac_selected = -1;
                        };
                    };
                },
                BrowserMode::Follow => {
                    if key == KEY_ESC {
                        mode = BrowserMode::Normal;
                    } else if key == 70 {
                        // F while in follow-chrome mode — hide chrome again
                        // and return to normal. Symmetric with the F toggle
                        // in Normal mode.
                        mode = BrowserMode::Normal;
                        while len(follow_input) > 0 { pop(follow_input); };
                        while len(follow_links) > 0 { pop(follow_links); };
                        if show_full {
                            show_full = false;
                            scroll_y = 0;
                            pending_follow_chrome = false;
                            if str_len(current_url) > 0 {
                                nav_url = current_url;
                                needs_navigate = true;
                            };
                            render_dirty = true;
                        };
                    } else if key >= 97 and key <= 122 {
                        // push already happened outside arena
                        let typed: str = str_from_chars(follow_input);
                        let mut matched: bool = false;
                        let mut partial: bool = false;
                        for li in 0..len(follow_links) {
                            if str_eq(follow_links[li].label, typed) {
                                let href: str = follow_links[li].href;
                                if str_len(href) > 0 {
                                    if str_contains(href, "://") {
                                        nav_url = href;
                                    } else {
                                        let cu: Url = url_parse(current_url);
                                        let rp: str = url_resolve_relative(cu.path, href);
                                        nav_url = url_to_string(Url {
                                            scheme: cu.scheme, host: cu.host,
                                            port: cu.port, path: rp,
                                            fragment: "",
                                        });
                                    };
                                    needs_navigate = true;
                                };
                                mode = BrowserMode::Normal;
                                matched = true;
                                break;
                            } else if str_starts_with(follow_links[li].label, typed) {
                                partial = true;
                            };
                        };
                        if not matched and not partial {
                            mode = BrowserMode::Normal;
                        };
                    };
                },
                BrowserMode::Search => {
                    if key == KEY_ESC {
                        mode = BrowserMode::Normal;
                        search_active = false;
                        search_query = "";
                        while len(search_match_y) > 0 { pop(search_match_y); };
                    } else if key == KEY_ENTER {
                        search_query = str_to_lower(str_from_chars(search_buf));
                        // Build match positions by scanning DOM text
                        while len(search_match_y) > 0 { pop(search_match_y); };
                        search_match_idx = 0;
                        if str_len(search_query) > 0 and dom_root >= 0 {
                            // Collect all text content and find matches by line
                            let full_text: str = str_to_lower(html_get_text_content(dom_nodes, dom_root));
                            let mut search_pos: i32 = 0;
                            let mut match_line: i32 = 0;
                            while search_pos < str_len(full_text) {
                                let found: i32 = str_find(str_slice(full_text, search_pos, str_len(full_text)), search_query);
                                if found < 0 { break; };
                                // Estimate y position: count chars up to match, divide by chars_per_line
                                let chars_per_line: i32 = (canvas_width() - PAD * 2) / FONT_W;
                                let char_pos: i32 = search_pos + found;
                                let line_num: i32 = char_pos / max_i32(chars_per_line, 1);
                                let match_y: i32 = line_num * LINE_H;
                                push(search_match_y, match_y);
                                search_pos = search_pos + found + str_len(search_query);
                            };
                        };
                        mode = BrowserMode::Normal;
                        // Jump to first match
                        if len(search_match_y) > 0 {
                            scroll_y = search_match_y[0];
                            if scroll_y < 0 { scroll_y = 0; };
                            if scroll_y > max_scroll { scroll_y = max_scroll; };
                        };
                    };
                    // push/pop for search_buf handled outside arena
                },
            };
            };  // end if nav_pass == 0

            nav_pass += 1;
            if not needs_navigate { break; };
        };  // end while nav_pass

            // ── Mouse: selection and link clicks ──────
            let mx: i32 = canvas_mouse_x();
            let my: i32 = canvas_mouse_y();
            let mbtn: i32 = canvas_mouse_btn();
            let btn_down: bool = band(mbtn, 1) == 1;
            let was_down: bool = band(prev_btn, 1) == 1;

            if btn_down and not was_down {
                // Mouse down — start selection
                sel_active = true;
                sel_start_x = mx;
                sel_start_y = my;
                sel_end_x = mx;
                sel_end_y = my;
            } else if btn_down and was_down and sel_active {
                // Mouse drag — update selection end
                sel_end_x = mx;
                sel_end_y = my;
            } else if not btn_down and was_down and sel_active {
                // Mouse up — finalize selection
                sel_end_x = mx;
                sel_end_y = my;

                // If it was a click (not a drag), handle as link click
                let dx: i32 = abs_i32(sel_end_x - sel_start_x);
                let dy: i32 = abs_i32(sel_end_y - sel_start_y);
                if dx < 4 and dy < 4 {
                    // Click — check onclick handlers first, then links
                    sel_active = false;
                    let mut onclick_handled: bool = false;
                    for ci in 0..len(page_clickables) {
                        let ck: ClickInfo = page_clickables[ci];
                        if mx >= ck.x and mx < ck.x + ck.w and my >= ck.y and my < ck.y + ck.h {
                            let onclick_attr: str = html_get_attr(dom_nodes[ck.node_idx], "onclick");
                            if str_len(onclick_attr) > 0 {
                                let _onclick_result: str = js_engine_eval(js_ctx, onclick_attr);
                                if js_bridge_is_dom_dirty() > 0 {
                                    js_bridge_clear_dom_dirty();
                                };
                                onclick_handled = true;
                                break;
                            };
                        };
                    };
                    if not onclick_handled {
                        for li in 0..len(page_links) {
                            let lk: LinkInfo = page_links[li];
                            if mx >= lk.x and mx < lk.x + lk.w and my >= lk.y and my < lk.y + lk.h {
                                let href: str = lk.href;
                                if str_len(href) > 0 {
                                    if str_contains(href, "://") {
                                        nav_url = href;
                                    } else {
                                        let cu: Url = url_parse(current_url);
                                        let rp: str = url_resolve_relative(cu.path, href);
                                        nav_url = url_to_string(Url {
                                            scheme: cu.scheme, host: cu.host,
                                            port: cu.port, path: rp,
                                            fragment: "",
                                        });
                                    };
                                    needs_navigate = true;
                                };
                                break;
                            };
                        };
                    };
                } else {
                    // Drag completed — copy selected text to clipboard
                    let sx0: i32 = min_i32(sel_start_x, sel_end_x);
                    let sy0: i32 = min_i32(sel_start_y, sel_end_y);
                    let sx1: i32 = max_i32(sel_start_x, sel_end_x);
                    let sy1: i32 = max_i32(sel_start_y, sel_end_y);
                    let mut sel_words: [str] = [];
                    for si in 0..len(word_map) {
                        let sw: WordInfo = word_map[si];
                        let wcx: i32 = sw.x + sw.w / 2;
                        let wcy: i32 = sw.y + LINE_H / 2;
                        if wcx >= sx0 and wcx <= sx1 and wcy >= sy0 and wcy <= sy1 {
                            push(sel_words, sw.text);
                        };
                    };
                    if len(sel_words) > 0 {
                        let sel_text: str = str_join(sel_words, " ");
                        clipboard_set(sel_text);
                    };
                };
            };

            // ── Render ──────────────────────────────
            // Only redraw when something observable changed.  Key presses,
            // mouse button transitions and navigation all flag the frame
            // dirty; idle frames become pure sleeps, which keeps process
            // memory bounded.  (The main loop intentionally runs outside
            // any `arena { }` block, so every per-frame allocation accumulates
            // on the process arena; on content-heavy pages this grows by
            // ~1 MB/sec until the OS starts paging and the window hangs.)
            //
            // Mouse *position* changes deliberately do NOT dirty by themselves
            // — otherwise a user simply moving the cursor over the window
            // would re-render every frame.  An active text selection or
            // Follow mode hover explicitly asks for re-render below.
            let pos_matters: bool = sel_active;
            if key != 0 or mbtn != prev_btn or wheel != 0 or
               canvas_resized() or
               (pos_matters and (mx != prev_mx or my != prev_my)) {
                render_dirty = true;
                if vlog_is_enabled() != 0 {
                    if key != 0 { vlog_int("dirty key", key); };
                    if mbtn != prev_btn { vlog_int("dirty mbtn", mbtn); };
                    if wheel != 0 { vlog_int("dirty wheel", wheel); };
                };
            };

            if render_dirty {
            vlog_msg("render start", "");
            canvas_clear(theme[T_BG]);

            // Address bar
            gfx_fill_rect(0, 0, canvas_width(), CHROME_TOP, theme[T_STATUS_BG]);
            // Font-size toggle button on the right edge of the chrome.
            // Label shows the *current* size; clicking flips to the other.
            let fs_btn_w: i32 = 44;
            let fs_btn_h: i32 = 20;
            let fs_btn_x: i32 = canvas_width() - fs_btn_w - 4;
            let fs_btn_y: i32 = 4;
            // Label: bitmap mode shows 8pt/12pt; TT mode shows the live
            // body pixel size so the user can see what each click produced.
            let fs_label: str = if tt_cfg[TTC_ENABLED] != 0 {
                str_concat(i32_to_str(tt_cfg[TTC_BASE_BODY_PX]), "pt")
            } else if small_font { "8pt" } else { "12pt" };
            let fs_clicked: bool = ui_button(fs_btn_x, fs_btn_y, fs_btn_w, fs_btn_h,
                                             fs_label, prev_btn, ui_colors);
            if fs_clicked {
                if tt_cfg[TTC_ENABLED] != 0 {
                    // Cycle body size through 8→12→16→20→24→28→8.  Mono
                    // tracks 2 px below body (readable code without looking
                    // oversized).
                    let sizes: [i32] = [8, 12, 16, 20, 24, 28];
                    let mut cur_idx: i32 = -1;
                    for si in 0..len(sizes) {
                        if sizes[si] == tt_cfg[TTC_BASE_BODY_PX] { cur_idx = si; };
                    };
                    let next_idx: i32 = if cur_idx < 0 { 1 } else { (cur_idx + 1) % len(sizes) };
                    tt_cfg[TTC_BASE_BODY_PX] = sizes[next_idx];
                    tt_cfg[TTC_BASE_MONO_PX] = sizes[next_idx] - 2;
                    if tt_cfg[TTC_BASE_MONO_PX] < 8 { tt_cfg[TTC_BASE_MONO_PX] = 8; };
                    tt_recache(tt_reg, tt_mono, tt_head, tt_cfg, small_font);
                    // Persist.
                    let mut pl3: [str] = [];
                    push(pl3, i32_to_str(tt_cfg[TTC_ENABLED]));
                    push(pl3, i32_to_str(tt_cfg[TTC_BASE_BODY_PX]));
                    push(pl3, i32_to_str(tt_cfg[TTC_BASE_MONO_PX]));
                    storage_save_lines("font.cfg", pl3);
                } else {
                    small_font = not small_font;
                    tt_recache(tt_reg, tt_mono, tt_head, tt_cfg, small_font);
                };
            };
            // TrueType toggle button just to the left of the font-size button.
            // Disabled (greyed label) when no regular TT font loaded.
            let tt_btn_w: i32 = 36;
            let tt_btn_x: i32 = fs_btn_x - tt_btn_w - 4;
            let tt_label: str = if tt_cfg[TTC_ENABLED] != 0 { "TT" } else { "Bmp" };
            let tt_clicked: bool = ui_button(tt_btn_x, fs_btn_y, tt_btn_w, fs_btn_h,
                                             tt_label, prev_btn, ui_colors);
            if tt_clicked and (tt_reg as i64) != (0 as i64) {
                tt_cfg[TTC_ENABLED] = if tt_cfg[TTC_ENABLED] != 0 { 0 } else { 1 };
                tt_recache(tt_reg, tt_mono, tt_head, tt_cfg, small_font);
                // Persist new state.
                let mut pl: [str] = [];
                push(pl, i32_to_str(tt_cfg[TTC_ENABLED]));
                push(pl, i32_to_str(tt_cfg[TTC_BASE_BODY_PX]));
                push(pl, i32_to_str(tt_cfg[TTC_BASE_MONO_PX]));
                storage_save_lines("font.cfg", pl);
            };
            // Theme (light/dark) toggle, just left of the TT button.  Label is
            // the icon representing the *current* state — sun for light, moon
            // for dark.  Clicking flips it and persists to theme.cfg.
            let th_btn_w: i32 = 28;
            let th_btn_x: i32 = tt_btn_x - th_btn_w - 4;
            let th_label: str = if light_mode { "Sun" } else { "Moon" };
            let th_clicked: bool = ui_button(th_btn_x, fs_btn_y, th_btn_w, fs_btn_h,
                                             th_label, prev_btn, ui_colors);
            if th_clicked {
                light_mode = not light_mode;
                theme = theme_make(light_mode);
                ui_colors = theme_make_ui(light_mode);
                let mut plth: [str] = [];
                push(plth, i32_to_str(if light_mode { 1 } else { 0 }));
                storage_save_lines("theme.cfg", plth);
            };
            // Pass key=0 to ui_textbox — we handle keyboard input outside arena.
            let show_focused: bool = match mode {
                BrowserMode::Insert => url_focused,
                _ => false,
            };
            let url_bar_w: i32 = canvas_width() - 8 - fs_btn_w - 4 - tt_btn_w - 4 - th_btn_w - 4;
            let mouse_focus: bool = ui_textbox(4, 4, url_bar_w, url_buf,
                                     show_focused, prev_btn, 0,
                                     url_cursor, url_select_all, ui_colors);
            // Detect actual click (button-down transition) inside the URL bar
            let url_bar_btn: i32 = canvas_mouse_btn();
            let url_bar_mx: i32 = canvas_mouse_x();
            let url_bar_my: i32 = canvas_mouse_y();
            let url_bar_hover: bool = url_bar_mx >= 4 and url_bar_mx < 4 + url_bar_w and url_bar_my >= 4 and url_bar_my < 24;
            let url_bar_clicked: bool = url_bar_hover and band(url_bar_btn, 1) == 1 and band(prev_btn, 1) == 0;

            match mode {
                BrowserMode::Normal => {
                    if url_bar_clicked {
                        mode = BrowserMode::Insert;
                        url_focused = true;
                        url_cursor = len(url_buf);
                        url_select_all = true;
                    };
                },
                BrowserMode::Insert => {
                    // Only reposition cursor on actual click, not every frame
                    if url_bar_clicked and not url_select_all {
                        let click_pos: i32 = (url_bar_mx - 4 - 4) / 8;
                        if click_pos < 0 { url_cursor = 0; }
                        else if click_pos > len(url_buf) { url_cursor = len(url_buf); }
                        else { url_cursor = click_pos; };
                    };
                    // Click clears select-all (but keeps focus)
                    if url_bar_clicked and url_select_all {
                        url_select_all = false;
                        url_cursor = len(url_buf);
                    };
                },
                _ => {},
            };

            // Page content
            if page_loaded and dom_root >= 0 {
                while len(page_links) > 0 { pop(page_links); };
                while len(page_clickables) > 0 { pop(page_clickables); };
                let x_ptr: [i32] = [PAD];
                let y_ptr: [i32] = [0];
                let pg_u: Url = url_parse(current_url);
                while len(word_map) > 0 { pop(word_map); };
                // Find the main content subtree. Used by both reader mode
                // and the default view: when a landmark (<main>/<article>)
                // is present, we render from there and skip all the site
                // chrome that precedes it in the DOM.  The user can force
                // the full page with `gR` (sets show_full).
                let main_idx: i32 = find_main_content_idx(dom_nodes, dom_root);
                let mut render_root: i32 = dom_root;
                if not show_full and main_idx >= 0 { render_root = main_idx; };
                // Narrow the main content column to a readable ~640 CSS px
                // (roughly 65-75 characters per line) and center it. Scales
                // with zoom so the same character count fits per line at any
                // body_scale. In reader mode this applies to the render root
                // (which equals <main>/<article> when present, otherwise the
                // whole tree). Outside reader mode it applies only when
                // <main>/<article> exists, so utility pages (homepages,
                // search results, dashboards with no <main>) are left at
                // full width.
                // Gated on the target not already having a max-width set by
                // the page's CSS — we don't want to fight pages that already
                // lay themselves out sensibly.
                let mut narrow_idx: i32 = -1;
                if reader_on { narrow_idx = render_root; }
                else if main_idx >= 0 and not show_full { narrow_idx = main_idx; };
                // Remember any mutation so we can restore it after rendering
                // (otherwise the page would stay mutated across frames).
                let mut narrow_override: bool = false;
                let mut narrow_prev_mwpx: i32 = -1;
                let mut narrow_prev_mwpct: i32 = -1;
                let mut narrow_prev_center: i32 = -1;
                if narrow_idx >= 0 and narrow_idx < len(dom_styles) {
                    if dom_styles[narrow_idx].max_width_px < 0
                       and dom_styles[narrow_idx].max_width_pct < 0 {
                        narrow_prev_mwpx = dom_styles[narrow_idx].max_width_px;
                        narrow_prev_mwpct = dom_styles[narrow_idx].max_width_pct;
                        narrow_prev_center = dom_styles[narrow_idx].center_block;
                        dom_styles[narrow_idx].max_width_px = 640 * body_scale;
                        dom_styles[narrow_idx].center_block = 1;
                        narrow_override = true;
                    };
                };
                let fragment_y_out: [i32] = [-1];
                let trim_chrome: bool = reader_on or not show_full;
                let body_font_eff: i32 = if small_font { FONT_PROPORTIONAL } else { BODY_FONT };
                let body_mono_eff: i32 = if small_font { FONT_DEFAULT } else { BODY_MONO_FONT };
                render_node(dom_nodes, render_root, x_ptr, y_ptr,
                            scroll_y, canvas_width(), page_links,
                            theme[T_FG], body_font_eff, body_scale, false, "", 0, false,
                            img_cache_idx, img_cache_data,
                            img_cache_w, img_cache_h,
                            pg_u.scheme, pg_u.host, pg_u.port, pg_u.path,
                            search_query, word_map,
                            false, false, -1, [0], page_clickables,
                            dom_styles,
                            trim_chrome, false,
                            pending_fragment, fragment_y_out,
                            outline_idx, outline_y,
                            body_mono_eff,
                            theme,
                            tt_reg, tt_mono, tt_head, tt_cfg);
                // Restore original ComputedStyle fields so toggling reader
                // mode off (or navigating away) cleanly reverts the narrowing.
                if narrow_override {
                    dom_styles[narrow_idx].max_width_px = narrow_prev_mwpx;
                    dom_styles[narrow_idx].max_width_pct = narrow_prev_mwpct;
                    dom_styles[narrow_idx].center_block = narrow_prev_center;
                };
                doc_height = y_ptr[0];
                max_scroll = max_i32(doc_height - (canvas_height() - CHROME_TOP - CHROME_BOT), 0);

                // Fragment scroll: if the pending fragment matched a node,
                // set scroll_y to its y position and schedule another
                // render pass so the content appears at the top.
                if str_len(pending_fragment) > 0 {
                    if fragment_y_out[0] >= 0 {
                        scroll_y = fragment_y_out[0];
                        if scroll_y > max_scroll { scroll_y = max_scroll; };
                        render_dirty = true;
                    };
                    // Consume fragment either way — avoids re-scrolling on
                    // every frame if the id isn't present.
                    pending_fragment = "";
                };
                if scroll_y > max_scroll { scroll_y = max_scroll; };

                // Draw text selection highlight
                if sel_active and (sel_start_x != sel_end_x or sel_start_y != sel_end_y) {
                    let sx0: i32 = min_i32(sel_start_x, sel_end_x);
                    let sy0: i32 = min_i32(sel_start_y, sel_end_y);
                    let sx1: i32 = max_i32(sel_start_x, sel_end_x);
                    let sy1: i32 = max_i32(sel_start_y, sel_end_y);
                    for hi in 0..len(word_map) {
                        let hw: WordInfo = word_map[hi];
                        let wcx: i32 = hw.x + hw.w / 2;
                        let wcy: i32 = hw.y + LINE_H / 2;
                        // Check if word center is inside selection rectangle
                        if wcx >= sx0 and wcx <= sx1 and wcy >= sy0 and wcy <= sy1 {
                            gfx_fill_rect(hw.x, hw.y, hw.w, LINE_H, theme[T_SEL]);
                            gfx_draw_text(hw.x, hw.y, hw.text, theme[T_HINT_FG], FONT_DEFAULT);
                        };
                    };
                };
            } else if str_len(error_msg) > 0 {
                gfx_draw_text(PAD, CHROME_TOP + PAD, "Error loading page:", theme[T_H1], FONT_DEFAULT);
                gfx_draw_text(PAD, CHROME_TOP + PAD + LINE_H * 2, error_msg, theme[T_FG], FONT_DEFAULT);
                gfx_draw_text(PAD, CHROME_TOP + PAD + LINE_H * 4, "Press 'o' to enter a new URL", theme[T_HR], FONT_DEFAULT);
            } else {
                // ASCII art logo
                let ax: i32 = PAD + 100;
                let mut ay: i32 = CHROME_TOP + 60;
                gfx_draw_text(ax, ay, "  ___            __      __   _", theme[T_H1], FONT_DEFAULT); ay += LINE_H;
                gfx_draw_text(ax, ay, " / _ \\ ___ ___  \\ \\    / /__| |__", theme[T_H1], FONT_DEFAULT); ay += LINE_H;
                gfx_draw_text(ax, ay, "| (_) (_-</ __|  \\ \\/\\/ / -_) '_ \\", theme[T_H1], FONT_DEFAULT); ay += LINE_H;
                gfx_draw_text(ax, ay, " \\___//__/\\___|   \\_/\\_/\\___|_.__/", theme[T_H1], FONT_DEFAULT); ay += LINE_H;
                ay += LINE_H;
                gfx_draw_text(ax, ay, "A minimal Vim-powered browser written in Oscan", theme[T_FG], FONT_DEFAULT); ay += LINE_H;
                ay += LINE_H * 2;
                gfx_draw_text(ax, ay, "Press 'o' to open a URL", theme[T_LINK], FONT_DEFAULT); ay += LINE_H;
                gfx_draw_text(ax, ay, "Press '?' for keyboard shortcuts", theme[T_LINK], FONT_DEFAULT); ay += LINE_H;
                ay += LINE_H * 2;
                gfx_draw_text(ax, ay, "Keyboard shortcuts:", theme[T_H2], FONT_DEFAULT); ay += LINE_H + 4;
                gfx_draw_text(ax, ay, "j/k       Scroll down/up", theme[T_FG], FONT_DEFAULT); ay += LINE_H;
                gfx_draw_text(ax, ay, "d/u       Half page down/up", theme[T_FG], FONT_DEFAULT); ay += LINE_H;
                gfx_draw_text(ax, ay, "Space     Full page down", theme[T_FG], FONT_DEFAULT); ay += LINE_H;
                gfx_draw_text(ax, ay, "gg / G    Top / bottom of page", theme[T_FG], FONT_DEFAULT); ay += LINE_H;
                gfx_draw_text(ax, ay, "f         Follow link (hint mode)", theme[T_FG], FONT_DEFAULT); ay += LINE_H;
                gfx_draw_text(ax, ay, "o         Open URL", theme[T_FG], FONT_DEFAULT); ay += LINE_H;
                gfx_draw_text(ax, ay, "p         Paste URL and go", theme[T_FG], FONT_DEFAULT); ay += LINE_H;
                gfx_draw_text(ax, ay, "yy        Copy URL to clipboard", theme[T_FG], FONT_DEFAULT); ay += LINE_H;
                gfx_draw_text(ax, ay, "Ctrl+V    Paste in URL bar", theme[T_FG], FONT_DEFAULT); ay += LINE_H;
                gfx_draw_text(ax, ay, "Ctrl+C    Copy URL", theme[T_FG], FONT_DEFAULT); ay += LINE_H;
                gfx_draw_text(ax, ay, "H / L     Back / forward", theme[T_FG], FONT_DEFAULT); ay += LINE_H;
                gfx_draw_text(ax, ay, "/         Search in page", theme[T_FG], FONT_DEFAULT); ay += LINE_H;
                gfx_draw_text(ax, ay, "r         Reload", theme[T_FG], FONT_DEFAULT); ay += LINE_H;
                gfx_draw_text(ax, ay, "Q         Quit browser", theme[T_FG], FONT_DEFAULT); ay += LINE_H;
                gfx_draw_text(ax, ay, "Esc       Normal mode", theme[T_FG], FONT_DEFAULT);
            };

            // URL-bar autocomplete dropdown (Insert mode only).  Matches
            // substrings of persistent history.  Down/Up cycle; Enter opens
            // the highlighted entry (or the literal typed text when none is
            // selected).
            while len(ac_matches) > 0 { pop(ac_matches); };
            let in_insert: bool = match mode {
                BrowserMode::Insert => true,
                _ => false,
            };
            if in_insert and len(url_buf) > 0 {
                let typed_lc: str = str_to_lower(str_from_chars(url_buf));
                for phi in 0..len(persistent_history) {
                    if len(ac_matches) >= 6 { break; };
                    let cand: str = persistent_history[phi];
                    if str_contains(str_to_lower(cand), typed_lc) and
                       not str_eq(str_to_lower(cand), typed_lc) {
                        push(ac_matches, cand);
                    };
                };
            };
            if ac_selected >= len(ac_matches) { ac_selected = -1; };
            if len(ac_matches) > 0 {
                let ady: i32 = CHROME_TOP;
                let ad_h: i32 = len(ac_matches) * 14 + 4;
                gfx_fill_rect(4, ady, canvas_width() - 8, ad_h, theme[T_STATUS_BG]);
                gfx_rect(4, ady, canvas_width() - 8, ad_h, UI_BORDER);
                for ami in 0..len(ac_matches) {
                    let rowy: i32 = ady + 2 + ami * 14;
                    if ami == ac_selected {
                        gfx_fill_rect(4, rowy, canvas_width() - 8, 14, theme[T_SEL]);
                    };
                    gfx_draw_text(10, rowy + 3, ac_matches[ami], theme[T_FG], FONT_DEFAULT);
                };
            };

            // Follow mode hints
            match mode {
                BrowserMode::Follow => {
                    for li in 0..len(follow_links) {
                        let fl: LinkInfo = follow_links[li];
                        if str_len(fl.label) > 0 {
                            let lw: i32 = str_len(fl.label) * FONT_W + 4;
                            gfx_fill_rect(fl.x - 2, fl.y - 1, lw, FONT_H + 2, theme[T_HINT_BG]);
                            gfx_draw_text(fl.x, fl.y, fl.label, theme[T_HINT_FG], FONT_DEFAULT);
                        };
                    };
                },
                _ => {},
            };

            // Search bar (shown in Search mode and when search is active in Normal mode)
            let show_search_bar: bool = match mode {
                BrowserMode::Search => true,
                _ => false,
            };
            if show_search_bar {
                let sy: i32 = canvas_height() - CHROME_BOT - 24;
                gfx_fill_rect(0, sy, canvas_width(), 24, theme[T_STATUS_BG]);
                gfx_rect(0, sy, canvas_width(), 1, UI_BORDER);
                gfx_draw_text(4, sy + 8, "/", theme[T_FG], FONT_DEFAULT);
                let st: str = str_from_chars(search_buf);
                gfx_draw_text(12, sy + 8, st, theme[T_FG], FONT_DEFAULT);
                // Cursor
                gfx_fill_rect(12 + len(search_buf) * FONT_W, sy + 8, 1, FONT_H, theme[T_FG]);
            } else if search_active and str_len(search_query) > 0 {
                // Show match count in status area
                let sy: i32 = canvas_height() - CHROME_BOT - 16;
                let match_info: str = if len(search_match_y) > 0 {
                    let idx_display: i32 = search_match_idx + 1;
                    "/{search_query}  [{idx_display}/{len(search_match_y)}]  (n/N to navigate, Esc to clear)"
                } else {
                    "/{search_query}  [no matches]"
                };
                gfx_fill_rect(0, sy, canvas_width(), 16, theme[T_STATUS_BG]);
                gfx_draw_text(4, sy + 4, match_info, theme[T_SEARCH_HL], FONT_DEFAULT);
            };

            // Help overlay
            if show_help {
                let hx: i32 = 200;
                let hy: i32 = 60;
                gfx_fill_rect(hx, hy, 600, 440, theme[T_STATUS_BG]);
                gfx_rect(hx, hy, 600, 440, UI_BORDER);
                gfx_draw_text(hx + 10, hy + 10, "OscaWeb Keyboard Shortcuts", theme[T_H1], FONT_DEFAULT);
                let mut ky: i32 = hy + 30;
                gfx_draw_text(hx + 10, ky, "j / k        Scroll down / up", theme[T_FG], FONT_DEFAULT); ky += LINE_H;
                gfx_draw_text(hx + 10, ky, "d / u        Half page down / up", theme[T_FG], FONT_DEFAULT); ky += LINE_H;
                gfx_draw_text(hx + 10, ky, "gg / G       Top / bottom", theme[T_FG], FONT_DEFAULT); ky += LINE_H;
                gfx_draw_text(hx + 10, ky, "gm           Jump to <main>/<article>", theme[T_FG], FONT_DEFAULT); ky += LINE_H;
                gfx_draw_text(hx + 10, ky, "f / F        Follow link (all / chrome only)", theme[T_FG], FONT_DEFAULT); ky += LINE_H;
                gfx_draw_text(hx + 10, ky, "t            Toggle outline (ToC); 1-9 jumps", theme[T_FG], FONT_DEFAULT); ky += LINE_H;
                gfx_draw_text(hx + 10, ky, "o / O        Open / edit URL  (type to search)", theme[T_FG], FONT_DEFAULT); ky += LINE_H;
                gfx_draw_text(hx + 10, ky, "r            Reload page", theme[T_FG], FONT_DEFAULT); ky += LINE_H;
                gfx_draw_text(hx + 10, ky, "gr           Toggle reader mode", theme[T_FG], FONT_DEFAULT); ky += LINE_H;
                gfx_draw_text(hx + 10, ky, "gR           Toggle show-full (disables chrome trim)", theme[T_FG], FONT_DEFAULT); ky += LINE_H;
                gfx_draw_text(hx + 10, ky, "b / B        Bookmark / bookmarks list", theme[T_FG], FONT_DEFAULT); ky += LINE_H;
                gfx_draw_text(hx + 10, ky, "+ / - / 0    Zoom in / out / reset", theme[T_FG], FONT_DEFAULT); ky += LINE_H;
                gfx_draw_text(hx + 10, ky, "p            Paste URL and go", theme[T_FG], FONT_DEFAULT); ky += LINE_H;
                gfx_draw_text(hx + 10, ky, "yy           Copy URL to clipboard", theme[T_FG], FONT_DEFAULT); ky += LINE_H;
                gfx_draw_text(hx + 10, ky, "Ctrl+V       Paste in URL bar", theme[T_FG], FONT_DEFAULT); ky += LINE_H;
                gfx_draw_text(hx + 10, ky, "Ctrl+C       Copy URL", theme[T_FG], FONT_DEFAULT); ky += LINE_H;
                gfx_draw_text(hx + 10, ky, "H / L        Back / forward", theme[T_FG], FONT_DEFAULT); ky += LINE_H;
                gfx_draw_text(hx + 10, ky, "/            Search in page", theme[T_FG], FONT_DEFAULT); ky += LINE_H;
                gfx_draw_text(hx + 10, ky, "Esc          Normal mode", theme[T_FG], FONT_DEFAULT); ky += LINE_H;
                gfx_draw_text(hx + 10, ky, "Q            Quit browser", theme[T_FG], FONT_DEFAULT); ky += LINE_H;
                gfx_draw_text(hx + 10, ky, "?            Toggle this help", theme[T_FG], FONT_DEFAULT); ky += LINE_H;
                ky += LINE_H;
                gfx_draw_text(hx + 10, ky, "Mouse click on links also works!", theme[T_LINK], FONT_DEFAULT);
            };

            // Outline (table of contents) overlay
            if show_outline {
                let ox: i32 = 200;
                let oy0: i32 = 100;
                let on_cap: i32 = if len(outline_idx) < 9 { len(outline_idx) } else { 9 };
                let oh: i32 = 40 + max_i32(on_cap, 1) * LINE_H;
                gfx_fill_rect(ox, oy0, 600, oh, theme[T_STATUS_BG]);
                gfx_rect(ox, oy0, 600, oh, UI_BORDER);
                gfx_draw_text(ox + 10, oy0 + 10,
                    "Outline (press 1-9 to jump, t to close)",
                    theme[T_H1], FONT_DEFAULT);
                if len(outline_idx) == 0 {
                    gfx_draw_text(ox + 10, oy0 + 30,
                        "No headings on this page.", theme[T_HR], FONT_DEFAULT);
                } else {
                    let mut oky: i32 = oy0 + 30;
                    for oki in 0..on_cap {
                        let orn: i32 = oki + 1;
                        let olv: i32 = outline_level[oki];
                        let indent_str: str = if olv == 1 { "" }
                                              else if olv == 2 { "  " }
                                              else { "    " };
                        let color_h: i32 = if olv == 1 { theme[T_H1] }
                                           else if olv == 2 { theme[T_H2] }
                                           else { theme[T_H3] };
                        let o_row: str = "{orn}. {indent_str}{outline_text[oki]}";
                        gfx_draw_text(ox + 10, oky, o_row, color_h, FONT_DEFAULT);
                        oky += LINE_H;
                    };
                };
            };

            // Bookmarks overlay
            if show_bookmarks {
                let bx: i32 = 200;
                let by: i32 = 100;
                let bh: i32 = 40 + max_i32(len(bookmarks), 1) * LINE_H;
                gfx_fill_rect(bx, by, 600, bh, theme[T_STATUS_BG]);
                gfx_rect(bx, by, 600, bh, UI_BORDER);
                gfx_draw_text(bx + 10, by + 10, "Bookmarks (press 1-9 to open, B to close)",
                              theme[T_H1], FONT_DEFAULT);
                if len(bookmarks) == 0 {
                    gfx_draw_text(bx + 10, by + 30,
                                  "No bookmarks yet. Press 'b' on a page to save one.",
                                  theme[T_HR], FONT_DEFAULT);
                } else {
                    let mut bky: i32 = by + 30;
                    let cap: i32 = if len(bookmarks) < 9 { len(bookmarks) } else { 9 };
                    for bki in 0..cap {
                        let row_num: i32 = bki + 1;
                        let bm_row: str = "{row_num}. {bookmarks[bki]}";
                        gfx_draw_text(bx + 10, bky, bm_row, theme[T_LINK], FONT_DEFAULT);
                        bky += LINE_H;
                    };
                };
            };

            // Status bar
            let sty: i32 = canvas_height() - CHROME_BOT;
            gfx_fill_rect(0, sty, canvas_width(), CHROME_BOT, theme[T_STATUS_BG]);
            let mode_str: str = match mode {
                BrowserMode::Normal => "NORMAL",
                BrowserMode::Insert => "INSERT",
                BrowserMode::Follow => "FOLLOW",
                BrowserMode::Search => "SEARCH",
            };
            let scroll_pct: str = if max_scroll > 0 {
                let pct: i32 = scroll_y * 100 / max_scroll;
                "{pct}%"
            } else {
                "Top"
            };
            let reader_flag: str = if reader_on { " | READER" } else { "" };
            let full_flag: str = if show_full { " | FULL" } else { "" };
            let zoom_flag: str = if body_scale > 1 { " | zoom {body_scale}x" } else { "" };
            gfx_draw_text(4, sty + 6,
                " {mode_str} | {status_msg} | {scroll_pct} | Links: {len(page_links)}{reader_flag}{full_flag}{zoom_flag}",
                theme[T_FG], FONT_DEFAULT);

            // Floating "F for Nav" button — visible whenever the page has
            // chrome (nav/header/footer/aside) that is currently trimmed.
            // Gives mouse users a visible affordance equivalent to the F
            // key toggle.
            let mut f_btn_clicked: bool = false;
            let is_insert: bool = match mode {
                BrowserMode::Insert => true,
                _ => false,
            };
            if page_loaded and has_chrome and not show_full and not is_insert {
                let fb_label: str = "'F' for Nav";
                let fb_w: i32 = gfx_text_width(fb_label, FONT_DEFAULT) + 16;
                let fb_h: i32 = 22;
                let fb_x: i32 = 8;
                let fb_y: i32 = CHROME_TOP + 8;
                // Simulated translucency: draw a darker shadow first so the
                // button blends with page content beneath.
                gfx_fill_rect(fb_x, fb_y, fb_w, fb_h, theme[T_STATUS_BG]);
                f_btn_clicked = ui_button(fb_x, fb_y, fb_w, fb_h, fb_label, prev_btn, ui_colors);
            };

            prev_btn = canvas_mouse_btn();
                render_dirty = false;
                vlog_msg("render end", "");

                // Handle floating F-button click — same semantics as F key.
                if f_btn_clicked and page_loaded {
                    if not show_full {
                        show_full = true;
                        scroll_y = 0;
                        pending_follow_chrome = true;
                        if str_len(current_url) > 0 {
                            nav_url = current_url;
                            needs_navigate = true;
                        };
                        render_dirty = true;
                    };
                };

                // If the user pressed F while chrome was trimmed, we
                // reloaded with show_full=true; now that page_links has
                // been populated by this render, activate follow-chrome
                // mode automatically.  Wait until the reload has actually
                // rendered chrome links — the very first render after F is
                // still the trimmed view, and activating then would leave
                // follow_links empty and any keypress would immediately
                // exit Follow mode.
                if pending_follow_chrome and page_loaded and show_full and
                   not needs_navigate {
                    let mut pfc_chrome: [LinkInfo] = [];
                    for pfi in 0..len(page_links) {
                        if page_links[pfi].chrome {
                            push(pfc_chrome, page_links[pfi]);
                        };
                    };
                    if len(pfc_chrome) > 0 {
                        pending_follow_chrome = false;
                        mode = BrowserMode::Follow;
                        while len(follow_input) > 0 { pop(follow_input); };
                        while len(follow_links) > 0 { pop(follow_links); };
                        let pfc_labels: [str] = make_hint_labels(len(pfc_chrome));
                        for pfi2 in 0..len(pfc_chrome) {
                            let pfc_lk: LinkInfo = pfc_chrome[pfi2];
                            let pfc_labeled: LinkInfo = LinkInfo {
                                x: pfc_lk.x, y: pfc_lk.y, w: pfc_lk.w, h: pfc_lk.h,
                                href: pfc_lk.href,
                                label: if pfi2 < len(pfc_labels) { pfc_labels[pfi2] } else { "" },
                                chrome: pfc_lk.chrome,
                            };
                            push(follow_links, pfc_labeled);
                        };
                        render_dirty = true;
                    };
                };
            };
            prev_mx = canvas_mouse_x();
            prev_my = canvas_mouse_y();
            canvas_flush();
            sleep_ms(16);
    };

    js_engine_destroy(js_ctx);
    canvas_close()
}
