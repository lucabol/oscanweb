// Tests for html.osc — entity decoding, parsing, and DOM queries
// Uses the flat DOM API (first_child / next_sibling indices).

use "../html.osc"

fn! assert_eq_str(actual: str, expected: str, test_name: str) {
    if str_eq(actual, expected) {
        println("PASS: {test_name}");
    } else {
        println("FAIL: {test_name} - expected '{expected}', got '{actual}'");
    };
}

fn! assert_eq_i32(actual: i32, expected: i32, test_name: str) {
    if actual == expected {
        println("PASS: {test_name}");
    } else {
        println("FAIL: {test_name} - expected {expected}, got {actual}");
    };
}

fn! assert_true(cond: bool, test_name: str) {
    if cond {
        println("PASS: {test_name}");
    } else {
        println("FAIL: {test_name}");
    };
}

// Helper: count children of a node by walking first_child -> next_sibling
fn! count_children(nodes: [HtmlNode], parent_idx: i32) -> i32 {
    let mut count: i32 = 0;
    let mut child: i32 = nodes[parent_idx].first_child;
    while child != -1 {
        count += 1;
        child = nodes[child].next_sibling;
    };
    count
}

// Helper: get nth child index
fn! nth_child(nodes: [HtmlNode], parent_idx: i32, n: i32) -> i32 {
    let mut child: i32 = nodes[parent_idx].first_child;
    let mut i: i32 = 0;
    while child != -1 and i < n {
        child = nodes[child].next_sibling;
        i += 1;
    };
    child
}

fn! main() {
    println("=== HTML Entity Decode Tests ===");

    // 1-4. Named entities
    assert_eq_str(html_entity_decode("&amp;"), "&", "entity decode &amp;");
    assert_eq_str(html_entity_decode("&lt;"), "<", "entity decode &lt;");
    assert_eq_str(html_entity_decode("&gt;"), ">", "entity decode &gt;");

    let dquote: str = str_from_chars([34]);
    assert_eq_str(html_entity_decode("&quot;"), dquote, "entity decode &quot;");

    // 5. Entity in context
    assert_eq_str(html_entity_decode("hello &amp; world"), "hello & world", "entity in context");

    // 6-7. Numeric entities
    assert_eq_str(html_entity_decode("&#65;"), "A", "entity decimal &#65;");
    assert_eq_str(html_entity_decode("&#x41;"), "A", "entity hex &#x41;");

    // 8. No entities
    assert_eq_str(html_entity_decode("no entities here"), "no entities here", "no entities passthrough");

    println("=== HTML Parse Tests ===");

    // 9. Simple paragraph
    let mut nodes1: [HtmlNode] = [];
    let root1: i32 = html_parse(nodes1, "<p>hello</p>");
    assert_eq_str(nodes1[root1].tag, "root", "parse p: root tag");
    assert_eq_i32(count_children(nodes1, root1), 1, "parse p: root has 1 child");
    let p_idx: i32 = nodes1[root1].first_child;
    assert_eq_str(nodes1[p_idx].tag, "p", "parse p: child is p");
    let p_text: i32 = nodes1[p_idx].first_child;
    assert_true(nodes1[p_text].is_text, "parse p: p child is text");
    assert_eq_str(nodes1[p_text].text, "hello", "parse p: text content");

    // 10. Anchor with href attribute
    let mut nodes2: [HtmlNode] = [];
    let root2: i32 = html_parse(nodes2, "<a href=\"url\">click</a>");
    let a_idx: i32 = nodes2[root2].first_child;
    assert_eq_str(nodes2[a_idx].tag, "a", "parse a: tag is a");
    assert_eq_str(html_get_attr(nodes2[a_idx], "href"), "url", "parse a: href attr");
    let a_text: i32 = nodes2[a_idx].first_child;
    assert_true(nodes2[a_text].is_text, "parse a: child is text");
    assert_eq_str(nodes2[a_text].text, "click", "parse a: text content");

    // 11. Void element <br>
    let mut nodes3: [HtmlNode] = [];
    let root3: i32 = html_parse(nodes3, "<br>");
    assert_eq_i32(count_children(nodes3, root3), 1, "parse br: root has 1 child");
    let br_idx: i32 = nodes3[root3].first_child;
    assert_eq_str(nodes3[br_idx].tag, "br", "parse br: child is br");

    // 12. Nested structure
    let mut nodes4: [HtmlNode] = [];
    let root4: i32 = html_parse(nodes4, "<div><p>one</p><p>two</p></div>");
    assert_eq_i32(count_children(nodes4, root4), 1, "parse nested: root has 1 child");
    let div_idx: i32 = nodes4[root4].first_child;
    assert_eq_str(nodes4[div_idx].tag, "div", "parse nested: child is div");
    assert_eq_i32(count_children(nodes4, div_idx), 2, "parse nested: div has 2 children");
    let p1_idx: i32 = nth_child(nodes4, div_idx, 0);
    let p2_idx: i32 = nth_child(nodes4, div_idx, 1);
    assert_eq_str(nodes4[p1_idx].tag, "p", "parse nested: first p");
    assert_eq_str(nodes4[p2_idx].tag, "p", "parse nested: second p");
    assert_eq_str(nodes4[nodes4[p1_idx].first_child].text, "one", "parse nested: first p text");
    assert_eq_str(nodes4[nodes4[p2_idx].first_child].text, "two", "parse nested: second p text");

    // 13. Comment skipped, text preserved
    let mut nodes5: [HtmlNode] = [];
    let root5: i32 = html_parse(nodes5, "<!-- comment -->text");
    assert_eq_i32(count_children(nodes5, root5), 1, "parse comment: root has 1 child");
    let ct_idx: i32 = nodes5[root5].first_child;
    assert_true(nodes5[ct_idx].is_text, "parse comment: child is text");
    assert_eq_str(nodes5[ct_idx].text, "text", "parse comment: text preserved");

    // 14. html_get_text_content on nested elements
    let mut nodes6: [HtmlNode] = [];
    let root6: i32 = html_parse(nodes6, "<div><span>hello</span> <b>world</b></div>");
    let div6: i32 = nodes6[root6].first_child;
    let tc: str = html_get_text_content(nodes6, div6);
    assert_true(str_contains(tc, "hello"), "get_text_content has hello");
    assert_true(str_contains(tc, "world"), "get_text_content has world");

    // 15. html_get_attr for missing attribute
    let mut nodes7: [HtmlNode] = [];
    let root7: i32 = html_parse(nodes7, "<p>text</p>");
    let p7: i32 = nodes7[root7].first_child;
    assert_eq_str(html_get_attr(nodes7[p7], "class"), "", "get_attr missing returns empty");

    println("=== HTML Tests Complete ===");
}
