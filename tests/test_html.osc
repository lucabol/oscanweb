// Tests for html.osc — entity decoding, parsing, and DOM queries
// Uses the flat DOM API (first_child / next_sibling indices).

use "../html.osc"

fn! assert_eq_str(actual: str, expected: str, test_name: str) {
    if str_eq(actual, expected) {
        println("PASS: {test_name}");
    } else {
        println("FAIL: {test_name} - expected '{expected}', got '{actual}'");
    };
}

fn! assert_eq_i32(actual: i32, expected: i32, test_name: str) {
    if actual == expected {
        println("PASS: {test_name}");
    } else {
        println("FAIL: {test_name} - expected {expected}, got {actual}");
    };
}

fn! assert_true(cond: bool, test_name: str) {
    if cond {
        println("PASS: {test_name}");
    } else {
        println("FAIL: {test_name}");
    };
}

// Helper: count children of a node by walking first_child -> next_sibling
fn! count_children(nodes: [HtmlNode], parent_idx: i32) -> i32 {
    let mut count: i32 = 0;
    let mut child: i32 = nodes[parent_idx].first_child;
    while child != -1 {
        count += 1;
        child = nodes[child].next_sibling;
    };
    count
}

// Helper: get nth child index
fn! nth_child(nodes: [HtmlNode], parent_idx: i32, n: i32) -> i32 {
    let mut child: i32 = nodes[parent_idx].first_child;
    let mut i: i32 = 0;
    while child != -1 and i < n {
        child = nodes[child].next_sibling;
        i += 1;
    };
    child
}

fn! main() {
    println("=== HTML Entity Decode Tests ===");

    // 1-4. Named entities
    assert_eq_str(html_entity_decode("&amp;"), "&", "entity decode &amp;");
    assert_eq_str(html_entity_decode("&lt;"), "<", "entity decode &lt;");
    assert_eq_str(html_entity_decode("&gt;"), ">", "entity decode &gt;");

    let dquote: str = str_from_chars([34]);
    assert_eq_str(html_entity_decode("&quot;"), dquote, "entity decode &quot;");

    // 5. Entity in context
    assert_eq_str(html_entity_decode("hello &amp; world"), "hello & world", "entity in context");

    // 6-7. Numeric entities
    assert_eq_str(html_entity_decode("&#65;"), "A", "entity decimal &#65;");
    assert_eq_str(html_entity_decode("&#x41;"), "A", "entity hex &#x41;");

    // 8. No entities
    assert_eq_str(html_entity_decode("no entities here"), "no entities here", "no entities passthrough");

    println("=== HTML Parse Tests ===");

    // 9. Simple paragraph
    let mut nodes1: [HtmlNode] = [];
    let root1: i32 = html_parse(nodes1, "<p>hello</p>");
    assert_eq_str(nodes1[root1].tag, "root", "parse p: root tag");
    assert_eq_i32(count_children(nodes1, root1), 1, "parse p: root has 1 child");
    let p_idx: i32 = nodes1[root1].first_child;
    assert_eq_str(nodes1[p_idx].tag, "p", "parse p: child is p");
    let p_text: i32 = nodes1[p_idx].first_child;
    assert_true(nodes1[p_text].is_text, "parse p: p child is text");
    assert_eq_str(nodes1[p_text].text, "hello", "parse p: text content");

    // 10. Anchor with href attribute
    let mut nodes2: [HtmlNode] = [];
    let root2: i32 = html_parse(nodes2, "<a href=\"url\">click</a>");
    let a_idx: i32 = nodes2[root2].first_child;
    assert_eq_str(nodes2[a_idx].tag, "a", "parse a: tag is a");
    assert_eq_str(html_get_attr(nodes2[a_idx], "href"), "url", "parse a: href attr");
    let a_text: i32 = nodes2[a_idx].first_child;
    assert_true(nodes2[a_text].is_text, "parse a: child is text");
    assert_eq_str(nodes2[a_text].text, "click", "parse a: text content");

    // 11. Void element <br>
    let mut nodes3: [HtmlNode] = [];
    let root3: i32 = html_parse(nodes3, "<br>");
    assert_eq_i32(count_children(nodes3, root3), 1, "parse br: root has 1 child");
    let br_idx: i32 = nodes3[root3].first_child;
    assert_eq_str(nodes3[br_idx].tag, "br", "parse br: child is br");

    // 12. Nested structure
    let mut nodes4: [HtmlNode] = [];
    let root4: i32 = html_parse(nodes4, "<div><p>one</p><p>two</p></div>");
    assert_eq_i32(count_children(nodes4, root4), 1, "parse nested: root has 1 child");
    let div_idx: i32 = nodes4[root4].first_child;
    assert_eq_str(nodes4[div_idx].tag, "div", "parse nested: child is div");
    assert_eq_i32(count_children(nodes4, div_idx), 2, "parse nested: div has 2 children");
    let p1_idx: i32 = nth_child(nodes4, div_idx, 0);
    let p2_idx: i32 = nth_child(nodes4, div_idx, 1);
    assert_eq_str(nodes4[p1_idx].tag, "p", "parse nested: first p");
    assert_eq_str(nodes4[p2_idx].tag, "p", "parse nested: second p");
    assert_eq_str(nodes4[nodes4[p1_idx].first_child].text, "one", "parse nested: first p text");
    assert_eq_str(nodes4[nodes4[p2_idx].first_child].text, "two", "parse nested: second p text");

    // 13. Comment skipped, text preserved
    let mut nodes5: [HtmlNode] = [];
    let root5: i32 = html_parse(nodes5, "<!-- comment -->text");
    assert_eq_i32(count_children(nodes5, root5), 1, "parse comment: root has 1 child");
    let ct_idx: i32 = nodes5[root5].first_child;
    assert_true(nodes5[ct_idx].is_text, "parse comment: child is text");
    assert_eq_str(nodes5[ct_idx].text, "text", "parse comment: text preserved");

    // 14. html_get_text_content on nested elements
    let mut nodes6: [HtmlNode] = [];
    let root6: i32 = html_parse(nodes6, "<div><span>hello</span> <b>world</b></div>");
    let div6: i32 = nodes6[root6].first_child;
    let tc: str = html_get_text_content(nodes6, div6);
    assert_true(str_contains(tc, "hello"), "get_text_content has hello");
    assert_true(str_contains(tc, "world"), "get_text_content has world");

    // 15. html_get_attr for missing attribute
    let mut nodes7: [HtmlNode] = [];
    let root7: i32 = html_parse(nodes7, "<p>text</p>");
    let p7: i32 = nodes7[root7].first_child;
    assert_eq_str(html_get_attr(nodes7[p7], "class"), "", "get_attr missing returns empty");

    // ── New entity decode tests ──
    println("=== New Entity Decode Tests ===");

    // mdash → — (U+2014, UTF-8: 0xE2 0x80 0x94 = 226 128 148)
    let mdash: str = html_entity_decode("hello&mdash;world");
    let mdash_chars: [i32] = str_to_chars(mdash);
    assert_eq_i32(len(mdash_chars), 13, "entity decode mdash length");
    assert_eq_i32(mdash_chars[5], 226, "entity decode mdash byte 0");
    assert_eq_i32(mdash_chars[6], 128, "entity decode mdash byte 1");
    assert_eq_i32(mdash_chars[7], 148, "entity decode mdash byte 2");

    // ndash → – (U+2013, UTF-8: 0xE2 0x80 0x93 = 226 128 147)
    let ndash: str = html_entity_decode("1&ndash;10");
    let ndash_chars: [i32] = str_to_chars(ndash);
    assert_eq_i32(ndash_chars[1], 226, "entity decode ndash byte 0");
    assert_eq_i32(ndash_chars[2], 128, "entity decode ndash byte 1");
    assert_eq_i32(ndash_chars[3], 147, "entity decode ndash byte 2");

    // copy → © (U+00A9, UTF-8: 0xC2 0xA9 = 194 169)
    let copy_str: str = html_entity_decode("&copy;");
    let copy_chars: [i32] = str_to_chars(copy_str);
    assert_eq_i32(copy_chars[0], 194, "entity decode copy byte 0");
    assert_eq_i32(copy_chars[1], 169, "entity decode copy byte 1");

    // bull → • (U+2022, UTF-8: 0xE2 0x80 0xA2 = 226 128 162)
    let bull_str: str = html_entity_decode("&bull;");
    let bull_chars: [i32] = str_to_chars(bull_str);
    assert_eq_i32(bull_chars[0], 226, "entity decode bull byte 0");
    assert_eq_i32(bull_chars[1], 128, "entity decode bull byte 1");
    assert_eq_i32(bull_chars[2], 162, "entity decode bull byte 2");

    // euro → € (U+20AC, UTF-8: 0xE2 0x82 0xAC = 226 130 172)
    let euro_str: str = html_entity_decode("&euro;");
    let euro_chars: [i32] = str_to_chars(euro_str);
    assert_eq_i32(euro_chars[0], 226, "entity decode euro byte 0");
    assert_eq_i32(euro_chars[1], 130, "entity decode euro byte 1");
    assert_eq_i32(euro_chars[2], 172, "entity decode euro byte 2");

    // hellip → … (U+2026, UTF-8: 0xE2 0x80 0xA6 = 226 128 166)
    let hellip_str: str = html_entity_decode("&hellip;");
    let hellip_chars: [i32] = str_to_chars(hellip_str);
    assert_eq_i32(hellip_chars[0], 226, "entity decode hellip byte 0");
    assert_eq_i32(hellip_chars[1], 128, "entity decode hellip byte 1");
    assert_eq_i32(hellip_chars[2], 166, "entity decode hellip byte 2");

    // rsquo → ' (U+2019, UTF-8: 0xE2 0x80 0x99 = 226 128 153)
    let rsquo_str: str = html_entity_decode("it&rsquo;s");
    let rsquo_chars: [i32] = str_to_chars(rsquo_str);
    assert_eq_i32(len(rsquo_chars), 6, "entity decode rsquo length");
    assert_eq_i32(rsquo_chars[2], 226, "entity decode rsquo byte 0");
    assert_eq_i32(rsquo_chars[3], 128, "entity decode rsquo byte 1");
    assert_eq_i32(rsquo_chars[4], 153, "entity decode rsquo byte 2");

    // Numeric decimal entity: &#8217; should produce the same UTF-8 bytes.
    let num_rsquo: str = html_entity_decode("&#8217;");
    let num_rsquo_chars: [i32] = str_to_chars(num_rsquo);
    assert_eq_i32(len(num_rsquo_chars), 3, "numeric entity rsquo length");
    assert_eq_i32(num_rsquo_chars[0], 226, "numeric entity rsquo byte 0");
    assert_eq_i32(num_rsquo_chars[1], 128, "numeric entity rsquo byte 1");
    assert_eq_i32(num_rsquo_chars[2], 153, "numeric entity rsquo byte 2");

    // Numeric hex entity: &#x2019; should produce the same UTF-8 bytes.
    let hex_rsquo: str = html_entity_decode("&#x2019;");
    let hex_rsquo_chars: [i32] = str_to_chars(hex_rsquo);
    assert_eq_i32(len(hex_rsquo_chars), 3, "hex entity rsquo length");
    assert_eq_i32(hex_rsquo_chars[0], 226, "hex entity rsquo byte 0");
    assert_eq_i32(hex_rsquo_chars[1], 128, "hex entity rsquo byte 1");
    assert_eq_i32(hex_rsquo_chars[2], 153, "hex entity rsquo byte 2");

    // ── ASCII folding for bitmap font fallback ──
    // Plain ASCII passes through unchanged.
    assert_eq_str(ascii_fold_utf8("hello"), "hello", "ascii fold: plain passthrough");

    // Curly apostrophe U+2019 (UTF-8 E2 80 99) folds to '.
    assert_eq_str(ascii_fold_utf8(html_entity_decode("it&rsquo;s")), "it's",
                  "ascii fold: rsquo to apostrophe");

    // Em-dash U+2014 folds to --, en-dash U+2013 to -.
    assert_eq_str(ascii_fold_utf8(html_entity_decode("a&mdash;b")), "a--b",
                  "ascii fold: mdash to --");
    assert_eq_str(ascii_fold_utf8(html_entity_decode("1&ndash;10")), "1-10",
                  "ascii fold: ndash to -");

    // Ellipsis, bullet, euro, copy.
    assert_eq_str(ascii_fold_utf8(html_entity_decode("a&hellip;b")), "a...b",
                  "ascii fold: hellip to ...");
    assert_eq_str(ascii_fold_utf8(html_entity_decode("&bull; item")), "* item",
                  "ascii fold: bull to *");
    assert_eq_str(ascii_fold_utf8(html_entity_decode("&euro;9")), "EUR9",
                  "ascii fold: euro to EUR");
    assert_eq_str(ascii_fold_utf8(html_entity_decode("&copy;2026")), "(c)2026",
                  "ascii fold: copy to (c)");

    // Curly double quotes.
    assert_eq_str(ascii_fold_utf8(html_entity_decode("&ldquo;hi&rdquo;")), "\"hi\"",
                  "ascii fold: ldquo/rdquo to \"");

    // ── New DOM structure tests ──
    println("=== New DOM Structure Tests ===");

    // 16. Definition list
    let mut nodes_dl: [HtmlNode] = [];
    let root_dl: i32 = html_parse(nodes_dl, "<dl><dt>Term</dt><dd>Definition</dd></dl>");
    let dl_idx: i32 = nodes_dl[root_dl].first_child;
    assert_eq_str(nodes_dl[dl_idx].tag, "dl", "parse dl: tag is dl");
    let dt_idx: i32 = nodes_dl[dl_idx].first_child;
    assert_eq_str(nodes_dl[dt_idx].tag, "dt", "parse dl: first child is dt");
    let dd_idx: i32 = nodes_dl[dt_idx].next_sibling;
    assert_eq_str(nodes_dl[dd_idx].tag, "dd", "parse dl: second child is dd");
    assert_eq_str(html_get_text_content(nodes_dl, dt_idx), "Term", "parse dl: dt text");
    assert_eq_str(html_get_text_content(nodes_dl, dd_idx), "Definition", "parse dl: dd text");

    // 17. Table structure
    let mut nodes_tbl: [HtmlNode] = [];
    let root_tbl: i32 = html_parse(nodes_tbl, "<table><tr><th>Name</th><th>Age</th></tr><tr><td>Alice</td><td>30</td></tr></table>");
    let tbl_idx: i32 = nodes_tbl[root_tbl].first_child;
    assert_eq_str(nodes_tbl[tbl_idx].tag, "table", "parse table: tag is table");
    let tr1_idx: i32 = nodes_tbl[tbl_idx].first_child;
    assert_eq_str(nodes_tbl[tr1_idx].tag, "tr", "parse table: first child is tr");
    let th1_idx: i32 = nodes_tbl[tr1_idx].first_child;
    assert_eq_str(nodes_tbl[th1_idx].tag, "th", "parse table: first cell is th");
    assert_eq_str(html_get_text_content(nodes_tbl, th1_idx), "Name", "parse table: th text");
    let tr2_idx: i32 = nodes_tbl[tr1_idx].next_sibling;
    assert_eq_str(nodes_tbl[tr2_idx].tag, "tr", "parse table: second row is tr");
    let td1_idx: i32 = nodes_tbl[tr2_idx].first_child;
    assert_eq_str(nodes_tbl[td1_idx].tag, "td", "parse table: data cell is td");
    assert_eq_str(html_get_text_content(nodes_tbl, td1_idx), "Alice", "parse table: td text");

    // 18. Blockquote
    let mut nodes_bq: [HtmlNode] = [];
    let root_bq: i32 = html_parse(nodes_bq, "<blockquote>Quoted text</blockquote>");
    let bq_idx: i32 = nodes_bq[root_bq].first_child;
    assert_eq_str(nodes_bq[bq_idx].tag, "blockquote", "parse blockquote: tag");
    assert_eq_str(html_get_text_content(nodes_bq, bq_idx), "Quoted text", "parse blockquote: text");

    // 19. Figure/figcaption
    let mut nodes_fig: [HtmlNode] = [];
    let root_fig: i32 = html_parse(nodes_fig, "<figure><figcaption>Caption</figcaption></figure>");
    let fig_idx: i32 = nodes_fig[root_fig].first_child;
    assert_eq_str(nodes_fig[fig_idx].tag, "figure", "parse figure: tag");
    let fc_idx: i32 = nodes_fig[fig_idx].first_child;
    assert_eq_str(nodes_fig[fc_idx].tag, "figcaption", "parse figure: figcaption tag");
    assert_eq_str(html_get_text_content(nodes_fig, fc_idx), "Caption", "parse figure: figcaption text");

    // 20. Ordered list
    let mut nodes_ol: [HtmlNode] = [];
    let root_ol: i32 = html_parse(nodes_ol, "<ol><li>First</li><li>Second</li></ol>");
    let ol_idx: i32 = nodes_ol[root_ol].first_child;
    assert_eq_str(nodes_ol[ol_idx].tag, "ol", "parse ol: tag");
    assert_eq_i32(count_children(nodes_ol, ol_idx), 2, "parse ol: 2 li children");

    // 21. Mark tag
    let mut nodes_mk: [HtmlNode] = [];
    let root_mk: i32 = html_parse(nodes_mk, "<p>Some <mark>highlighted</mark> text</p>");
    let p_mk: i32 = nodes_mk[root_mk].first_child;
    assert_eq_str(nodes_mk[p_mk].tag, "p", "parse mark: p tag");
    let mark_idx: i32 = nth_child(nodes_mk, p_mk, 1);
    assert_eq_str(nodes_mk[mark_idx].tag, "mark", "parse mark: mark tag");
    assert_eq_str(html_get_text_content(nodes_mk, mark_idx), "highlighted", "parse mark: text");

    // 22. Auto-close: unclosed dt/dd (CERN-style HTML)
    let mut nodes_ac: [HtmlNode] = [];
    let root_ac: i32 = html_parse(nodes_ac, "<dl><dt>A<dd>B<dt>C<dd>D</dl>");
    let dl_ac: i32 = nodes_ac[root_ac].first_child;
    assert_eq_str(nodes_ac[dl_ac].tag, "dl", "autoclose dl: tag is dl");
    // dt/dd should be siblings under dl, not nested
    assert_eq_i32(count_children(nodes_ac, dl_ac), 4, "autoclose dl: 4 children (dt dd dt dd)");
    let ac_dt1: i32 = nth_child(nodes_ac, dl_ac, 0);
    let ac_dd1: i32 = nth_child(nodes_ac, dl_ac, 1);
    let ac_dt2: i32 = nth_child(nodes_ac, dl_ac, 2);
    let ac_dd2: i32 = nth_child(nodes_ac, dl_ac, 3);
    assert_eq_str(nodes_ac[ac_dt1].tag, "dt", "autoclose: child 0 is dt");
    assert_eq_str(nodes_ac[ac_dd1].tag, "dd", "autoclose: child 1 is dd");
    assert_eq_str(nodes_ac[ac_dt2].tag, "dt", "autoclose: child 2 is dt");
    assert_eq_str(nodes_ac[ac_dd2].tag, "dd", "autoclose: child 3 is dd");

    // 23. Auto-close: unclosed li
    let mut nodes_ali: [HtmlNode] = [];
    let root_ali: i32 = html_parse(nodes_ali, "<ul><li>one<li>two<li>three</ul>");
    let ul_ali: i32 = nodes_ali[root_ali].first_child;
    assert_eq_i32(count_children(nodes_ali, ul_ali), 3, "autoclose li: 3 children");

    // 24. Attribute values are HTML-entity decoded (e.g. &amp; in stylesheet URLs).
    let mut nodes_ae: [HtmlNode] = [];
    let root_ae: i32 = html_parse(nodes_ae,
        "<link rel=\"stylesheet\" href=\"/w/load.php?lang=en&amp;modules=site.styles\">");
    let link_ae: i32 = nodes_ae[root_ae].first_child;
    assert_eq_str(nodes_ae[link_ae].tag, "link", "attr entity: link tag");
    assert_eq_str(html_get_attr(nodes_ae[link_ae], "href"),
        "/w/load.php?lang=en&modules=site.styles",
        "attr entity: &amp; decoded in href");

    // 25. Unquoted attribute values containing slashes (HTML5 allows '/' in
    // unquoted values; danluu.com-style markup like <a href=https://x.com/p/>
    // must NOT be parsed as self-closing or have href truncated at first '/').
    let mut nodes_uq: [HtmlNode] = [];
    let root_uq: i32 = html_parse(nodes_uq, "<a href=https://danluu.com/ballmer/>Ballmer</a>");
    let a_uq: i32 = nodes_uq[root_uq].first_child;
    assert_eq_str(nodes_uq[a_uq].tag, "a", "unquoted slash href: tag");
    assert_eq_str(html_get_attr(nodes_uq[a_uq], "href"),
        "https://danluu.com/ballmer/",
        "unquoted slash href: full URL preserved");
    let txt_uq: i32 = nodes_uq[a_uq].first_child;
    assert_true(txt_uq != -1, "unquoted slash href: <a> has child text");
    assert_eq_str(nodes_uq[txt_uq].text, "Ballmer", "unquoted slash href: child text");

    println("=== HTML Tests Complete ===");
}
