// Tests for css.osc — tokenizer, parser, matcher, and cascade.
use "../css.osc"
use "../html.osc"

fn! assert_eq_i32(actual: i32, expected: i32, test_name: str) {
    if actual == expected {
        println("PASS: {test_name}");
    } else {
        println("FAIL: {test_name} - expected {expected}, got {actual}");
    };
}

fn! assert_true(cond: bool, test_name: str) {
    if cond {
        println("PASS: {test_name}");
    } else {
        println("FAIL: {test_name}");
    };
}

fn! assert_eq_str(actual: str, expected: str, test_name: str) {
    if str_eq(actual, expected) {
        println("PASS: {test_name}");
    } else {
        println("FAIL: {test_name} - expected '{expected}', got '{actual}'");
    };
}

fn! main() {
    println("=== CSS Color Tests ===");
    assert_eq_i32(css_parse_color("#000000"), 0, "hex black");
    assert_eq_i32(css_parse_color("#ffffff"), 255*65536+255*256+255, "hex white");
    assert_eq_i32(css_parse_color("#ff0000"), 255*65536, "hex red");
    assert_eq_i32(css_parse_color("#F00"),    255*65536, "short hex red");
    assert_eq_i32(css_parse_color("red"),     255*65536, "named red");
    assert_eq_i32(css_parse_color("Blue"),    255, "named Blue case-insensitive");
    assert_eq_i32(css_parse_color("rgb(10, 20, 30)"), 10*65536 + 20*256 + 30, "rgb triple");
    assert_eq_i32(css_parse_color("not-a-color"), -1, "invalid color -> -1");

    println("=== CSS Comment Strip ===");
    assert_eq_str(css_strip_comments("a /* x */ b"), "a  b", "strip simple comment");
    assert_eq_str(css_strip_comments("/* all */"), "", "strip whole comment");
    assert_eq_str(css_strip_comments("no-comments"), "no-comments", "strip no-op");

    println("=== CSS Simple Selector Parse ===");
    let s1: CssSimple = css_parse_simple("h1");
    assert_eq_str(s1.tag, "h1", "simple tag selector");
    assert_eq_str(s1.cls, "", "simple tag has no class");

    let s2: CssSimple = css_parse_simple(".warn");
    assert_eq_str(s2.tag, "", "class-only has no tag");
    assert_eq_str(s2.cls, "warn", "class selector");

    let s3: CssSimple = css_parse_simple("#main");
    assert_eq_str(s3.id, "main", "id selector");

    let s4: CssSimple = css_parse_simple("h1.title");
    assert_eq_str(s4.tag, "h1", "compound tag");
    assert_eq_str(s4.cls, "title", "compound class");

    let s5: CssSimple = css_parse_simple("*");
    assert_eq_str(s5.tag, "*", "universal selector");

    let s6: CssSimple = css_parse_simple("h1>p");
    assert_eq_str(s6.tag, "__fail__", "child combinator rejected");

    println("=== CSS Selector List Validator ===");
    assert_true(css_selector_list_supported("h1"), "h1 supported");
    assert_true(css_selector_list_supported("h1, h2, p"), "selector list supported");
    assert_true(css_selector_list_supported(".a.b"), "compound supported");
    assert_true(not css_selector_list_supported("div > p"), "child combinator rejected");
    assert_true(not css_selector_list_supported("p:hover"), "pseudo rejected");
    assert_true(css_selector_list_supported("div p"), "descendant combinator supported");
    assert_true(css_selector_list_supported("nav a.x, .y h2"), "mixed descendants supported");
    assert_true(not css_selector_list_supported("a > b, .x y"), "list with one bad rejected");

    println("=== CSS Parser ===");
    let mut rules: [CssRule] = [];
    let src1: str = "h1 {{ color: red; font-weight: bold; }}\n.note {{ color: #00ff00 !important; }}\n/* comment */ p, div {{ color: blue; }}\n@media screen {{ skip-me {{ color: black; }} }}\n";
    let _o: i32 = css_parse(rules, src1, 0);
    assert_eq_i32(len(rules), 3, "parsed 3 rules");

    assert_eq_i32(len(rules[0].selectors), 1, "h1 has 1 selector");
    assert_eq_str(rules[0].selectors[0].parts[0].tag, "h1", "h1 selector tag");
    assert_eq_i32(len(rules[0].decls), 2, "h1 has 2 decls");
    assert_eq_str(rules[0].decls[0].property, "color", "h1 first decl property");
    assert_eq_str(rules[0].decls[1].property, "font-weight", "h1 second decl property");

    assert_eq_str(rules[1].decls[0].property, "color", ".note color property");
    assert_true(rules[1].decls[0].important, ".note color !important parsed");

    assert_eq_i32(len(rules[2].selectors), 2, "p, div has 2 selectors");

    println("=== CSS Specificity ===");
    let sp_tag:  i32 = css_specificity(CssSimple { tag: "h1", id: "", cls: "" });
    let sp_cls:  i32 = css_specificity(CssSimple { tag: "",   id: "", cls: "a" });
    let sp_id:   i32 = css_specificity(CssSimple { tag: "",   id: "x", cls: "" });
    let sp_comb: i32 = css_specificity(CssSimple { tag: "h1", id: "x", cls: "a" });
    assert_true(sp_cls > sp_tag, "class beats tag");
    assert_true(sp_id > sp_cls, "id beats class");
    assert_true(sp_comb > sp_id, "id+class+tag beats id alone");

    println("=== CSS Matching ===");
    let mut nodes: [HtmlNode] = [];
    // Build: <div id="main" class="a b"><p class="b">x</p></div>
    let root_attrs: map = map_new();
    let root_node: HtmlNode = html_node_element("div", root_attrs);
    push(nodes, root_node);
    nodes[0].attrs = map_new();
    map_set(nodes[0].attrs, "id", "main");
    map_set(nodes[0].attrs, "class", "a b");

    let p_attrs: map = map_new();
    let p_node: HtmlNode = html_node_element("p", p_attrs);
    push(nodes, p_node);
    nodes[1].attrs = map_new();
    map_set(nodes[1].attrs, "class", "b");

    html_append_child(nodes, 0, 1);

    let sel_div: CssSimple = CssSimple { tag: "div", id: "", cls: "" };
    let sel_b:   CssSimple = CssSimple { tag: "",   id: "", cls: "b" };
    let sel_id:  CssSimple = CssSimple { tag: "",   id: "main", cls: "" };
    let sel_mis: CssSimple = CssSimple { tag: "",   id: "", cls: "z" };

    assert_true(css_simple_matches(sel_div, nodes[0]), "div matches div");
    assert_true(css_simple_matches(sel_b,   nodes[0]), ".b matches div.b");
    assert_true(css_simple_matches(sel_b,   nodes[1]), ".b matches p.b");
    assert_true(css_simple_matches(sel_id,  nodes[0]), "#main matches");
    assert_true(not css_simple_matches(sel_mis, nodes[0]), ".z does not match");
    assert_true(not css_simple_matches(sel_div, nodes[1]), "div does not match p");

    println("=== CSS Cascade / Inherit ===");
    let mut rules2: [CssRule] = [];
    let src2: str = "div {{ color: red; }}\np {{ color: blue; }}\n.b {{ color: green; }}\n#main {{ background-color: yellow; }}\n";
    let _o2: i32 = css_parse(rules2, src2, 0);

    let mut styles: [ComputedStyle] = [];
    css_compute_all(nodes, 0, rules2, styles);

    assert_eq_i32(len(styles), len(nodes), "styles parallel to nodes");

    // div#main.a.b: id wins → color = red? No: #main only sets bg.
    // "div" (spec 1) and ".b" (spec 100) both match div → .b wins → green
    assert_eq_i32(styles[0].color, css_parse_color("green"), "div.b picks .b green");
    assert_eq_i32(styles[0].bg_color, css_parse_color("yellow"), "#main bg yellow");
    assert_true(not styles[0].display_none, "div not display-none");

    // p.b: "p" (spec 1) and ".b" (spec 100) match → .b wins → green
    assert_eq_i32(styles[1].color, css_parse_color("green"), "p.b picks .b green");
    // bg does not inherit → p has no bg
    assert_eq_i32(styles[1].bg_color, -1, "p.b bg not inherited");

    println("=== CSS Inline style override ===");
    let mut nodes3: [HtmlNode] = [];
    let a3: map = map_new();
    let n3: HtmlNode = html_node_element("p", a3);
    push(nodes3, n3);
    nodes3[0].attrs = map_new();
    map_set(nodes3[0].attrs, "style", "color: red; font-weight: bold");

    let mut rules3: [CssRule] = [];
    let _o3: i32 = css_parse(rules3, "p {{ color: blue; }}", 0);
    let mut styles3: [ComputedStyle] = [];
    css_compute_all(nodes3, 0, rules3, styles3);
    assert_eq_i32(styles3[0].color, css_parse_color("red"), "inline beats rule");
    assert_eq_i32(styles3[0].bold, 1, "inline font-weight bold");

    println("=== CSS Display: none ===");
    let mut nodes4: [HtmlNode] = [];
    let a4: map = map_new();
    let n4: HtmlNode = html_node_element("div", a4);
    push(nodes4, n4);
    nodes4[0].attrs = map_new();
    map_set(nodes4[0].attrs, "style", "display: none");
    let mut rules4: [CssRule] = [];
    let mut styles4: [ComputedStyle] = [];
    css_compute_all(nodes4, 0, rules4, styles4);
    assert_true(styles4[0].display_none, "display:none honored");

    println("=== CSS text-decoration ===");
    let mut nodes5: [HtmlNode] = [];
    let a5: map = map_new();
    let n5: HtmlNode = html_node_element("span", a5);
    push(nodes5, n5);
    nodes5[0].attrs = map_new();
    map_set(nodes5[0].attrs, "style", "text-decoration: underline line-through");
    let mut rules5: [CssRule] = [];
    let mut styles5: [ComputedStyle] = [];
    css_compute_all(nodes5, 0, rules5, styles5);
    assert_eq_i32(styles5[0].underline, 1, "underline set");
    assert_eq_i32(styles5[0].strike, 1, "line-through set");

    println("=== CSS collect <style> ===");
    let mut dom: [HtmlNode] = [];
    let root: i32 = html_parse(dom, "<html><head><style>p {{ color: red; }}</style></head><body><p>hi</p></body></html>");
    assert_true(root >= 0, "parsed HTML with <style>");
    let mut texts: [str] = [];
    css_collect_style_texts(dom, root, texts);
    assert_eq_i32(len(texts), 1, "one <style> collected");
    assert_true(str_contains(texts[0], "color: red"), "style text captured");

    println("=== CSS text-align ===");
    let mut nodes_ta: [HtmlNode] = [];
    let a_ta: map = map_new();
    let n_ta: HtmlNode = html_node_element("h1", a_ta);
    push(nodes_ta, n_ta);
    nodes_ta[0].attrs = map_new();
    map_set(nodes_ta[0].attrs, "style", "text-align: center");
    let mut rules_ta: [CssRule] = [];
    let mut styles_ta: [ComputedStyle] = [];
    css_compute_all(nodes_ta, 0, rules_ta, styles_ta);
    assert_eq_i32(styles_ta[0].text_align, 1, "text-align:center = 1");

    // Inheritance: parent body with text-align:right should propagate to child p.
    let mut dom_ta: [HtmlNode] = [];
    let root_ta: i32 = html_parse(dom_ta, "<body style=\"text-align: right\"><p>x</p></body>");
    let mut rules_ta2: [CssRule] = [];
    let mut styles_ta2: [ComputedStyle] = [];
    css_compute_all(dom_ta, root_ta, rules_ta2, styles_ta2);
    // Find the <p> child and confirm it inherited text_align = 2.
    let mut found_p: i32 = -1;
    for pi in 0..len(dom_ta) {
        if not dom_ta[pi].is_text and str_eq(dom_ta[pi].tag, "p") { found_p = pi; };
    };
    assert_true(found_p >= 0, "found <p> node");
    assert_eq_i32(styles_ta2[found_p].text_align, 2, "text-align:right inherited to child");

    println("=== CSS descendant combinator ===");
    // Parse a compound
    let c1: CssCompound = css_parse_compound("nav a");
    assert_eq_i32(len(c1.parts), 2, "compound nav a has 2 parts");
    assert_eq_str(c1.parts[0].tag, "nav", "outer is nav");
    assert_eq_str(c1.parts[1].tag, "a", "subject is a");

    let c2: CssCompound = css_parse_compound("  article  .title  ");
    assert_eq_i32(len(c2.parts), 2, "whitespace collapsed");
    assert_eq_str(c2.parts[0].tag, "article", "first part article");
    assert_eq_str(c2.parts[1].cls, "title", "second part .title class");

    // Specificity = sum of parts
    let spec_c1: i32 = css_compound_specificity(c1);
    assert_eq_i32(spec_c1, 2, "nav + a specificity = 1+1");
    let spec_c2: i32 = css_compound_specificity(c2);
    assert_eq_i32(spec_c2, 101, "article + .title = 1 + 100");

    // Build: <nav><p><a>x</a></p></nav>
    let mut dc_nodes: [HtmlNode] = [];
    let nav_node: HtmlNode = html_node_element("nav", map_new());
    push(dc_nodes, nav_node);
    let p_wrap: HtmlNode = html_node_element("p", map_new());
    push(dc_nodes, p_wrap);
    let a_leaf: HtmlNode = html_node_element("a", map_new());
    push(dc_nodes, a_leaf);
    html_append_child(dc_nodes, 0, 1);
    html_append_child(dc_nodes, 1, 2);

    // Ancestor path to the <a>: [nav_idx, p_idx]
    let mut anc_a: [i32] = [];
    push(anc_a, 0);
    push(anc_a, 1);
    assert_true(css_compound_matches(c1, dc_nodes[2], dc_nodes, anc_a),
                "nav a matches <a> under <nav>");

    // Build a sibling <a> that is NOT under <nav>
    let mut other_nodes: [HtmlNode] = [];
    let body_node: HtmlNode = html_node_element("body", map_new());
    push(other_nodes, body_node);
    let a_only: HtmlNode = html_node_element("a", map_new());
    push(other_nodes, a_only);
    html_append_child(other_nodes, 0, 1);
    let mut anc_b: [i32] = [];
    push(anc_b, 0);
    assert_true(not css_compound_matches(c1, other_nodes[1], other_nodes, anc_b),
                "nav a does NOT match <a> not under <nav>");

    // End-to-end via cascade: #main .inner should apply inside a <div id=main>.
    let mut dom_dc: [HtmlNode] = [];
    let r_dc: i32 = html_parse(dom_dc,
        "<div id=\"main\"><p><span class=\"inner\">hi</span></p></div><span class=\"inner\">out</span>");
    let mut rules_dc: [CssRule] = [];
    let _odc: i32 = css_parse(rules_dc, "#main .inner {{ color: red; }}", 0);
    let mut styles_dc: [ComputedStyle] = [];
    css_compute_all(dom_dc, r_dc, rules_dc, styles_dc);

    let mut inner_inside: i32 = -1;
    let mut inner_outside: i32 = -1;
    for qi in 0..len(dom_dc) {
        if not dom_dc[qi].is_text and str_eq(dom_dc[qi].tag, "span") {
            let cls: str = html_get_attr(dom_dc[qi], "class");
            if str_eq(cls, "inner") {
                // First match is inside #main (document order); second is outside.
                if inner_inside < 0 { inner_inside = qi; }
                else { inner_outside = qi; };
            };
        };
    };
    assert_true(inner_inside >= 0 and inner_outside >= 0, "found both .inner spans");
    assert_eq_i32(styles_dc[inner_inside].color, css_parse_color("red"),
                  "#main .inner matches inside");
    assert_eq_i32(styles_dc[inner_outside].color, -1,
                  "#main .inner does NOT match outside");

    println("=== CSS collect sources (link + style) ===");
    let mut dom_src: [HtmlNode] = [];
    let r_src: i32 = html_parse(dom_src,
        "<html><head><link rel=\"stylesheet\" href=\"a.css\"><style>p {{ color: red; }}</style><link rel=\"icon\" href=\"x.ico\"></head><body><p>hi</p></body></html>");
    assert_true(r_src >= 0, "parsed HTML with link + style");
    let mut ks: [i32] = [];
    let mut vs: [str] = [];
    css_collect_sources(dom_src, r_src, ks, vs);
    assert_eq_i32(len(ks), 2, "two sources collected (link + style)");
    assert_eq_i32(ks[0], 1, "first source is <link> (kind 1)");
    assert_eq_str(vs[0], "a.css", "link href captured");
    assert_eq_i32(ks[1], 0, "second source is <style> (kind 0)");
    assert_true(str_contains(vs[1], "color: red"), "style text captured");

    println("=== CSS Phase 3 — padding / max-width / line-height / margin-auto ===");
    let mut np3: [HtmlNode] = [];
    let np3_node: HtmlNode = html_node_element("div", map_new());
    push(np3, np3_node);
    np3[0].attrs = map_new();
    map_set(np3[0].attrs, "style",
        "padding: 10px 20px; max-width: 720px; line-height: 24px; margin: 0 auto");
    let mut rp3: [CssRule] = [];
    let mut sp3: [ComputedStyle] = [];
    css_compute_all(np3, 0, rp3, sp3);
    assert_eq_i32(sp3[0].pad_t, 10, "padding shorthand T=10");
    assert_eq_i32(sp3[0].pad_r, 20, "padding shorthand R=20");
    assert_eq_i32(sp3[0].pad_b, 10, "padding shorthand B=10");
    assert_eq_i32(sp3[0].pad_l, 20, "padding shorthand L=20");
    assert_eq_i32(sp3[0].max_width_px, 720, "max-width px");
    assert_eq_i32(sp3[0].max_width_pct, -1, "max-width px has no pct");
    assert_eq_i32(sp3[0].line_height_px, 24, "line-height 24px");
    assert_eq_i32(sp3[0].center_block, 1, "margin:0 auto centers");

    // max-width percent
    let mut np3b: [HtmlNode] = [];
    let np3b_node: HtmlNode = html_node_element("div", map_new());
    push(np3b, np3b_node);
    np3b[0].attrs = map_new();
    map_set(np3b[0].attrs, "style", "max-width: 50%");
    let mut rp3b: [CssRule] = [];
    let mut sp3b: [ComputedStyle] = [];
    css_compute_all(np3b, 0, rp3b, sp3b);
    assert_eq_i32(sp3b[0].max_width_pct, 50, "max-width 50%");

    // line-height unitless -> multiplier stored separately from px
    let mut np3c: [HtmlNode] = [];
    let np3c_node: HtmlNode = html_node_element("div", map_new());
    push(np3c, np3c_node);
    np3c[0].attrs = map_new();
    map_set(np3c[0].attrs, "style", "line-height: 1.5");
    let mut rp3c: [CssRule] = [];
    let mut sp3c: [ComputedStyle] = [];
    css_compute_all(np3c, 0, rp3c, sp3c);
    assert_eq_i32(sp3c[0].line_height_mul_x100, 150, "line-height 1.5 -> mul 150");
    assert_eq_i32(sp3c[0].line_height_px, -1, "line-height 1.5 leaves px unset");

    // line-height inherits; padding/max-width/center do NOT.
    let mut dom_in: [HtmlNode] = [];
    let r_in: i32 = html_parse(dom_in,
        "<body style=\"line-height: 24px; padding: 10px; max-width: 500px; margin: 0 auto\"><p>x</p></body>");
    let mut rules_in: [CssRule] = [];
    let mut styles_in: [ComputedStyle] = [];
    css_compute_all(dom_in, r_in, rules_in, styles_in);
    let mut p_in: i32 = -1;
    for ii in 0..len(dom_in) {
        if not dom_in[ii].is_text and str_eq(dom_in[ii].tag, "p") { p_in = ii; };
    };
    assert_true(p_in >= 0, "found <p> child");
    assert_eq_i32(styles_in[p_in].line_height_px, 24, "line-height inherits to child");
    assert_eq_i32(styles_in[p_in].pad_t, -1, "padding does NOT inherit");
    assert_eq_i32(styles_in[p_in].max_width_px, -1, "max-width does NOT inherit");
    assert_eq_i32(styles_in[p_in].center_block, -1, "center does NOT inherit");

    println("=== CSS Phase 3 — @media (prefers-color-scheme) ===");
    // Dark media applies (OscaWeb is always-dark); light media is skipped.
    let mut dom_m: [HtmlNode] = [];
    let r_m: i32 = html_parse(dom_m, "<h1>hi</h1>");
    let mut rules_m: [CssRule] = [];
    let _om: i32 = css_parse(rules_m,
        "@media (prefers-color-scheme: dark) {{ h1 {{ color: #ff0000; }} }}\n@media (prefers-color-scheme: light) {{ h1 {{ color: #00ff00; }} }}", 0);
    let mut styles_m: [ComputedStyle] = [];
    css_compute_all(dom_m, r_m, rules_m, styles_m);
    let mut h1_i: i32 = -1;
    for mi in 0..len(dom_m) {
        if not dom_m[mi].is_text and str_eq(dom_m[mi].tag, "h1") { h1_i = mi; };
    };
    assert_true(h1_i >= 0, "found <h1>");
    assert_eq_i32(styles_m[h1_i].color, css_parse_color("#ff0000"), "dark media applied");

    println("=== CSS Done ===");
}