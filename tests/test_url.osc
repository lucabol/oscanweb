// Tests for url.osc — URL parsing, serialization, and relative resolution

use "../url.osc"

fn! assert_eq_str(actual: str, expected: str, test_name: str) {
    if str_eq(actual, expected) {
        println("PASS: {test_name}");
    } else {
        println("FAIL: {test_name} - expected '{expected}', got '{actual}'");
    };
}

fn! assert_eq_i32(actual: i32, expected: i32, test_name: str) {
    if actual == expected {
        println("PASS: {test_name}");
    } else {
        println("FAIL: {test_name} - expected {expected}, got {actual}");
    };
}

fn! main() {
    println("=== URL Parser Tests ===");

    // 1. Parse http://example.com
    let u1: Url = url_parse("http://example.com");
    assert_eq_str(u1.scheme, "http", "parse http scheme");
    assert_eq_str(u1.host, "example.com", "parse http host");
    assert_eq_i32(u1.port, 80, "parse http default port");
    assert_eq_str(u1.path, "/", "parse http default path");

    // 2. Parse https://example.com
    let u2: Url = url_parse("https://example.com");
    assert_eq_str(u2.scheme, "https", "parse https scheme");
    assert_eq_str(u2.host, "example.com", "parse https host");
    assert_eq_i32(u2.port, 443, "parse https default port");
    assert_eq_str(u2.path, "/", "parse https default path");

    // 3. Parse http://example.com:8080
    let u3: Url = url_parse("http://example.com:8080");
    assert_eq_str(u3.host, "example.com", "parse custom port host");
    assert_eq_i32(u3.port, 8080, "parse custom port");

    // 4. Parse http://example.com/path/to/page
    let u4: Url = url_parse("http://example.com/path/to/page");
    assert_eq_str(u4.host, "example.com", "parse with path host");
    assert_eq_str(u4.path, "/path/to/page", "parse with path");

    // 5. Parse http://example.com:3000/api
    let u5: Url = url_parse("http://example.com:3000/api");
    assert_eq_str(u5.host, "example.com", "parse port+path host");
    assert_eq_i32(u5.port, 3000, "parse port+path port");
    assert_eq_str(u5.path, "/api", "parse port+path path");

    // 6. Parse bare hostname (no scheme) — defaults to https.  Modern
    // sites overwhelmingly require TLS; omnibox input like "lucabol.com"
    // should resolve to https://lucabol.com/ without forcing the user to
    // type the scheme.
    let u6: Url = url_parse("example.com");
    assert_eq_str(u6.scheme, "https", "no-scheme defaults to https");
    assert_eq_str(u6.host, "example.com", "no-scheme host");
    assert_eq_i32(u6.port, 443, "no-scheme port defaults to 443");

    // 7. url_to_string round-trip
    let rt1: str = url_to_string(url_parse("http://example.com"));
    assert_eq_str(rt1, "http://example.com/", "round-trip http default");

    let rt2: str = url_to_string(url_parse("https://example.com"));
    assert_eq_str(rt2, "https://example.com/", "round-trip https default");

    let rt3: str = url_to_string(url_parse("http://example.com:8080/page"));
    assert_eq_str(rt3, "http://example.com:8080/page", "round-trip custom port+path");

    // 8-10. url_resolve_relative
    let r1: str = url_resolve_relative("/dir/page.html", "other.html");
    assert_eq_str(r1, "/dir/other.html", "resolve relative sibling");

    let r2: str = url_resolve_relative("/dir/page.html", "/absolute");
    assert_eq_str(r2, "/absolute", "resolve absolute path");

    let r3: str = url_resolve_relative("/", "page.html");
    assert_eq_str(r3, "/page.html", "resolve from root");

    // Fragment preserved
    let uf1: Url = url_parse("https://example.com/page#section");
    assert_eq_str(uf1.path, "/page", "fragment stripped from path");
    assert_eq_str(uf1.fragment, "section", "fragment captured");

    let uf2: Url = url_parse("https://example.com/page#");
    assert_eq_str(uf2.path, "/page", "empty fragment stripped");

    let uf3: Url = url_parse("https://example.com/#top");
    assert_eq_str(uf3.path, "/", "fragment at root gives /");
    assert_eq_str(uf3.fragment, "top", "fragment captured at root");

    // Query string PRESERVED (needed for search URLs, permalinks)
    let uq1: Url = url_parse("https://example.com/search?q=test");
    assert_eq_str(uq1.path, "/search?q=test", "query string preserved in path");

    // Fragment serialises back out
    let rtf: str = url_to_string(url_parse("https://example.com/page#sec"));
    assert_eq_str(rtf, "https://example.com/page#sec", "round-trip with fragment");

    // URL-vs-query heuristic
    if url_looks_like_url("http://x") { println("PASS: url with scheme"); } else { println("FAIL: url with scheme"); };
    if url_looks_like_url("example.com") { println("PASS: bare hostname"); } else { println("FAIL: bare hostname"); };
    if url_looks_like_url("localhost:8000") { println("PASS: localhost"); } else { println("FAIL: localhost"); };
    if not url_looks_like_url("news today") { println("PASS: query with space"); } else { println("FAIL: query with space"); };
    if not url_looks_like_url("weather") { println("PASS: dotless query"); } else { println("FAIL: dotless query"); };
    if not url_looks_like_url("") { println("PASS: empty not a URL"); } else { println("FAIL: empty not a URL"); };

    // url_encode
    assert_eq_str(url_encode("hello world"), "hello%20world", "encode space");
    assert_eq_str(url_encode("a+b=c"), "a%2Bb%3Dc", "encode special chars");
    assert_eq_str(url_encode("abc-_.~"), "abc-_.~", "unreserved preserved");

    // url_decode
    assert_eq_str(url_decode("hello%20world"), "hello world", "decode space");
    assert_eq_str(url_decode("a%2Bb%3Dc"), "a+b=c", "decode special chars");
    assert_eq_str(url_decode("plain"), "plain", "decode no-op plain text");
    assert_eq_str(url_decode("%2F"), "/", "decode slash");
    assert_eq_str(url_decode("bad%ZZ"), "bad%ZZ", "decode invalid escape passthrough");

    // url_unwrap_tracking - DuckDuckGo redirect
    let ddg1: str = url_unwrap_tracking("//duckduckgo.com/l/?uddg=https%3A%2F%2Fen.wikipedia.org%2Fwiki%2FRust&rut=abc123");
    assert_eq_str(ddg1, "https://en.wikipedia.org/wiki/Rust", "unwrap DDG protocol-relative");

    let ddg2: str = url_unwrap_tracking("https://duckduckgo.com/l/?uddg=https%3A%2F%2Frust-lang.org%2F");
    assert_eq_str(ddg2, "https://rust-lang.org/", "unwrap DDG https with no extra params");

    let ddg3: str = url_unwrap_tracking("/l/?uddg=https%3A%2F%2Fexample.com%2F&rut=xyz");
    assert_eq_str(ddg3, "https://example.com/", "unwrap DDG path-relative");

    // Non-tracking URLs pass through unchanged
    assert_eq_str(url_unwrap_tracking("https://example.com/page"), "https://example.com/page", "unwrap passthrough normal url");
    assert_eq_str(url_unwrap_tracking("/local/path"), "/local/path", "unwrap passthrough relative path");

    // url_resolve_relative: safety for accidental absolute URLs
    assert_eq_str(url_resolve_relative("/dir/page", "https://other.com/x"),
                  "https://other.com/x",
                  "resolve_relative passes through absolute https");
    assert_eq_str(url_resolve_relative("/dir/page", "http://other.com/x"),
                  "http://other.com/x",
                  "resolve_relative passes through absolute http");

    // url_resolve_full: the real entry point for link navigation
    assert_eq_str(url_resolve_full("https://en.wikipedia.org/wiki/HTTP", "/wiki/Hypertext"),
                  "https://en.wikipedia.org/wiki/Hypertext",
                  "resolve_full root-relative");
    assert_eq_str(url_resolve_full("https://en.wikipedia.org/wiki/HTTP", "Hypertext"),
                  "https://en.wikipedia.org/wiki/Hypertext",
                  "resolve_full path-relative");
    assert_eq_str(url_resolve_full("https://en.wikipedia.org/wiki/HTTP", "https://example.com/x"),
                  "https://example.com/x",
                  "resolve_full absolute https unchanged");
    assert_eq_str(url_resolve_full("https://en.wikipedia.org/wiki/HTTP", "http://example.com/x"),
                  "http://example.com/x",
                  "resolve_full absolute http unchanged");
    assert_eq_str(url_resolve_full("https://en.wikipedia.org/wiki/HTTP", "//upload.wikimedia.org/foo.png"),
                  "https://upload.wikimedia.org/foo.png",
                  "resolve_full protocol-relative inherits https");
    assert_eq_str(url_resolve_full("http://example.com/page", "//other.com/bar"),
                  "http://other.com/bar",
                  "resolve_full protocol-relative inherits http");
    assert_eq_str(url_resolve_full("https://en.wikipedia.org/wiki/HTTP", "#History"),
                  "https://en.wikipedia.org/wiki/HTTP#History",
                  "resolve_full fragment-only keeps path");
    assert_eq_str(url_resolve_full("https://example.com/a/b/c.html", "d.html"),
                  "https://example.com/a/b/d.html",
                  "resolve_full sibling resolution");

    println("=== URL Tests Complete ===");
}
